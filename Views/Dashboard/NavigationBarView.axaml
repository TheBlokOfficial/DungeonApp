<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:DungeonApp.ViewModels"
             x:Class="DungeonApp.Views.NavigationBarView"
             x:DataType="vm:MainWindowViewModel"
             x:Name="Root">
    
    <UserControl.Styles>
        <!-- Domyślny styl przycisków nawigacji -->
        <Style Selector="Button.navButton">
            <Setter Property="Background" Value="Transparent" />
        </Style>
        <Style Selector="Button.navButton:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="{DynamicResource BorderSecondary}" />
        </Style>
        
        <!-- Styl włączony tylko dla AKTYWNEJ zakładki -->
        <Style Selector="Button.navButton.active /template/ ContentPresenter">
            <Setter Property="Background" Value="{DynamicResource BorderSecondary}" />
        </Style>
        <Style Selector="Button.navButton.active TextBlock">
            <Setter Property="FontWeight" Value="Bold" />
            <Setter Property="Foreground" Value="{DynamicResource TextPrimary}" />
        </Style>
    </UserControl.Styles>
    
    <Border Background="{DynamicResource CardBackground}">
        <StackPanel Margin="20" Spacing="8">
            <!-- Logo / Tytuł -->
            <TextBlock Text="DUNGEON" FontSize="28" FontWeight="Bold" Foreground="{DynamicResource AccentGold}" />
            <TextBlock Text="Session Manager" FontSize="16" Foreground="{DynamicResource TextPrimary}" Margin="0,0,0,40" />

            <TextBlock Text="GŁÓWNE MENU" FontSize="12" FontWeight="Bold" Foreground="{DynamicResource TextMuted}" Margin="0,0,0,8" />

            <!-- Przycisk: Kampanie -->
            <Button Classes="navButton" Classes.active="{Binding IsCampaignsVisible}"
                    Command="{Binding ShowCampaignsCommand}"
                    BorderThickness="0" CornerRadius="6" FontSize="15" Padding="15,12" HorizontalAlignment="Stretch"
                    HorizontalContentAlignment="Left">
                <StackPanel Orientation="Horizontal" Spacing="12">
                    <!-- Ikona zawsze świeci na złoto -->
                    <PathIcon Data="{StaticResource IconShield}" Width="16" Height="16" Foreground="{DynamicResource AccentGold}" />
                    <TextBlock Text="Kampanie RPG" VerticalAlignment="Center" Foreground="{DynamicResource TextSecondary}" />
                </StackPanel>
            </Button>

            <!-- Przycisk: Bohaterowie -->
            <Button Classes="navButton" Classes.active="{Binding IsCharactersVisible}"
                    Command="{Binding ShowCharactersCommand}"
                    BorderThickness="0" CornerRadius="6" FontSize="15" Padding="15,12" HorizontalAlignment="Stretch"
                    HorizontalContentAlignment="Left">
                <StackPanel Orientation="Horizontal" Spacing="12">
                    <!-- Ikona zawsze świeci na złoto -->
                    <PathIcon Data="{StaticResource IconSwords}" Width="16" Height="16" Foreground="{DynamicResource AccentGold}" />
                    <TextBlock Text="Rejestr Postaci" VerticalAlignment="Center" Foreground="{DynamicResource TextSecondary}" />
                </StackPanel>
            </Button>
            <TextBlock Text="SYSTEM" FontSize="12" FontWeight="Bold" Foreground="{DynamicResource TextMuted}" Margin="0,16,0,8" />
            <!-- Przycisk: Ustawienia -->
            <Button Classes="navButton" Classes.active="{Binding IsSettingsVisible}"
                    Command="{Binding ShowSettingsCommand}"
                    BorderThickness="0" CornerRadius="6" FontSize="15" Padding="15,12" HorizontalAlignment="Stretch"
                    HorizontalContentAlignment="Left">
                <StackPanel Orientation="Horizontal" Spacing="12">
                    <!-- Ikona zawsze świeci na złoto -->
                    <PathIcon Data="{StaticResource IconSettings}" Width="16" Height="16" Foreground="{DynamicResource AccentGold}" />
                    <TextBlock Text="Ustawienia Opcji" VerticalAlignment="Center" Foreground="{DynamicResource TextSecondary}" />
                </StackPanel>
            </Button>
        </StackPanel>
    </Border>
</UserControl>