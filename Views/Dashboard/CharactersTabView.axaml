<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:DungeonApp.ViewModels"
             x:Class="DungeonApp.Views.Dashboard.CharactersTabView"
             x:DataType="vm:MainWindowViewModel"
             x:Name="Root">

    <Grid ColumnDefinitions="350, *">
        <!-- LEWA: Lista postaci -->
        <Grid Grid.Column="0" RowDefinitions="Auto, *" Margin="0,0,30,0">
            <Grid Grid.Row="0" ColumnDefinitions="*, Auto" Margin="0,0,0,24">
                <TextBlock Grid.Column="0" Text="Postacie" FontSize="28" FontWeight="Bold" Foreground="{DynamicResource TextPrimary}" VerticalAlignment="Center"/>
                <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8">
                    <Button Classes="icon" Command="{Binding RefreshCharactersCommand}">
                        <PathIcon Data="{StaticResource IconReload}" Width="16" Height="16" />
                    </Button>
                    <Button Classes="primary" Command="{Binding CreateNewCharacterCommand}" Padding="8">
                        <PathIcon Data="{StaticResource IconAdd}" Width="16" Height="16" />
                    </Button>
                </StackPanel>
            </Grid>

            <ScrollViewer Grid.Row="1">
                <ItemsControl ItemsSource="{Binding Characters}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Button Classes="card" Command="{Binding ((vm:MainWindowViewModel)DataContext).SelectCharacterCommand, ElementName=Root, FallbackValue=null}" 
                                    CommandParameter="{Binding}" Margin="0,0,0,12">
                                <StackPanel>
                                    <TextBlock Text="{Binding CharacterName}" FontSize="16" FontWeight="Bold" Foreground="{DynamicResource TextSecondary}" />
                                    <TextBlock Text="{Binding ClassAndLevel}" FontSize="12" Foreground="{DynamicResource TextMuted}" Margin="0,4,0,0"/>
                                </StackPanel>
                            </Button>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
        </Grid>

        <!-- PRAWA: Szczegóły postaci (Widoczne tylko po wybraniu) -->
        <Border Grid.Column="1" IsVisible="{Binding SelectedCharacter, Converter={x:Static ObjectConverters.IsNotNull}}" Background="{DynamicResource CardBackground}" CornerRadius="12" BorderBrush="{DynamicResource BorderSecondary}" BorderThickness="1" Padding="40" VerticalAlignment="Stretch">
            <StackPanel>
                <Grid ColumnDefinitions="*, Auto" Margin="0,0,0,24">
                    <StackPanel Grid.Column="0">
                        <TextBlock Text="{Binding SelectedCharacter.CharacterName}" FontSize="32" FontWeight="Bold" Foreground="{DynamicResource AccentGold}" TextWrapping="Wrap"/>
                        <StackPanel Orientation="Horizontal" Spacing="6" Margin="0,8,0,0">
                            <TextBlock Text="Gra:" FontSize="14" Foreground="{DynamicResource TextMuted}" />
                            <TextBlock Text="{Binding SelectedCharacter.PlayerName}" FontSize="14" Foreground="{DynamicResource TextSecondary}" FontWeight="SemiBold" />
                        </StackPanel>
                    </StackPanel>
                    <Button Grid.Column="1" Classes="dangerGhost" Command="{Binding DeleteCharacterCommand}" CommandParameter="{Binding SelectedCharacter}" VerticalAlignment="Top">
                        <StackPanel Orientation="Horizontal" Spacing="6">
                            <PathIcon Data="{StaticResource IconTrash}" Width="14" Height="14" />
                            <TextBlock Text="Usuń" FontSize="13"/>
                        </StackPanel>
                    </Button>
                </Grid>
                
                <Border BorderThickness="0,0,0,1" BorderBrush="{DynamicResource BorderSecondary}" Margin="0,0,0,24" />

                <Grid RowDefinitions="Auto, Auto" ColumnDefinitions="150, *">
                    <TextBlock Grid.Row="0" Grid.Column="0" Text="Rasa" Foreground="{DynamicResource TextMuted}" FontSize="13" Margin="0,0,0,16"/>
                    <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding SelectedCharacter.Race}" Foreground="{DynamicResource TextPrimary}" FontSize="15" FontWeight="Medium" Margin="0,0,0,16"/>
                    
                    <TextBlock Grid.Row="1" Grid.Column="0" Text="Klasa i Poziom" Foreground="{DynamicResource TextMuted}" FontSize="13"/>
                    <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding SelectedCharacter.ClassAndLevel}" Foreground="{DynamicResource TextPrimary}" FontSize="15" FontWeight="Medium"/>
                </Grid>

                <Button Classes="primary" Command="{Binding ((vm:MainWindowViewModel)DataContext).OpenCharacterDetailCommand, ElementName=Root}" CommandParameter="{Binding SelectedCharacter}" HorizontalAlignment="Stretch" Margin="0,40,0,0">
                    <TextBlock Text="Otwórz pełną Kartę Postaci" FontSize="14" />
                </Button>
            </StackPanel>
        </Border>
        
        <!-- PUSTY STAN (Gdy nic nie wybrano) -->
        <Border Grid.Column="1" IsVisible="{Binding SelectedCharacter, Converter={x:Static ObjectConverters.IsNull}}" Background="{DynamicResource CardBackground}" CornerRadius="12" BorderBrush="{DynamicResource BorderSecondary}" BorderThickness="1" Padding="40" VerticalAlignment="Stretch">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Spacing="16">
                <PathIcon Data="{StaticResource IconSwords}" Width="48" Height="48" Foreground="{DynamicResource BorderInput}"/>
                <TextBlock Text="Wybierz bohatera z listy po lewej, aby zobaczyć szczegóły." Foreground="{DynamicResource TextMuted}" FontSize="14"/>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>