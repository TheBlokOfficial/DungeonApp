<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:DungeonApp.ViewModels.Dashboard"
             xmlns:module="using:DungeonApp.Models.Campaigns.Engine.Modules.Timekeeper"
             xmlns:moduleCore="using:DungeonApp.Models.Campaigns.Engine.Modules.Core"
             xmlns:moduleViews="using:DungeonApp.Views.Campaigns.Modules"
             xmlns:controls="using:DungeonApp.Controls"
             x:Class="DungeonApp.Views.Dashboard.SandboxTabView"
             x:DataType="vm:SandboxTabViewModel"
             x:CompileBindings="False">

    <UserControl.DataTemplates>
        <DataTemplate DataType="module:TimekeeperModule">
            <moduleViews:TimekeeperView />
        </DataTemplate>
        <DataTemplate DataType="moduleCore:ConsoleModule">
            <moduleViews:ConsoleView />
        </DataTemplate>
    </UserControl.DataTemplates>

    <!--
        GŁÓWNA SIATKA: 3 wiersze
        Row 0 — Nagłówek (Auto)
        Row 1 — Canvas z pływającym panelem modułu (*)
        Row 2 — Konsola zakotwiczona na dole (~40% szerokości, Auto)

        DLACZEGO Canvas zamiast HorizontalAlignment="Center":
        Z Center-alignment każda zmiana Width podczas resize przelicza
        pozycję lewego marginesu — panel "walczy" ze swoją pozycją i drży.
        Canvas ustawia Left/Top RAZ (CenterPanel() przy starcie) i nigdy
        już nie zmienia pozycji podczas resize — tylko Width/Height rosną.
        Brak przeliczania pozycji = zero drżenia.
    -->
    <Grid RowDefinitions="Auto, *, Auto" Margin="30,20,30,0">

        <!-- ═══════════════════════════════════════════════════════════
             ROW 0 — NAGŁÓWEK
             ═══════════════════════════════════════════════════════════ -->
        <StackPanel Grid.Row="0"
                    Orientation="Horizontal" Spacing="10"
                    VerticalAlignment="Center"
                    Margin="0,0,0,16">
            <TextBlock Text="WORKBENCH"
                       FontSize="12" FontWeight="Bold" LetterSpacing="2"
                       Foreground="{DynamicResource TextMuted}"
                       VerticalAlignment="Center"
                       TextTrimming="CharacterEllipsis"/>
            <Border Background="{DynamicResource AccentGold}"
                    CornerRadius="2" Padding="6,2">
                <TextBlock Text="TRYB DEWELOPERSKI"
                           FontSize="10" FontWeight="Bold"
                           Foreground="Black" LetterSpacing="1"/>
            </Border>
        </StackPanel>

        <!-- ═══════════════════════════════════════════════════════════
             ROW 1 — CANVAS z pływającym panelem modułu
             ClipToBounds zapobiega wychodzeniu panelu poza obszar.
             Usunięto tło, by moduł wisiał bezpośrednio na szarym tle aplikacji.
             ═══════════════════════════════════════════════════════════ -->
        <Canvas Grid.Row="1" x:Name="WorkCanvas" ClipToBounds="True" Margin="0,0,0,16">

            <!-- ───────────────────────────────────────────────────
                 Panel modułu pozycjonowany absolutnie przez code-behind
                 (CenterPanel() ustawia Canvas.Left/Top raz przy starcie).
                 Resize grip ◢ zmienia tylko Width/Height — bez dotykania
                 Canvas.Left/Top, co eliminuje drżenie podczas resize.
                 ─────────────────────────────────────────────────── -->
            <controls:FloatingPanel x:Name="ModulePanel"
                                    PanelTitle="Core.Timekeeper">
                <controls:FloatingPanel.PanelContent>
                    <ContentControl Content="{Binding TimekeeperModule}"
                                    HorizontalAlignment="Stretch"
                                    VerticalAlignment="Stretch"
                                    Margin="14,8,14,14"/>
                </controls:FloatingPanel.PanelContent>
            </controls:FloatingPanel>

        </Canvas>

        <!-- ═══════════════════════════════════════════════════════════
             ROW 2 — KONSOLA (~40% szerokości, wyśrodkowana)
             ColumnDefinitions "3*, 4*, 3*" = środkowa kolumna 4/10 = 40%.
             Height="180" — niewysoki terminal.
             ═══════════════════════════════════════════════════════════ -->
        <Grid Grid.Row="2" ColumnDefinitions="3*, 4*, 3*" Margin="0,0,0,24">
            <Border Grid.Column="1"
                    Height="180"
                    Background="{DynamicResource CardBackground}"
                    CornerRadius="6"
                    BorderBrush="{DynamicResource BorderPrimary}"
                    BorderThickness="1"
                    Padding="12,10">
                <ContentControl Content="{Binding ConsoleModule}" />
            </Border>
        </Grid>

    </Grid>
</UserControl>
