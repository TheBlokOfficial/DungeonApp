<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:DungeonApp.ViewModels"
             xmlns:dashboard="clr-namespace:DungeonApp.Views.Dashboard"
             xmlns:views="clr-namespace:DungeonApp.Views"
             xmlns:converters="using:Avalonia.Data.Converters"
             x:Class="DungeonApp.Views.DashboardView"
             x:DataType="vm:MainWindowViewModel"
             x:Name="Root">
    
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto" /> <!-- Główny Sidebar -->
            <ColumnDefinition Width="*" />    <!-- Główna zawartość -->
        </Grid.ColumnDefinitions>

        <!-- KOLUMNA 0: GŁÓWNY SIDEBAR -->
        <views:NavigationBarView Grid.Column="0" Width="{Binding CurrentSidebarWidth}" />
        
        <!-- KOLUMNA 1: GŁÓWNA ZAWARTOŚĆ -->
        <Border Grid.Column="1" Padding="20">
            <!-- Bezpieczny, pojedynczy system wymieniania ekranów (zarówno dashboard jak i ekrany kontekstowe gry) -->
            <TransitioningContentControl Content="{Binding ActiveMainView}">
                <TransitioningContentControl.PageTransition>
                    <CrossFade Duration="0:0:0.25" />
                </TransitioningContentControl.PageTransition>
            </TransitioningContentControl>
        </Border>
    </Grid>
    
</UserControl>
