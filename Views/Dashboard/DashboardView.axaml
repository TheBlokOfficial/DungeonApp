<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:DungeonApp.ViewModels"
             xmlns:dashboard="clr-namespace:DungeonApp.Views.Dashboard"
             xmlns:views="clr-namespace:DungeonApp.Views"
             xmlns:converters="using:Avalonia.Data.Converters"
             x:Class="DungeonApp.Views.DashboardView"
             x:DataType="vm:MainWindowViewModel"
             x:Name="Root">
    
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <views:NavigationBarView Width="{Binding CurrentSidebarWidth}" />
        
        <!-- PRAWY PANEL: GŁÓWNA ZAWARTOŚĆ -->
        <Border Grid.Column="1" Padding="50">
            <Grid>
                <Grid>
                    <dashboard:CampaignsTabView Classes="fadeTab" Classes.active="{Binding IsCampaignsListVisible}" />
                    <dashboard:CharactersTabView Classes="fadeTab" Classes.active="{Binding IsCharactersListVisible}" />
                    <dashboard:SettingsTabView Classes="fadeTab" Classes.active="{Binding IsSettingsVisible}" />
                </Grid>
                
                <!-- Ekran Gry / Ekran Tworzenia Postaci (Zagnieżdżony nad poczekalniami) -->
                <TransitioningContentControl Content="{Binding NavigationService.CurrentView}">
                    <TransitioningContentControl.PageTransition>
                        <CrossFade Duration="0:0:0.25" />
                    </TransitioningContentControl.PageTransition>
                </TransitioningContentControl>
            </Grid>
        </Border>
    </Grid>
    
</UserControl>