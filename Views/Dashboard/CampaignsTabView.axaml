<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:DungeonApp.ViewModels"
             x:Class="DungeonApp.Views.Dashboard.CampaignsTabView"
             x:DataType="vm:MainWindowViewModel"
             x:Name="Root">

    <StackPanel>
        <!-- Nagłówek Kampanii -->
        <Grid ColumnDefinitions="Auto, *, Auto" Margin="0,0,0,30">
            <TextBlock Grid.Column="0" Text="Twoje Kampanie" FontSize="28" FontWeight="Bold" Foreground="{DynamicResource TextPrimary}" VerticalAlignment="Center" />
            
            <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="12" VerticalAlignment="Center">
                <Button Classes="icon" Command="{Binding RefreshCampaignsCommand}" ToolTip.Tip="Odśwież listę">
                    <PathIcon Data="{StaticResource IconReload}" Width="18" Height="18" />
                </Button>
                
                <Button Classes="primary" Command="{Binding CreateNewCampaignCommand}">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <PathIcon Data="{StaticResource IconAdd}" Width="14" Height="14" />
                        <TextBlock Text="Nowa Kampania" />
                    </StackPanel>
                </Button>
            </StackPanel>
        </Grid>
        
        <Border BorderThickness="0,0,0,1" BorderBrush="{DynamicResource BorderSecondary}" Margin="0,0,0,25" />

        <!-- Lista Kampanii przełączona na układ kafelkowy (Grid/Wrap) -->
        <ItemsControl ItemsSource="{Binding Campaigns}">
            <!-- KROK 1: Zmiana sposobu układania elementów na WrapPanel -->
            <ItemsControl.ItemsPanel>
                <ItemsPanelTemplate>
                    <WrapPanel Orientation="Horizontal" />
                </ItemsPanelTemplate>
            </ItemsControl.ItemsPanel>

            <ItemsControl.ItemTemplate>
                <DataTemplate>
                    <!-- KROK 2: Nadanie kafelkowi stałych wymiarów i marginesu z prawej/dołu -->
                    <Button Classes="card"
                            Command="{Binding ((vm:MainWindowViewModel)DataContext).OpenCampaignCommand, ElementName=Root, FallbackValue=null}"
                            CommandParameter="{Binding}"
                            Margin="0,0,16,16"
                            Width="320" Height="145">
                        
                        <!-- KROK 3: Nowy, kompaktowy układ wewnątrz kafelka -->
                        <Grid RowDefinitions="Auto, *, Auto">
                            
                            <!-- GÓRNA SEKCJA: Ikona, Nazwa i Kosz -->
                            <Grid Grid.Row="0" ColumnDefinitions="Auto, *, Auto">
                                <!-- Ikona tarczy -->
                                <Border Grid.Column="0" Background="{DynamicResource BorderSecondary}" CornerRadius="6" Padding="10" Margin="0,0,12,0" VerticalAlignment="Top">
                                    <PathIcon Data="{StaticResource IconShield}" Width="20" Height="20" Foreground="{DynamicResource AccentGold}" />
                                </Border>
                                
                                <!-- Tytuł i system (zabezpieczone przed ucinaniem tekstu) -->
                                <StackPanel Grid.Column="1" VerticalAlignment="Top" Margin="0,2,0,0">
                                    <TextBlock Text="{Binding Name}" FontSize="16" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimary}" TextTrimming="CharacterEllipsis"/>
                                    <TextBlock Text="{Binding System}" Foreground="{DynamicResource TextMuted}" FontSize="13" Margin="0,2,0,0" TextTrimming="CharacterEllipsis"/>
                                </StackPanel>
                                
                                <!-- Przycisk Usuń (w prawym górnym rogu kafelka) -->
                                <Button Grid.Column="3" Classes="iconDanger"
                                        Command="{Binding ((vm:MainWindowViewModel)DataContext).DeleteCampaignCommand, ElementName=Root, FallbackValue=null}"
                                        CommandParameter="{Binding}" VerticalAlignment="Top">
                                    <PathIcon Data="{StaticResource IconTrash}" Width="14" Height="14" />
                                </Button>
                            </Grid>
                            
                            <!-- DOLNA SEKCJA: Statystyki sesji (oddzielone subtelną linią) -->
                            <StackPanel Grid.Row="2" Spacing="2">
                                <Border BorderThickness="0,1,0,0" BorderBrush="{DynamicResource BorderPrimary}" Margin="0,0,0,8"/>
                                <Grid ColumnDefinitions="*, *">
                                    <TextBlock Grid.Column="0" Text="{Binding LastSession, StringFormat='Ostatnia: {0:dd.MM.yyyy}'}" Foreground="{DynamicResource TextMuted}" FontSize="12" VerticalAlignment="Center" />
                                    <TextBlock Grid.Column="1" Text="{Binding SessionsCount, StringFormat='Sesje: {0}'}" Foreground="{DynamicResource TextMuted}" FontSize="12" TextAlignment="Right" VerticalAlignment="Center"/>
                                </Grid>
                            </StackPanel>
                            
                        </Grid>
                    </Button>
                </DataTemplate>
            </ItemsControl.ItemTemplate>
        </ItemsControl>
    </StackPanel>
</UserControl>