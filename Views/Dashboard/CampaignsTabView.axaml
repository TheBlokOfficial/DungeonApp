<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:DungeonApp.ViewModels"
             x:Class="DungeonApp.Views.Dashboard.CampaignsTabView"
             x:DataType="vm:MainWindowViewModel"
             x:Name="Root">

    <StackPanel>
        <!-- Nagłówek Kampanii -->
        <Grid ColumnDefinitions="Auto, *, Auto" Margin="0,0,0,30">
            <TextBlock Grid.Column="0" Text="Twoje Kampanie" FontSize="28" FontWeight="Bold" Foreground="#FFFFFF" VerticalAlignment="Center" />
            
            <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="12" VerticalAlignment="Center">
                <Button Command="{Binding RefreshCampaignsCommand}" Background="Transparent" BorderThickness="0" Padding="10" ToolTip.Tip="Odśwież listę">
                    <Button.Styles><Style Selector="Button:pointerover /template/ ContentPresenter"><Setter Property="Background" Value="#292929" /></Style></Button.Styles>
                    <PathIcon Data="{StaticResource IconReload}" Width="18" Height="18" Foreground="#888888" />
                </Button>
                
                <Button Command="{Binding CreateNewCampaignCommand}" Background="#D4A017" Foreground="#171717" FontWeight="Bold" CornerRadius="6" Padding="20,12">
                    <Button.Styles><Style Selector="Button:pointerover /template/ ContentPresenter"><Setter Property="Background" Value="#E5B027" /></Style></Button.Styles>
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <PathIcon Data="{StaticResource IconAdd}" Width="14" Height="14" Foreground="#171717" />
                        <TextBlock Text="Nowa Kampania" />
                    </StackPanel>
                </Button>
            </StackPanel>
        </Grid>
        
        <Border BorderThickness="0,0,0,1" BorderBrush="#292929" Margin="0,0,0,25" />

        <!-- Lista Kampanii przełączona na układ kafelkowy (Grid/Wrap) -->
        <ItemsControl ItemsSource="{Binding Campaigns}">
            <!-- KROK 1: Zmiana sposobu układania elementów na WrapPanel -->
            <ItemsControl.ItemsPanel>
                <ItemsPanelTemplate>
                    <WrapPanel Orientation="Horizontal" />
                </ItemsPanelTemplate>
            </ItemsControl.ItemsPanel>

            <ItemsControl.ItemTemplate>
                <DataTemplate>
                    <!-- KROK 2: Nadanie kafelkowi stałych wymiarów i marginesu z prawej/dołu -->
                    <Button Classes="campaignCard"
                            Command="{Binding ((vm:MainWindowViewModel)DataContext).OpenCampaignCommand, ElementName=Root, FallbackValue=null}"
                            CommandParameter="{Binding}"
                            Background="#1A1A1A" CornerRadius="8" 
                            Margin="0,0,16,16" Padding="16"
                            Width="320" Height="145"
                            BorderThickness="1">
                        <Button.Styles>
                            <Style Selector="Button.campaignCard"><Setter Property="BorderBrush" Value="#292929" /></Style>
                            <Style Selector="Button.campaignCard:pointerover /template/ ContentPresenter">
                                <Setter Property="Background" Value="#1E1E1E" />
                                <Setter Property="BorderBrush" Value="#444444" />
                            </Style>
                        </Button.Styles>
                        
                        <!-- KROK 3: Nowy, kompaktowy układ wewnątrz kafelka -->
                        <Grid RowDefinitions="Auto, *, Auto">
                            
                            <!-- GÓRNA SEKCJA: Ikona, Nazwa i Kosz -->
                            <Grid Grid.Row="0" ColumnDefinitions="Auto, *, Auto">
                                <!-- Ikona tarczy -->
                                <Border Grid.Column="0" Background="#292929" CornerRadius="6" Padding="10" Margin="0,0,12,0" VerticalAlignment="Top">
                                    <PathIcon Data="{StaticResource IconShield}" Width="20" Height="20" Foreground="#D4A017" />
                                </Border>
                                
                                <!-- Tytuł i system (zabezpieczone przed ucinaniem tekstu) -->
                                <StackPanel Grid.Column="1" VerticalAlignment="Top" Margin="0,2,0,0">
                                    <TextBlock Text="{Binding Name}" FontSize="16" FontWeight="SemiBold" Foreground="#FFFFFF" TextTrimming="CharacterEllipsis"/>
                                    <TextBlock Text="{Binding System}" Foreground="#888888" FontSize="13" Margin="0,2,0,0" TextTrimming="CharacterEllipsis"/>
                                </StackPanel>
                                
                                <!-- Przycisk Usuń (w prawym górnym rogu kafelka) -->
                                <Button Grid.Column="3" Command="{Binding ((vm:MainWindowViewModel)DataContext).DeleteCampaignCommand, ElementName=Root, FallbackValue=null}"
                                        CommandParameter="{Binding}" Background="Transparent" BorderThickness="0" CornerRadius="6" Padding="8" VerticalAlignment="Top">
                                    <Button.Styles><Style Selector="Button:pointerover /template/ ContentPresenter"><Setter Property="Background" Value="#5C1515" /></Style></Button.Styles>
                                    <PathIcon Data="{StaticResource IconTrash}" Width="14" Height="14" Foreground="#FF4D4D" />
                                </Button>
                            </Grid>
                            
                            <!-- DOLNA SEKCJA: Statystyki sesji (oddzielone subtelną linią) -->
                            <StackPanel Grid.Row="2" Spacing="2">
                                <Border BorderThickness="0,1,0,0" BorderBrush="#232323" Margin="0,0,0,8"/>
                                <Grid ColumnDefinitions="*, *">
                                    <TextBlock Grid.Column="0" Text="{Binding LastSession, StringFormat='Ostatnia: {0:dd.MM.yyyy}'}" Foreground="#888888" FontSize="12" VerticalAlignment="Center" />
                                    <TextBlock Grid.Column="1" Text="{Binding SessionsCount, StringFormat='Sesje: {0}'}" Foreground="#A3A3A3" FontSize="12" TextAlignment="Right" VerticalAlignment="Center"/>
                                </Grid>
                            </StackPanel>
                            
                        </Grid>
                    </Button>
                </DataTemplate>
            </ItemsControl.ItemTemplate>
        </ItemsControl>
    </StackPanel>
</UserControl>