<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:DungeonApp.ViewModels.Dashboard"
             x:Class="DungeonApp.Views.Dashboard.CampaignsListView"
             x:DataType="vm:CampaignsListViewModel"
             x:Name="Root">
    <ItemsControl ItemsSource="{Binding Parent.Campaigns}">
        <ItemsControl.ItemsPanel>
            <ItemsPanelTemplate>
                <StackPanel Spacing="15" />
            </ItemsPanelTemplate>
        </ItemsControl.ItemsPanel>
        <ItemsControl.ItemTemplate>
            <DataTemplate>
                <Button Classes="card"
                        Command="{Binding ((vm:CampaignsListViewModel)DataContext).Parent.OpenCampaignCommand, ElementName=Root, FallbackValue=null}"
                        CommandParameter="{Binding}"
                        HorizontalAlignment="Stretch">
                    
                    <Grid ColumnDefinitions="Auto, *, Auto, 140, Auto" Margin="10,5">
                        <Border Grid.Column="0" Width="45" Height="45" CornerRadius="10" Background="{DynamicResource InputBackground}" Margin="0,0,20,0">
                            <PathIcon Data="{StaticResource IconShield}" Width="22" Height="22" Foreground="{DynamicResource AccentGold}" />
                        </Border>
                        
                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                            <TextBlock Text="{Binding Name}" FontSize="20" FontWeight="Bold" Foreground="{DynamicResource TextSecondary}" />
                            <TextBlock Text="{Binding System}" FontSize="15" Foreground="{DynamicResource TextMuted}" />
                        </StackPanel>
                        
                        <StackPanel Grid.Column="2" VerticalAlignment="Center" Margin="0,0,40,0">
                            <TextBlock Text="OSTATNIA SESJA" FontSize="11" FontWeight="Bold" Foreground="{DynamicResource TextMuted}" LetterSpacing="1" />
                            <TextBlock Text="{Binding LastSession, StringFormat='{}{0:dd.MM.yyyy}'}" FontSize="16" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimary}" />
                        </StackPanel>
                        
                        <StackPanel Grid.Column="3" VerticalAlignment="Center">
                            <TextBlock Text="ROZEGRANO" FontSize="11" FontWeight="Bold" Foreground="{DynamicResource TextMuted}" LetterSpacing="1" />
                            <TextBlock Text="{Binding SessionsCount, StringFormat='{}{0} sesji'}" FontSize="16" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimary}" />
                        </StackPanel>
                        
                        <Button Grid.Column="4" Classes="iconDanger"
                                Command="{Binding ((vm:CampaignsListViewModel)DataContext).Parent.DeleteCampaignCommand, ElementName=Root, FallbackValue=null}"
                                CommandParameter="{Binding}" VerticalAlignment="Center">
                            <PathIcon Data="{StaticResource IconTrash}" Width="20" Height="20" />
                        </Button>
                    </Grid>
                </Button>
            </DataTemplate>
        </ItemsControl.ItemTemplate>
    </ItemsControl>
</UserControl>
