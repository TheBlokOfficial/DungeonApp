<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:DungeonApp.ViewModels"
             x:Class="DungeonApp.Views.CreateCampaignView"
             x:DataType="vm:CreateCampaignViewModel"
             Background="#171717"> <!-- Dajemy ciemne tło na cały ekran -->
    
    <UserControl.Styles>
        <Style Selector="TextBox">
            <Setter Property="Background" Value="#1E1E1E"/>
            <Setter Property="Foreground" Value="#E5E5E5"/>
            <Setter Property="BorderBrush" Value="#292929"/>
            <Setter Property="CornerRadius" Value="6"/>
            <Setter Property="Padding" Value="12,10"/>
        </Style>
    </UserControl.Styles>

    <!-- Centrujemy zawartość na środku ekranu -->
    <Grid VerticalAlignment="Center" HorizontalAlignment="Center">
        <Border Background="#1A1A1A" 
                BorderBrush="#292929" 
                BorderThickness="1" 
                CornerRadius="12" 
                Padding="40" 
                Width="500">
            
            <StackPanel Spacing="24">
                <!-- Tytuł Widoku -->
                <TextBlock Text="⚔️ Stwórz Nową Kampanię" FontSize="24" FontWeight="Bold" Foreground="#FFFFFF" HorizontalAlignment="Center"/>

                <!-- Formularz -->
                <StackPanel Spacing="8">
                    <TextBlock Text="Nazwa Kampanii" Foreground="#888888" FontSize="13" FontWeight="Medium"/>
                    <TextBox Text="{Binding Name}" PlaceholderText="np. Klątwa Strahda..."/>
                </StackPanel>

                <StackPanel Spacing="8">
                    <TextBlock Text="System RPG" Foreground="#888888" FontSize="13" FontWeight="Medium"/>
                    <TextBox Text="{Binding System}" PlaceholderText="np. D&amp;D 5e..."/>
                </StackPanel>

                <!-- Przyciski Akcji -->
                <Grid ColumnDefinitions="*, *" Margin="0,10,0,0">
                    <Button Grid.Column="0" Content="Anuluj" 
                            Command="{Binding CancelCommand}"
                            Background="Transparent" BorderBrush="#333333" BorderThickness="1"
                            Foreground="#A3A3A3" Padding="15,12" CornerRadius="6"
                            HorizontalAlignment="Stretch" HorizontalContentAlignment="Center" Margin="0,0,6,0">
                        <Button.Styles>
                            <Style Selector="Button:pointerover /template/ ContentPresenter">
                                <Setter Property="Background" Value="#292929"/>
                                <Setter Property="Foreground" Value="#FFFFFF"/>
                            </Style>
                        </Button.Styles>
                    </Button>

                    <Button Grid.Column="1" Content="Zapisz" 
                            Command="{Binding CreateCommand}"
                            Background="#D4A017" Foreground="#171717" 
                            FontWeight="Bold" Padding="15,12" CornerRadius="6"
                            HorizontalAlignment="Stretch" HorizontalContentAlignment="Center" Margin="6,0,0,0">
                        <Button.Styles>
                            <Style Selector="Button:pointerover /template/ ContentPresenter">
                                <Setter Property="Background" Value="#E5B027"/>
                            </Style>
                        </Button.Styles>
                    </Button>
                </Grid>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>