<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:DungeonApp.ViewModels"
             x:Class="DungeonApp.Views.CampaignDetailView"
             x:DataType="vm:CampaignDetailViewModel"
             x:Name="Root"
             Background="#171717">

    <UserControl.Styles>
        <Style Selector="TextBox">
            <Setter Property="Background" Value="#1E1E1E"/>
            <Setter Property="Foreground" Value="#E5E5E5"/>
            <Setter Property="BorderBrush" Value="#292929"/>
            <Setter Property="CornerRadius" Value="6"/>
            <Setter Property="Padding" Value="12,10"/>
        </Style>
    </UserControl.Styles>

    <Grid RowDefinitions="Auto,*" Margin="30">

        <!-- Górny pasek: powrót + nazwa kampanii -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" Spacing="16" Margin="0,0,0,30">
            <Button Command="{Binding BackCommand}"
                    Background="Transparent" BorderThickness="0" CornerRadius="6" Padding="10,8">
                <Button.Styles>
                    <Style Selector="Button:pointerover /template/ ContentPresenter">
                        <Setter Property="Background" Value="#292929"/>
                    </Style>
                </Button.Styles>
                <TextBlock Text="← Wróć" FontSize="14" Foreground="#A3A3A3"/>
            </Button>

            <StackPanel VerticalAlignment="Center">
                <TextBlock Text="{Binding Campaign.Name}" FontSize="24" FontWeight="Bold" Foreground="#FFFFFF"/>
                <TextBlock Text="{Binding Campaign.System}" FontSize="14" Foreground="#888888"/>
            </StackPanel>
        </StackPanel>

        <!-- Główna zawartość: lista sesji + edytor -->
        <Grid Grid.Row="1" ColumnDefinitions="280,20,*">

            <!-- Lewa kolumna: lista sesji -->
            <Grid Grid.Column="0" RowDefinitions="Auto,*">
                <Button Grid.Row="0" Command="{Binding AddSessionCommand}"
                        Background="#D4A017" Foreground="#171717" FontWeight="Bold"
                        CornerRadius="6" Padding="12,10" HorizontalAlignment="Stretch"
                        HorizontalContentAlignment="Center" Margin="0,0,0,16">
                    <Button.Styles>
                        <Style Selector="Button:pointerover /template/ ContentPresenter">
                            <Setter Property="Background" Value="#E5B027"/>
                        </Style>
                    </Button.Styles>
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <PathIcon Data="{StaticResource IconAdd}" Width="14" Height="14" Foreground="#171717"/>
                        <TextBlock Text="Nowa Sesja" FontSize="14"/>
                    </StackPanel>
                </Button>

                <ScrollViewer Grid.Row="1">
                    <ItemsControl ItemsSource="{Binding Sessions}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Button Classes="sessionCard"
                                        Command="{Binding ((vm:CampaignDetailViewModel)DataContext).SelectSessionCommand, ElementName=Root, FallbackValue=null}"
                                        CommandParameter="{Binding}"
                                        Background="#1A1A1A" CornerRadius="8" Padding="14,12" Margin="0,0,0,8"
                                        BorderThickness="1" HorizontalAlignment="Stretch" HorizontalContentAlignment="Left">
                                    <Button.Styles>
                                        <Style Selector="Button.sessionCard">
                                            <Setter Property="BorderBrush" Value="Transparent"/>
                                        </Style>
                                        <Style Selector="Button.sessionCard:pointerover /template/ ContentPresenter">
                                            <Setter Property="BorderBrush" Value="#333333"/>
                                        </Style>
                                    </Button.Styles>
                                    <StackPanel Spacing="4">
                                        <TextBlock Text="{Binding Title}" FontSize="14" FontWeight="SemiBold" Foreground="#EEEEEE"/>
                                        <TextBlock Text="{Binding Date, StringFormat='{}{0:dd.MM.yyyy}'}" FontSize="12" Foreground="#666666"/>
                                    </StackPanel>
                                </Button>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </Grid>

            <!-- Prawa kolumna: edytor wybranej sesji -->
            <Border Grid.Column="2" Background="#1A1A1A" CornerRadius="12" Padding="30" BorderBrush="#292929" BorderThickness="1">
                <Grid>
                    <!-- Widok gdy nic nie wybrano -->
                    <StackPanel IsVisible="{Binding SelectedSession, Converter={x:Static ObjectConverters.IsNull}}"
                                VerticalAlignment="Center" HorizontalAlignment="Center" Spacing="12">
                        <PathIcon Data="{StaticResource IconShield}" Width="40" Height="40" Foreground="#333333" HorizontalAlignment="Center"/>
                        <TextBlock Text="Wybierz sesję z listy albo stwórz nową." FontSize="14" Foreground="#666666"/>
                    </StackPanel>

                    <!-- Edytor sesji -->
                    <StackPanel IsVisible="{Binding SelectedSession, Converter={x:Static ObjectConverters.IsNotNull}}" Spacing="16">
                        <TextBox Text="{Binding SelectedSession.Title}" FontSize="18" FontWeight="SemiBold" Watermark="Tytuł sesji"/>
                        <TextBox Text="{Binding SelectedSession.Notes}" AcceptsReturn="True" TextWrapping="Wrap"
                                  MinHeight="300" MaxHeight="500" VerticalContentAlignment="Top" Watermark="Notatki z sesji..."/>

                        <Grid ColumnDefinitions="*,Auto">
                            <TextBlock Grid.Column="0" VerticalAlignment="Center" Foreground="#666666" FontSize="13"
                                        Text="{Binding SelectedSession.Date, StringFormat='Data: {0:dd.MM.yyyy}'}"/>

                            <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8">
                                <Button Command="{Binding DeleteSessionCommand}" CommandParameter="{Binding SelectedSession}"
                                        Background="Transparent" BorderThickness="1" BorderBrush="#5C1515"
                                        Foreground="#FF4D4D" CornerRadius="6" Padding="14,10">
                                    <Button.Styles>
                                        <Style Selector="Button:pointerover /template/ ContentPresenter">
                                            <Setter Property="Background" Value="#5C1515"/>
                                        </Style>
                                    </Button.Styles>
                                    <TextBlock Text="Usuń sesję"/>
                                </Button>

                                <Button Command="{Binding SaveCurrentSessionCommand}"
                                        Background="#D4A017" Foreground="#171717" FontWeight="Bold"
                                        CornerRadius="6" Padding="14,10">
                                    <Button.Styles>
                                        <Style Selector="Button:pointerover /template/ ContentPresenter">
                                            <Setter Property="Background" Value="#E5B027"/>
                                        </Style>
                                    </Button.Styles>
                                    <TextBlock Text="Zapisz"/>
                                </Button>
                            </StackPanel>
                        </Grid>
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</UserControl>