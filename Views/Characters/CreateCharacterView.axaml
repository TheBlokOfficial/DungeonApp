<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:DungeonApp.ViewModels"
             x:Class="DungeonApp.Views.CreateCharacterView"
             x:DataType="vm:CreateCharacterViewModel"
             Background="#171717"> 
    
    <UserControl.Styles>
        <Style Selector="TextBox">
            <Setter Property="Background" Value="#1E1E1E"/>
            <Setter Property="Foreground" Value="#E5E5E5"/>
            <Setter Property="BorderBrush" Value="#292929"/>
            <Setter Property="CornerRadius" Value="6"/>
            <Setter Property="Padding" Value="12,10"/>
        </Style>
    </UserControl.Styles>

    <Grid VerticalAlignment="Center" HorizontalAlignment="Center">
        <!-- Dodano sztywne Height="520" oraz ClipToBounds="True" -->
        <Border Background="#1A1A1A" BorderBrush="#292929" BorderThickness="1" CornerRadius="12" Padding="40" Width="500" Height="520" ClipToBounds="True">
            
            <!-- Główny układ dzielący okno na 3 części: Nagłówek (Auto), Środek (*), Przyciski (Auto) -->
            <Grid RowDefinitions="Auto, *, Auto">
                
                <!-- NAGŁÓWEK -->
                <StackPanel Grid.Row="0" Orientation="Horizontal" Spacing="10" HorizontalAlignment="Center" Margin="0,0,0,24">
                    <PathIcon Data="{StaticResource IconSwords}" Width="24" Height="24" Foreground="#D4A017"/>
                    <TextBlock Text="Zarejestruj Nową Postać" FontSize="24" FontWeight="Bold" Foreground="#FFFFFF" VerticalAlignment="Center"/>
                </StackPanel>

                <!-- FORMULARZ -->
                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                    <StackPanel Spacing="24" VerticalAlignment="Top">
                        
                        <StackPanel Spacing="8">
                            <TextBlock Text="Imię Postaci *" Foreground="#888888" FontSize="13" FontWeight="Medium"/>
                            <TextBox Text="{Binding CharacterName}" PlaceholderText="np. Geralt z Rivii..."/>
                        </StackPanel>

                        <StackPanel Spacing="8">
                            <TextBlock Text="Imię Gracza" Foreground="#888888" FontSize="13" FontWeight="Medium"/>
                            <TextBox Text="{Binding PlayerName}" PlaceholderText="np. Tomek..."/>
                        </StackPanel>

                        <Grid ColumnDefinitions="*,16,*">
                            <StackPanel Grid.Column="0" Spacing="8">
                                <TextBlock Text="Rasa" Foreground="#888888" FontSize="13" FontWeight="Medium"/>
                                <TextBox Text="{Binding Race}" PlaceholderText="np. Człowiek..."/>
                            </StackPanel>
                            <StackPanel Grid.Column="2" Spacing="8">
                                <TextBlock Text="Klasa i Poziom" Foreground="#888888" FontSize="13" FontWeight="Medium"/>
                                <TextBox Text="{Binding ClassAndLevel}" PlaceholderText="np. Wojownik 5..."/>
                            </StackPanel>
                        </Grid>
                        
                    </StackPanel>
                </ScrollViewer>

                <!-- PRZYCISKI -->
                <Grid Grid.Row="2" ColumnDefinitions="*, *" Margin="0,20,0,0">
                    <Button Grid.Column="0" Content="Anuluj" Command="{Binding CancelCommand}"
                            Background="Transparent" BorderBrush="#333333" BorderThickness="1" Foreground="#A3A3A3" Padding="15,12" CornerRadius="6" HorizontalAlignment="Stretch" HorizontalContentAlignment="Center" Margin="0,0,6,0">
                        <Button.Styles><Style Selector="Button:pointerover /template/ ContentPresenter"><Setter Property="Background" Value="#292929"/><Setter Property="Foreground" Value="#FFFFFF"/></Style></Button.Styles>
                    </Button>
                    <Button Grid.Column="1" Content="Zapisz" Command="{Binding CreateCommand}"
                            Background="#D4A017" Foreground="#171717" FontWeight="Bold" Padding="15,12" CornerRadius="6" HorizontalAlignment="Stretch" HorizontalContentAlignment="Center" Margin="6,0,0,0">
                        <Button.Styles><Style Selector="Button:pointerover /template/ ContentPresenter"><Setter Property="Background" Value="#E5B027"/></Style></Button.Styles>
                    </Button>
                </Grid>
                
            </Grid>
        </Border>
    </Grid>
</UserControl>