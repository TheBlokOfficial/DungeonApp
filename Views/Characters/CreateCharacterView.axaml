<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:DungeonApp.ViewModels"
             xmlns:i18n="using:DungeonApp.Markup"
             x:Class="DungeonApp.Views.CreateCharacterView"
             x:DataType="vm:CreateCharacterViewModel">
    
    <UserControl.Styles>
        <Style Selector="TextBox">
            <Setter Property="Background" Value="{DynamicResource InputBackground}"/>
            <Setter Property="Foreground" Value="{DynamicResource TextPrimary}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BorderSecondary}"/>
            <Setter Property="CornerRadius" Value="{DynamicResource InputBorderRadius}"/>
            <Setter Property="Padding" Value="12,10"/>
        </Style>
    </UserControl.Styles>

    <Grid VerticalAlignment="Center" HorizontalAlignment="Center">
        <!-- Dodano sztywne Height="650" oraz ClipToBounds="True" -->
        <Border Classes="popModal" Background="{DynamicResource CardBackground}"  BorderThickness="0" CornerRadius="{DynamicResource CardCornerRadius}" Padding="{DynamicResource CardPadding}" Width="625" Height="650" ClipToBounds="True">
            
            <!-- Główny układ dzielący okno na 3 części: Nagłówek (Auto), Środek (*), Przyciski (Auto) -->
            <Grid RowDefinitions="Auto, *, Auto">
                
                <!-- NAGŁÓWEK -->
                <StackPanel Grid.Row="0" Orientation="Horizontal" Spacing="12" HorizontalAlignment="Center" Margin="0,0,0,30">
                    <PathIcon Data="{StaticResource IconSwords}" Width="30" Height="30" Foreground="{DynamicResource AccentGold}"/>
                    <TextBlock Classes="dynamic" Text="{i18n:Translate ui_register_character}" FontSize="30" FontWeight="Bold" Foreground="{DynamicResource TextPrimary}" VerticalAlignment="Center"/>
                </StackPanel>

                <!-- FORMULARZ -->
                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                    <StackPanel Spacing="30" VerticalAlignment="Top">
                        
                        <StackPanel Spacing="10">
                            <TextBlock Classes="dynamic" Text="{i18n:Translate ui_character_name}" Foreground="{DynamicResource TextMuted}" FontSize="16" FontWeight="Medium"/>
                            <TextBox Text="{Binding CharacterName}" PlaceholderText="{i18n:Translate ui_character_name_placeholder}"/>
                        </StackPanel>

                        <StackPanel Spacing="10">
                            <TextBlock Classes="dynamic" Text="{i18n:Translate ui_player_name}" Foreground="{DynamicResource TextMuted}" FontSize="16" FontWeight="Medium"/>
                            <TextBox Text="{Binding PlayerName}" PlaceholderText="{i18n:Translate ui_player_name_placeholder}"/>
                        </StackPanel>

                        <Grid ColumnDefinitions="*,16,*">
                            <StackPanel Grid.Column="0" Spacing="10">
                                <TextBlock Classes="dynamic" Text="{i18n:Translate ui_race}" Foreground="{DynamicResource TextMuted}" FontSize="16" FontWeight="Medium"/>
                                <TextBox Text="{Binding Race}" PlaceholderText="{i18n:Translate ui_race_placeholder}"/>
                            </StackPanel>
                            <StackPanel Grid.Column="2" Spacing="10">
                                <TextBlock Classes="dynamic" Text="{i18n:Translate ui_class_level}" Foreground="{DynamicResource TextMuted}" FontSize="16" FontWeight="Medium"/>
                                <TextBox Text="{Binding ClassAndLevel}" PlaceholderText="{i18n:Translate ui_class_level_placeholder}"/>
                            </StackPanel>
                        </Grid>
                        
                    </StackPanel>
                </ScrollViewer>

                <!-- PRZYCISKI -->
                <Grid Grid.Row="2" ColumnDefinitions="*, *" Margin="0,25,0,0">
                    <Button Grid.Column="0" Command="{Binding CancelCommand}" Classes="ghost"
                            BorderThickness="0"  HorizontalAlignment="Stretch" Margin="0,0,8,0" >
                        <TextBlock Classes="dynamic" Text="{i18n:Translate ui_cancel}" HorizontalAlignment="Center"/>
                    </Button>
                    <Button Grid.Column="1" Command="{Binding CreateCommand}" Classes="primary"
                            HorizontalAlignment="Stretch" Margin="8,0,0,0" >
                        <TextBlock Classes="dynamic" Text="{i18n:Translate ui_save}" HorizontalAlignment="Center"/>
                    </Button>
                </Grid>
                
            </Grid>
        </Border>
    </Grid>
</UserControl>
