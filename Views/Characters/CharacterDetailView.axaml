<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:DungeonApp.ViewModels"
             x:Class="DungeonApp.Views.CharacterDetailView"
             x:DataType="vm:CharacterDetailViewModel"
             Background="{DynamicResource AppBackground}">
    
    <UserControl.Styles>
        <Style Selector="TextBox">
            <Setter Property="Background" Value="{DynamicResource InputBackground}"/>
            <Setter Property="Foreground" Value="{DynamicResource TextPrimary}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BorderSecondary}"/>
            <Setter Property="CornerRadius" Value="{DynamicResource InputBorderRadius}"/>
            <Setter Property="Padding" Value="10,8"/>
        </Style>
        <Style Selector="TextBlock.label">
            <Setter Property="Foreground" Value="{DynamicResource TextMuted}"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Margin" Value="0,0,0,4"/>
        </Style>
        <Style Selector="Border.statBox">
            <Setter Property="Background" Value="{DynamicResource CardBackground}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BorderSecondary}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="{DynamicResource CardCornerRadius}"/>
            <Setter Property="Padding" Value="12"/>
        </Style>
    </UserControl.Styles>

    <Grid RowDefinitions="Auto, *" Margin="30">
        
        <!-- GÓRNY PASEK: PRZYCISKI -->
        <Grid Grid.Row="0" ColumnDefinitions="Auto, *, Auto" Margin="0,0,0,24">
            <Button Grid.Column="0" Classes="ghost" Command="{Binding CancelCommand}">
                <TextBlock Text="← Wróć (Anuluj)" FontSize="14" Foreground="{DynamicResource TextMuted}"/>
            </Button>
            
            <TextBlock Grid.Column="1" Text="Karta Postaci" FontSize="20" FontWeight="Bold" Foreground="{DynamicResource TextPrimary}" HorizontalAlignment="Center" VerticalAlignment="Center"/>
            
            <Button Grid.Column="2" Classes="accent" Command="{Binding SaveCommand}">
                <TextBlock Text="Zapisz" />
            </Button>
        </Grid>

        <ScrollViewer Grid.Row="1">
            <Grid ColumnDefinitions="*, 400" Margin="0,0,0,20">
                
                <!-- LEWA KOLUMNA: PODSTAWY, WALKA, ATRYBUTY -->
                <StackPanel Grid.Column="0" Spacing="24" Margin="0,0,24,0">
                    
                    <!-- DANE BOHATERA -->
                    <Border Classes="statBox" BorderBrush="{DynamicResource AccentGold}">
                        <Grid ColumnDefinitions="*, *, *">
                            <StackPanel Grid.Column="0" Margin="0,0,16,0">
                                <TextBlock Classes="label" Text="Imię Postaci"/>
                                <TextBox Text="{Binding Character.CharacterName}" FontSize="18" FontWeight="Bold" Foreground="{DynamicResource AccentGold}"/>
                            </StackPanel>
                            <StackPanel Grid.Column="1" Margin="0,0,16,0">
                                <TextBlock Classes="label" Text="Rasa"/>
                                <TextBox Text="{Binding Character.Race}"/>
                            </StackPanel>
                            <StackPanel Grid.Column="2">
                                <TextBlock Classes="label" Text="Klasa i Poziom"/>
                                <TextBox Text="{Binding Character.ClassAndLevel}"/>
                            </StackPanel>
                        </Grid>
                    </Border>
                    
                    <!-- STATYSTYKI BOJOWE -->
                    <Border Classes="statBox">
                        <Grid ColumnDefinitions="*, *, *, *">
                            <StackPanel Grid.Column="0" Margin="0,0,16,0">
                                <TextBlock Classes="label" Text="Aktualne HP"/>
                                <TextBox Text="{Binding Character.CurrentHp}" FontSize="24" FontWeight="Bold" Foreground="{DynamicResource AccentDanger}" TextAlignment="Center"/>
                            </StackPanel>
                            <StackPanel Grid.Column="1" Margin="0,0,16,0">
                                <TextBlock Classes="label" Text="Max HP"/>
                                <TextBox Text="{Binding Character.MaxHp}" FontSize="24" FontWeight="Bold" TextAlignment="Center"/>
                            </StackPanel>
                            <StackPanel Grid.Column="2" Margin="0,0,16,0">
                                <TextBlock Classes="label" Text="Klasa Pancerza (AC)"/>
                                <TextBox Text="{Binding Character.ArmorClass}" FontSize="24" FontWeight="Bold" Foreground="{DynamicResource AccentPrimary}" TextAlignment="Center"/>
                            </StackPanel>
                            <StackPanel Grid.Column="3">
                                <TextBlock Classes="label" Text="Szybkość"/>
                                <TextBox Text="{Binding Character.Speed}" FontSize="24" FontWeight="Bold" TextAlignment="Center"/>
                            </StackPanel>
                        </Grid>
                    </Border>
                    
                    <!-- ATRYBUTY -->
                    <Border Classes="statBox">
                        <StackPanel>
                            <TextBlock Text="ATRYBUTY" Classes="label" Margin="0,0,0,12"/>
                            <Grid ColumnDefinitions="*, *, *, *, *, *">
                                <!-- SIŁA -->
                                <StackPanel Grid.Column="0" HorizontalAlignment="Center">
                                    <TextBlock Text="SIŁ" Classes="label" HorizontalAlignment="Center"/>
                                    <TextBox Text="{Binding Character.Strength}" Width="50" TextAlignment="Center" FontWeight="Bold" Margin="0,0,0,4"/>
                                    <TextBlock Text="{Binding StrMod}" Foreground="#A3A3A3" FontWeight="SemiBold" HorizontalAlignment="Center"/>
                                </StackPanel>
                                <!-- ZRĘCZNOŚĆ -->
                                <StackPanel Grid.Column="1" HorizontalAlignment="Center">
                                    <TextBlock Text="ZRĘ" Classes="label" HorizontalAlignment="Center"/>
                                    <TextBox Text="{Binding Character.Dexterity}" Width="50" TextAlignment="Center" FontWeight="Bold" Margin="0,0,0,4"/>
                                    <TextBlock Text="{Binding DexMod}" Foreground="#A3A3A3" FontWeight="SemiBold" HorizontalAlignment="Center"/>
                                </StackPanel>
                                <!-- KONDYCJA -->
                                <StackPanel Grid.Column="2" HorizontalAlignment="Center">
                                    <TextBlock Text="KON" Classes="label" HorizontalAlignment="Center"/>
                                    <TextBox Text="{Binding Character.Constitution}" Width="50" TextAlignment="Center" FontWeight="Bold" Margin="0,0,0,4"/>
                                    <TextBlock Text="{Binding ConMod}" Foreground="#A3A3A3" FontWeight="SemiBold" HorizontalAlignment="Center"/>
                                </StackPanel>
                                <!-- INTELIGENCJA -->
                                <StackPanel Grid.Column="3" HorizontalAlignment="Center">
                                    <TextBlock Text="INT" Classes="label" HorizontalAlignment="Center"/>
                                    <TextBox Text="{Binding Character.Intelligence}" Width="50" TextAlignment="Center" FontWeight="Bold" Margin="0,0,0,4"/>
                                    <TextBlock Text="{Binding IntMod}" Foreground="#A3A3A3" FontWeight="SemiBold" HorizontalAlignment="Center"/>
                                </StackPanel>
                                <!-- MĄDROŚĆ -->
                                <StackPanel Grid.Column="4" HorizontalAlignment="Center">
                                    <TextBlock Text="MĄD" Classes="label" HorizontalAlignment="Center"/>
                                    <TextBox Text="{Binding Character.Wisdom}" Width="50" TextAlignment="Center" FontWeight="Bold" Margin="0,0,0,4"/>
                                    <TextBlock Text="{Binding WisMod}" Foreground="#A3A3A3" FontWeight="SemiBold" HorizontalAlignment="Center"/>
                                </StackPanel>
                                <!-- CHARYZMA -->
                                <StackPanel Grid.Column="5" HorizontalAlignment="Center">
                                    <TextBlock Text="CHA" Classes="label" HorizontalAlignment="Center"/>
                                    <TextBox Text="{Binding Character.Charisma}" Width="50" TextAlignment="Center" FontWeight="Bold" Margin="0,0,0,4"/>
                                    <TextBlock Text="{Binding ChaMod}" Foreground="#A3A3A3" FontWeight="SemiBold" HorizontalAlignment="Center"/>
                                </StackPanel>
                            </Grid>
                        </StackPanel>
                    </Border>
                    
                </StackPanel>
                
                <!-- PRAWA KOLUMNA: EKWIPUNEK I NOTATKI -->
                <StackPanel Grid.Column="1" Spacing="24">
                    <Border Classes="statBox" Height="250">
                        <StackPanel Height="230">
                            <TextBlock Classes="label" Text="EKWIPUNEK"/>
                            <TextBox Text="{Binding Character.Equipment}" AcceptsReturn="True" TextWrapping="Wrap" Height="190" VerticalContentAlignment="Top"/>
                        </StackPanel>
                    </Border>
                    
                    <Border Classes="statBox" Height="300">
                        <StackPanel Height="280">
                            <TextBlock Classes="label" Text="NOTATKI / HISTORIA"/>
                            <TextBox Text="{Binding Character.Notes}" AcceptsReturn="True" TextWrapping="Wrap" Height="240" VerticalContentAlignment="Top"/>
                        </StackPanel>
                    </Border>
                </StackPanel>
                
            </Grid>
        </ScrollViewer>
    </Grid>
</UserControl>
