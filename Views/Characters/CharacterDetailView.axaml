<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:DungeonApp.ViewModels"
             xmlns:i18n="using:DungeonApp.Markup"
             x:Class="DungeonApp.Views.CharacterDetailView"
             x:DataType="vm:CharacterDetailViewModel"
             Background="Transparent">
    
    <UserControl.Styles>
        <Style Selector="TextBox">
            <Setter Property="Background" Value="{DynamicResource InputBackground}"/>
            <Setter Property="Foreground" Value="{DynamicResource TextPrimary}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="CornerRadius" Value="{DynamicResource InputBorderRadius}"/>
            <Setter Property="Padding" Value="10,8"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>
        <Style Selector="TextBlock.label">
            <Setter Property="Foreground" Value="{DynamicResource TextMuted}"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Margin" Value="0,0,0,4"/>
            <Setter Property="HorizontalAlignment" Value="Center"/>
        </Style>
        <Style Selector="Border.statBox">
            <Setter Property="Background" Value="{DynamicResource CardBackground}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="CornerRadius" Value="{DynamicResource CardCornerRadius}"/>
            <Setter Property="Padding" Value="24"/>
        </Style>
        
        <Style Selector="FlyoutPresenter">
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BorderSecondary}"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="CornerRadius" Value="{DynamicResource CardCornerRadius}"/>
            <Setter Property="Background" Value="{DynamicResource InputBackground}"/>
        </Style>
        
        <Style Selector="TextBox.ghostInput">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Foreground" Value="{DynamicResource TextPrimary}"/>
            <Setter Property="Padding" Value="15,0"/>
            <Setter Property="MinHeight" Value="0"/>
            <Setter Property="MinWidth" Value="60"/>
            <Setter Property="HorizontalAlignment" Value="Center"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Cursor" Value="IBeam"/>
        </Style>
        <Style Selector="TextBox.ghostInput:pointerover /template/ Border#PART_BorderElement">
            <Setter Property="Background" Value="{DynamicResource InputBackground}"/>
            <Setter Property="CornerRadius" Value="{DynamicResource InputBorderRadius}"/>
        </Style>
        <Style Selector="TextBox.ghostInput:focus /template/ Border#PART_BorderElement">
            <Setter Property="Background" Value="{DynamicResource InputBackground}"/>
            <Setter Property="CornerRadius" Value="{DynamicResource InputBorderRadius}"/>
        </Style>
    </UserControl.Styles>

    <Grid RowDefinitions="Auto, Auto, *" Margin="30,30,0,30">
        
        <!-- GÓRNY PASEK: PRZYCISKI -->
        <DockPanel Grid.Row="0" Margin="0,0,0,20">
            <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" Spacing="15" HorizontalAlignment="Right">
                <Button Classes="danger" Command="{Binding DeleteCommand}">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <PathIcon Data="{StaticResource IconTrash}" Width="14" Height="14"/>
                        <TextBlock Classes="dynamic" Text="{i18n:Translate ui_delete_character}"/>
                    </StackPanel>
                </Button>
                <Button Classes="primary" Command="{Binding SaveCommand}">
                    <TextBlock Classes="dynamic" Text="{i18n:Translate ui_save_changes}" FontWeight="Bold"/>
                </Button>
            </StackPanel>
            <TextBlock Text=" " HorizontalAlignment="Center" VerticalAlignment="Center" IsVisible="False"/>
        </DockPanel>

        <!-- KAFELEK 1: NAGŁÓWEK TOŻSAMOŚCI (Wiersz 1) -->
        <!-- Szerokość zablokowana na 855px (420+420+15), by idealnie pasowało do siatki Bento Box pod spodem -->
        <Border Grid.Row="1" Classes="statBox" Margin="0,0,0,15" MinHeight="110" VerticalAlignment="Top" HorizontalAlignment="Left" Width="855">
            <StackPanel Spacing="5" VerticalAlignment="Center">
                
                <StackPanel Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">
                    <TextBox Classes="ghostInput" Text="{Binding Character.CharacterName}" 
                             FontSize="36" FontWeight="Bold" Foreground="{DynamicResource TextPrimary}" 
                             Height="45" Padding="0" MinWidth="10" HorizontalAlignment="Left" HorizontalContentAlignment="Left"
                             IsHitTestVisible="{Binding IsEditingIdentity}" Focusable="{Binding IsEditingIdentity}"/>
                    
                    <Panel VerticalAlignment="Center">
                        <Button Classes="icon" Command="{Binding ToggleEditIdentityCommand}" ToolTip.Tip="{i18n:Translate ui_edit_identity}" 
                                Opacity="{Binding !IsEditingIdentity}" IsHitTestVisible="{Binding !IsEditingIdentity}">
                            <PathIcon Data="{StaticResource IconEdit}" Width="16" Height="16"/>
                        </Button>
                        <Button Classes="primary" Command="{Binding ToggleEditIdentityCommand}" Padding="15,8"
                                Opacity="{Binding IsEditingIdentity}" IsHitTestVisible="{Binding IsEditingIdentity}">
                            <TextBlock Classes="dynamic" Text="{i18n:Translate ui_confirm}" FontWeight="Bold"/>
                        </Button>
                    </Panel>
                </StackPanel>
                
                <Grid ColumnDefinitions="*, *" Height="30">
                    <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="5" Margin="0,0,10,0">
                        <TextBlock Classes="dynamic" Text="{i18n:Translate ui_race}" FontSize="18" Foreground="{DynamicResource TextMuted}" VerticalAlignment="Center"/>
                        <TextBlock Text=":" FontSize="18" Foreground="{DynamicResource TextMuted}" VerticalAlignment="Center"/>
                        <TextBox Classes="ghostInput" Text="{Binding Character.Race}" FontSize="18" Foreground="{DynamicResource TextMuted}" Padding="0" MinWidth="10"
                                 IsHitTestVisible="{Binding IsEditingIdentity}" Focusable="{Binding IsEditingIdentity}"/>
                    </StackPanel>
                    <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="5">
                        <TextBlock Classes="dynamic" Text="{i18n:Translate ui_class}" FontSize="18" Foreground="{DynamicResource TextMuted}" VerticalAlignment="Center"/>
                        <TextBlock Text=":" FontSize="18" Foreground="{DynamicResource TextMuted}" VerticalAlignment="Center"/>
                        <TextBox Classes="ghostInput" Text="{Binding Character.ClassAndLevel}" FontSize="18" Foreground="{DynamicResource TextMuted}" Padding="0" MinWidth="10"
                                 IsHitTestVisible="{Binding IsEditingIdentity}" Focusable="{Binding IsEditingIdentity}"/>
                    </StackPanel>
                </Grid>
            </StackPanel>
        </Border>

        <!-- BENTO BOX GRID: Ekwipunek, Statystyki, Notatki (Wiersz 2) -->
        <Grid Grid.Row="2" ColumnDefinitions="420, 420" RowDefinitions="Auto, *">
            
            <!-- KAFELEK 2: EKWIPUNEK (Lewa Kolumna, Wiersz 0 + 1) -->
            <!-- Wysokość 530px by pomieścić aż 8 elementów! -->
            <Border Grid.Row="0" Grid.RowSpan="2" Grid.Column="0" Classes="statBox" Margin="0,0,15,0" Height="530" VerticalAlignment="Top">
                <Grid RowDefinitions="Auto, *, Auto">
                    <Grid Grid.Row="0" ColumnDefinitions="*, Auto" Margin="0,0,0,20">
                        <TextBlock Grid.Column="0" Classes="label dynamic" Text="{i18n:Translate ui_equipment}" VerticalAlignment="Center" HorizontalAlignment="Left" FontSize="14"/>
                        <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8">
                            <!-- Przycisk z Flyoutem do Rejestru -->
                            <Button Classes="icon" ToolTip.Tip="{i18n:Translate ui_add_from_registry}">
                                <PathIcon Data="{StaticResource IconShield}" Width="15" Height="15"/>
                                <Button.Flyout>
                                    <Flyout Placement="BottomEdgeAlignedRight" IsOpen="{Binding IsRegistryFlyoutOpen, Mode=TwoWay}">
                                        <Grid RowDefinitions="Auto, Auto, *" Width="350" Height="400" Margin="5">
                                            <TextBlock Grid.Row="0" Classes="dynamic" Text="{i18n:Translate ui_add_from_registry}" FontSize="16" FontWeight="Bold" Margin="0,0,0,10" Foreground="{DynamicResource TextPrimary}"/>
                                            <TextBox Grid.Row="1" Text="{Binding RegistrySearchQuery}" PlaceholderText="{i18n:Translate ui_registry_search_placeholder}" Margin="0,0,0,15" CornerRadius="8"/>
                                            <ScrollViewer Grid.Row="2" HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Auto">
                                                <ItemsControl ItemsSource="{Binding FilteredRegistryItems}">
                                                    <ItemsControl.ItemTemplate>
                                                        <DataTemplate>
                                                            <Button Command="{ReflectionBinding $parent[ItemsControl].DataContext.AddRegistryItemCommand}" CommandParameter="{Binding FullId}" Background="Transparent" BorderThickness="0" HorizontalAlignment="Stretch" HorizontalContentAlignment="Left" Padding="10" Margin="0,0,0,5" CornerRadius="8">
                                                                <StackPanel>
                                                                    <TextBlock Classes="dynamic" Text="{Binding Name}" FontWeight="Bold" FontSize="14" Foreground="{DynamicResource TextPrimary}"/>
                                                                    <TextBlock Classes="dynamic" Text="{Binding DisplayPath}" FontSize="11" Foreground="{DynamicResource TextMuted}"/>
                                                                </StackPanel>
                                                            </Button>
                                                        </DataTemplate>
                                                    </ItemsControl.ItemTemplate>
                                                </ItemsControl>
                                            </ScrollViewer>
                                        </Grid>
                                    </Flyout>
                                </Button.Flyout>
                            </Button>
                            
                            <!-- Przycisk dodania Customowego Przedmiotu -->
                            <Button Classes="icon" Command="{Binding AddEquipmentItemCommand}" ToolTip.Tip="Dodaj własny (customowy)">
                                <PathIcon Data="{StaticResource IconAdd}" Width="15" Height="15"/>
                            </Button>
                        </StackPanel>
                    </Grid>
                    
                    <ItemsControl Grid.Row="1" ItemsSource="{Binding PaginatedEquipment}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <StackPanel Spacing="10" />
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Grid ColumnDefinitions="*, 80, Auto">
                                    <!-- Nazwa przedmiotu: dla referencyjnych (z paczki) wyświetla DisplayName w trybie tylko-do-odczytu.
                                         Dla customowych (bez TemplateId) pozwala na edycję CustomName. -->
                                    <Panel Grid.Column="0" Margin="0,0,10,0">
                                        <TextBox Text="{Binding CustomName}" FontSize="12" Padding="10,6" IsVisible="{Binding !IsFromPack}"/>
                                        <Border Background="{DynamicResource BorderSecondary}" CornerRadius="6" IsVisible="{Binding IsFromPack}">
                                            <StackPanel Orientation="Horizontal" Spacing="4" VerticalAlignment="Center" Margin="10,6">
                                                <TextBlock Classes="dynamic" Text="{Binding PackNameDisplay, Mode=OneWay}" FontSize="10" Foreground="{DynamicResource TextMuted}" VerticalAlignment="Center" Opacity="0.7"/>
                                                <TextBlock Classes="dynamic" Text="{Binding DisplayName, Mode=OneWay}" FontSize="12" FontWeight="SemiBold" VerticalAlignment="Center"/>
                                            </StackPanel>
                                        </Border>
                                    </Panel>
                                    <TextBox Grid.Column="1" Text="{Binding Quantity}" TextAlignment="Center" Margin="0,0,10,0" FontSize="12" Padding="10,6"/>
                                    <Button Grid.Column="2" Classes="iconDanger" Command="{Binding ((vm:CharacterDetailViewModel)DataContext).RemoveEquipmentItemCommand, RelativeSource={RelativeSource AncestorType=UserControl}}" CommandParameter="{Binding}">
                                        <PathIcon Data="{StaticResource IconTrash}" Width="14" Height="14"/>
                                    </Button>
                                </Grid>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                    
                    <!-- Paginacja -->
                    <Grid Grid.Row="2" ColumnDefinitions="Auto, *, Auto" Margin="0,15,0,0">
                        <Button Grid.Column="0" Classes="ghost" Command="{Binding PreviousPageCommand}" Padding="8">
                            <TextBlock Text="&lt;" FontWeight="Bold" FontSize="16"/>
                        </Button>
                        <TextBlock Grid.Column="1" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="{DynamicResource TextMuted}" FontSize="14">
                            <TextBlock.Text>
                                <MultiBinding StringFormat="{}{0} / {1}">
                                    <Binding Path="CurrentEquipmentPage"/>
                                    <Binding Path="TotalEquipmentPages"/>
                                </MultiBinding>
                            </TextBlock.Text>
                        </TextBlock>
                        <Button Grid.Column="2" Classes="ghost" Command="{Binding NextPageCommand}" Padding="8">
                            <TextBlock Text="&gt;" FontWeight="Bold" FontSize="16"/>
                        </Button>
                    </Grid>
                </Grid>
            </Border>

            <!-- KAFELEK 3: STATYSTYKI BOJOWE (Prawa Kolumna, Góra) -->
            <Border Grid.Row="0" Grid.Column="1" Classes="statBox" Margin="0,0,0,15" Height="160" VerticalAlignment="Top">
                <Grid ColumnDefinitions="*, 60" HorizontalAlignment="Stretch">
                    
                    <Grid Grid.Column="0" ColumnDefinitions="*, *" RowDefinitions="Auto, Auto" VerticalAlignment="Center" HorizontalAlignment="Stretch">
                        
                        <!-- Wiersz 0: HP -->
                        <!-- Ustawiamy sztywne Height=45 dla komórek by zapobiec skakaniu w pionie -->
                        <StackPanel Grid.Row="0" Grid.Column="0" Margin="0,0,10,15" Height="45">
                            <TextBlock Classes="label dynamic" Text="{i18n:Translate ui_current_hp}"/>
                            <Grid Height="35">
                                <TextBox Text="{Binding Character.CurrentHp}" FontSize="28" FontWeight="Bold" Foreground="{DynamicResource AccentDanger}" Classes="ghostInput" IsHitTestVisible="{Binding IsEditingCombat}" Focusable="{Binding IsEditingCombat}"/>
                            </Grid>
                        </StackPanel>
                        <StackPanel Grid.Row="0" Grid.Column="1" Margin="0,0,0,15" Height="45">
                            <TextBlock Classes="label dynamic" Text="{i18n:Translate ui_max_hp}"/>
                            <Grid Height="35">
                                <TextBox Text="{Binding Character.MaxHp}" FontSize="28" FontWeight="Bold" Foreground="{DynamicResource TextMuted}" Classes="ghostInput" IsHitTestVisible="{Binding IsEditingCombat}" Focusable="{Binding IsEditingCombat}"/>
                            </Grid>
                        </StackPanel>
                        
                        <!-- Wiersz 1: AC i Szybkość -->
                        <StackPanel Grid.Row="1" Grid.Column="0" Margin="0,0,10,0" Height="45">
                            <TextBlock Classes="label dynamic" Text="{i18n:Translate ui_armor_class}"/>
                            <Grid Height="35">
                                <TextBox Text="{Binding Character.ArmorClass}" FontSize="24" FontWeight="Bold" Foreground="{DynamicResource AccentPrimary}" Classes="ghostInput" IsHitTestVisible="{Binding IsEditingCombat}" Focusable="{Binding IsEditingCombat}"/>
                            </Grid>
                        </StackPanel>
                        <StackPanel Grid.Row="1" Grid.Column="1" Margin="0,0,0,0" Height="45">
                            <TextBlock Classes="label dynamic" Text="{i18n:Translate ui_speed}"/>
                            <Grid Height="35">
                                <TextBox Text="{Binding Character.Speed}" FontSize="24" FontWeight="Bold" Classes="ghostInput" IsHitTestVisible="{Binding IsEditingCombat}" Focusable="{Binding IsEditingCombat}"/>
                            </Grid>
                        </StackPanel>

                    </Grid>

                    <!-- Kłódka -->
                    <Grid Grid.Column="1" VerticalAlignment="Center" HorizontalAlignment="Right">
                        <Button Classes="icon" Command="{Binding ToggleEditCombatCommand}" ToolTip.Tip="{i18n:Translate ui_unlock_edit}" 
                                Opacity="{Binding !IsEditingCombat}" IsHitTestVisible="{Binding !IsEditingCombat}">
                            <PathIcon Data="{StaticResource IconEdit}" Width="20" Height="20"/>
                        </Button>
                        <Button Classes="icon" Command="{Binding ToggleEditCombatCommand}" ToolTip.Tip="{i18n:Translate ui_lock_edit}" 
                                Opacity="{Binding IsEditingCombat}" IsHitTestVisible="{Binding IsEditingCombat}">
                            <PathIcon Data="{StaticResource IconLock}" Width="20" Height="20"/>
                        </Button>
                    </Grid>

                </Grid>
            </Border>

            <!-- KAFELEK 4: NOTATKI (Prawa Kolumna, Dół) -->
            <!-- 530 (Eq) - 160 (Staty) - 15 (Margin) = 355 px wysokości, gwarantuje absolutne zrównanie dołów kafelków! -->
            <Border Grid.Row="1" Grid.Column="1" Classes="statBox" VerticalAlignment="Top" Height="355" Margin="0,0,0,0">
                <Grid RowDefinitions="Auto, *">
                    <TextBlock Grid.Row="0" Classes="label dynamic" Text="{i18n:Translate ui_notes}" Margin="0,0,0,20" HorizontalAlignment="Left" FontSize="14"/>
                    <TextBox Grid.Row="1" Text="{Binding Character.Notes}" AcceptsReturn="True" TextWrapping="Wrap" VerticalContentAlignment="Top" VerticalAlignment="Stretch" Padding="15"/>
                </Grid>
            </Border>
            
        </Grid>
    </Grid>
</UserControl>
