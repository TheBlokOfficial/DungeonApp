<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:DungeonApp.ViewModels"
             x:Class="DungeonApp.Views.Sessions.SessionCombatView"
             x:DataType="vm:SessionDetailViewModel"
             x:Name="Root">

    <Grid RowDefinitions="Auto, Auto, *" Margin="0,8,0,0">

        <!-- ===== SEKCJA 1: SZYBKIE DODAWANIE DRUŻYNY ===== -->
        <Border Grid.Row="0" IsVisible="{Binding IsEditable}" Background="{DynamicResource CardBackground}" CornerRadius="{StaticResource CardCornerRadius}" Padding="{StaticResource CardPadding}" Margin="0,0,0,16" BorderBrush="{DynamicResource BorderSecondary}" BorderThickness="1">
            <StackPanel Spacing="16">
                <!-- Nagłówek sekcji drużyny -->
                <Grid ColumnDefinitions="*, Auto">
                    <StackPanel Grid.Column="0">
                        <TextBlock Text="DRUŻYNA KAMPANII" FontSize="11" FontWeight="Bold" Foreground="{DynamicResource AccentPrimary}" LetterSpacing="1"/>
                        <TextBlock Text="Kliknij na postać, aby dodać ją do walki" FontSize="12" Foreground="{DynamicResource TextMuted}" Margin="0,2,0,0"/>
                    </StackPanel>
                    <Button Grid.Column="1" Classes="ghost" Command="{Binding AddAllPartyToCombatCommand}" 
                            BorderThickness="1" BorderBrush="{DynamicResource BorderInput}" Padding="12,6">
                        <TextBlock Text="Dodaj wszystkich" FontSize="12" Foreground="{DynamicResource AccentPrimary}"/>
                    </Button>
                </Grid>

                <!-- Lista postaci z drużyny (karty klikalne) -->
                <ItemsControl ItemsSource="{Binding PartyCharacters}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <WrapPanel Orientation="Horizontal"/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Button Classes="card" Command="{Binding ((vm:SessionDetailViewModel)DataContext).AddPartyMemberToCombatCommand, ElementName=Root}"
                                    CommandParameter="{Binding}"
                                    Padding="12,10" Margin="0,0,10,0">
                                <StackPanel Orientation="Horizontal" Spacing="10">
                                    <Border Width="32" Height="32" CornerRadius="16" Background="{DynamicResource AccentPrimaryDark}">
                                        <PathIcon Data="{StaticResource IconShield}" Width="16" Height="16" Foreground="{DynamicResource AccentPrimary}"/>
                                    </Border>
                                    <StackPanel VerticalAlignment="Center">
                                        <TextBlock Text="{Binding CharacterName}" FontSize="13" FontWeight="Bold" Foreground="{DynamicResource TextSecondary}"/>
                                        <TextBlock Text="{Binding ClassAndLevel}" FontSize="11" Foreground="{DynamicResource TextMuted}"/>
                                    </StackPanel>
                                </StackPanel>
                            </Button>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <!-- Separator -->
                <Border Height="1" Background="{DynamicResource BorderSecondary}"/>

                <!-- Formularz ręcznego dodawania (dla potworów/NPC) -->
                <StackPanel Spacing="8">
                    <TextBlock Text="DODAJ RĘCZNIE (POTWORY / NPC)" FontSize="11" FontWeight="Bold" Foreground="{DynamicResource AccentDanger}" LetterSpacing="1"/>
                    <Grid ColumnDefinitions="*, 100, 100, Auto, Auto">
                        <TextBox Grid.Column="0" Text="{Binding NewCombatantName}" 
                                 PlaceholderText="Nazwa potwora/NPC..." 
                                 Margin="0,0,8,0"
                                 Background="{DynamicResource AppBackground}" BorderBrush="{DynamicResource BorderSecondary}" CornerRadius="6" Padding="10,8"/>
                        <TextBox Grid.Column="1" Text="{Binding NewCombatantInitiative}" 
                                 PlaceholderText="Inicjatywa" 
                                 Margin="0,0,8,0"
                                 Background="{DynamicResource AppBackground}" BorderBrush="{DynamicResource BorderSecondary}" CornerRadius="6" Padding="10,8" TextAlignment="Center"/>
                        <TextBox Grid.Column="2" Text="{Binding NewCombatantHp}" 
                                 PlaceholderText="Max HP" 
                                 Margin="0,0,8,0"
                                 Background="{DynamicResource AppBackground}" BorderBrush="{DynamicResource BorderSecondary}" CornerRadius="6" Padding="10,8" TextAlignment="Center"/>
                        
                        <CheckBox Grid.Column="3" IsChecked="{Binding NewCombatantIsEnemy}" 
                                  Content="Wróg" Foreground="{DynamicResource AccentDanger}" Margin="0,0,12,0" VerticalAlignment="Center"/>
                        
                        <Button Grid.Column="4" Classes="accent" Command="{Binding AddCombatantCommand}" Padding="16,8">
                            <StackPanel Orientation="Horizontal" Spacing="6">
                                <PathIcon Data="{StaticResource IconAdd}" Width="12" Height="12" />
                                <TextBlock Text="Dodaj"/>
                            </StackPanel>
                        </Button>
                    </Grid>
                </StackPanel>
            </StackPanel>
        </Border>

        <!-- ===== SEKCJA 2: PASEK KONTROLNY WALKI ===== -->
        <Border Grid.Row="1" Background="{DynamicResource CardHoverBackground}" CornerRadius="8" Padding="16,12" Margin="0,0,0,16">
            <Grid ColumnDefinitions="Auto, Auto, *, Auto, Auto, Auto, Auto">
                
                <!-- Informacja o rundzie -->
                <Border Grid.Column="0" Background="{DynamicResource BorderSecondary}" CornerRadius="6" Padding="14,8" Margin="0,0,16,0">
                    <StackPanel Orientation="Horizontal" Spacing="6">
                        <TextBlock Text="RUNDA" FontSize="11" FontWeight="Bold" Foreground="{DynamicResource TextMuted}" VerticalAlignment="Center"/>
                        <TextBlock Text="{Binding CurrentRound}" FontSize="18" FontWeight="Bold" Foreground="{DynamicResource AccentGold}" VerticalAlignment="Center"/>
                    </StackPanel>
                </Border>

                <!-- Status walki -->
                <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center" Margin="0,0,16,0" IsVisible="{Binding !IsCombatActive}">
                    <PathIcon Data="{StaticResource IconPause}" Width="14" Height="14" Foreground="{DynamicResource TextMuted}"/>
                    <TextBlock Text="WALKA NIEAKTYWNA" Foreground="{DynamicResource TextMuted}" FontSize="12" FontWeight="SemiBold"/>
                </StackPanel>
                <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center" Margin="0,0,16,0" IsVisible="{Binding IsCombatActive}">
                    <PathIcon Data="{StaticResource IconSwords}" Width="14" Height="14" Foreground="{DynamicResource AccentDanger}"/>
                    <TextBlock Text="WALKA TRWA" Foreground="{DynamicResource AccentDanger}" FontSize="12" FontWeight="Bold"/>
                </StackPanel>

                <!-- Spacer -->
                <Border Grid.Column="2"/>
                
                <!-- Przyciski akcji -->
                <Button Grid.Column="3" Classes="success" Command="{Binding StartCombatCommand}" 
                        IsVisible="{Binding !IsCombatActive}" Margin="0,0,8,0">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <PathIcon Data="{StaticResource IconPlay}" Width="14" Height="14" />
                        <TextBlock Text="Rozpocznij Walkę"/>
                    </StackPanel>
                </Button>

                <Button Grid.Column="3" Classes="danger" Command="{Binding StopCombatCommand}" 
                        IsVisible="{Binding IsCombatActive}" Margin="0,0,8,0">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <PathIcon Data="{StaticResource IconStop}" Width="14" Height="14" />
                        <TextBlock Text="Zakończ Walkę"/>
                    </StackPanel>
                </Button>
                
                <Button Grid.Column="4" Classes="ghost" Command="{Binding SortInitiativeCommand}" 
                        BorderThickness="1" BorderBrush="{DynamicResource BorderInput}" Margin="0,0,8,0">
                    <StackPanel Orientation="Horizontal" Spacing="6" HorizontalAlignment="Center">
                        <PathIcon Data="{StaticResource IconSort}" Width="14" Height="14" Foreground="{DynamicResource TextMuted}"/>
                        <TextBlock Text="Sortuj" Foreground="{DynamicResource TextMuted}" FontSize="12"/>
                    </StackPanel>
                </Button>

                <Button Grid.Column="5" Classes="accent" Command="{Binding NextTurnCommand}" Padding="20,8" Margin="0,0,8,0">
                    <StackPanel Orientation="Horizontal" Spacing="8" HorizontalAlignment="Center">
                        <TextBlock Text="Następna Tura" FontWeight="Bold"/>
                        <PathIcon Data="{StaticResource IconNext}" Width="16" Height="16" />
                    </StackPanel>
                </Button>

                <Button Grid.Column="6" Classes="dangerGhost" Command="{Binding ClearAllCombatantsCommand}" BorderThickness="1">
                    <PathIcon Data="{StaticResource IconTrash}" Width="14" Height="14" />
                </Button>
            </Grid>
        </Border>
        
        <!-- ===== SEKCJA 3: LISTA UCZESTNIKÓW WALKI ===== -->
        <ScrollViewer Grid.Row="2">
            <StackPanel>
                <!-- Pusty stan -->
                <Border IsVisible="{Binding !CombatantsList.Count}" 
                        Background="{DynamicResource CardBackground}" CornerRadius="12" Padding="40" 
                        HorizontalAlignment="Stretch">
                    <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="12">
                        <PathIcon Data="{StaticResource IconSwords}" Width="48" Height="48" HorizontalAlignment="Center" Foreground="{DynamicResource BorderInput}"/>
                        <TextBlock Text="Brak uczestników walki" FontSize="16" Foreground="{DynamicResource TextMuted}" HorizontalAlignment="Center"/>
                        <TextBlock Text="Dodaj postaci z drużyny lub ręcznie powyżej" FontSize="13" Foreground="{DynamicResource TextMuted}" HorizontalAlignment="Center"/>
                    </StackPanel>
                </Border>

                <!-- Lista walczących -->
                <ItemsControl ItemsSource="{Binding CombatantsList}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <!-- Wiersz walczącego -->
                            <Border CornerRadius="10" Padding="16,14" Margin="0,0,0,8" BorderThickness="2">
                                <Border.Styles>
                                    <!-- Domyślnie: ciemne tło -->
                                    <Style Selector="Border">
                                        <Setter Property="Background" Value="{DynamicResource CardBackground}"/>
                                        <Setter Property="BorderBrush" Value="{DynamicResource BorderSecondary}"/>
                                    </Style>
                                </Border.Styles>
                                
                                <Grid ColumnDefinitions="44, 12, *, Auto, 16, Auto, 16, Auto">
                                    
                                    <!-- Numer tury / Ikona aktywnej tury -->
                                    <Border Grid.Column="0" Width="40" Height="40" CornerRadius="20" 
                                            VerticalAlignment="Center">
                                        <Border.Styles>
                                            <Style Selector="Border">
                                                <Setter Property="Background" Value="{DynamicResource InputBackground}"/>
                                            </Style>
                                        </Border.Styles>
                                        <!-- Ikona aktywnej tury -->
                                        <Panel>
                                            <PathIcon Data="{StaticResource IconChevronRight}" Width="18" Height="18" Foreground="{DynamicResource AccentGold}"
                                                      HorizontalAlignment="Center" VerticalAlignment="Center"
                                                      IsVisible="{Binding IsActiveTurn}"/>
                                            <Panel IsVisible="{Binding !IsActiveTurn}">
                                                <PathIcon Data="{StaticResource IconShield}" Width="18" Height="18" Foreground="{DynamicResource AccentPrimary}"
                                                          HorizontalAlignment="Center" VerticalAlignment="Center"
                                                          IsVisible="{Binding !IsEnemy}"/>
                                                <PathIcon Data="{StaticResource IconSkull}" Width="18" Height="18" Foreground="{DynamicResource AccentDanger}"
                                                          HorizontalAlignment="Center" VerticalAlignment="Center"
                                                          IsVisible="{Binding IsEnemy}"/>
                                            </Panel>
                                        </Panel>
                                    </Border>
                                    
                                    <!-- Nazwa i typ -->
                                    <StackPanel Grid.Column="2" VerticalAlignment="Center">
                                        <TextBlock Text="{Binding Name}" FontSize="17" FontWeight="Bold" Foreground="{DynamicResource TextSecondary}"/>
                                        <StackPanel Orientation="Horizontal" Spacing="8" Margin="0,3,0,0">
                                            <TextBlock Text="PRZECIWNIK" FontSize="10" Foreground="{DynamicResource AccentDanger}" FontWeight="Bold" IsVisible="{Binding IsEnemy}"/>
                                            <TextBlock Text="BOHATER" FontSize="10" Foreground="{DynamicResource AccentPrimary}" FontWeight="Bold" IsVisible="{Binding !IsEnemy}"/>
                                        </StackPanel>
                                    </StackPanel>
                                    
                                    <!-- Inicjatywa -->
                                    <Border Grid.Column="3" Background="{DynamicResource InputBackground}" CornerRadius="8" Padding="12,6" VerticalAlignment="Center" MinWidth="70">
                                        <StackPanel HorizontalAlignment="Center">
                                            <TextBlock Text="INIC." FontSize="9" Foreground="{DynamicResource TextMuted}" FontWeight="Bold" HorizontalAlignment="Center"/>
                                            <TextBox Text="{Binding Initiative}" 
                                                     FontSize="20" FontWeight="Bold" Foreground="{DynamicResource TextPrimary}" 
                                                     TextAlignment="Center" 
                                                     Background="Transparent" BorderThickness="0" 
                                                     Padding="0" MinWidth="40" HorizontalContentAlignment="Center"/>
                                        </StackPanel>
                                    </Border>

                                    <!-- HP -->
                                    <Border Grid.Column="5" Background="{DynamicResource InputBackground}" CornerRadius="8" Padding="12,6" VerticalAlignment="Center" MinWidth="120">
                                        <StackPanel HorizontalAlignment="Center">
                                            <TextBlock Text="PUNKTY ŻYCIA" FontSize="9" Foreground="{DynamicResource TextMuted}" FontWeight="Bold" HorizontalAlignment="Center"/>
                                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Spacing="4">
                                                <TextBox Text="{Binding CurrentHp}" 
                                                         Width="50" TextAlignment="Center" 
                                                         FontSize="18" FontWeight="Bold" 
                                                         Padding="4,2" 
                                                         Background="Transparent" BorderThickness="0" 
                                                         Foreground="{DynamicResource AccentDanger}"/>
                                                <TextBlock Text="/" Foreground="{DynamicResource BorderSecondary}" VerticalAlignment="Center" FontSize="16"/>
                                                <TextBlock Text="{Binding MaxHp}" Foreground="{DynamicResource TextMuted}" VerticalAlignment="Center" FontSize="16" FontWeight="SemiBold"/>
                                            </StackPanel>
                                        </StackPanel>
                                    </Border>
                                    
                                    <!-- Przycisk usunięcia -->
                                    <Button Grid.Column="7" Classes="iconDanger"
                                            Command="{Binding ((vm:SessionDetailViewModel)DataContext).RemoveCombatantCommand, ElementName=Root}" 
                                            CommandParameter="{Binding}" 
                                            VerticalAlignment="Center">
                                        <PathIcon Data="{StaticResource IconTrash}" Width="14" Height="14" />
                                    </Button>
                                    
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </StackPanel>
        </ScrollViewer>

    </Grid>
</UserControl>
