<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:DungeonApp.ViewModels"
             x:Class="DungeonApp.Views.Sessions.SessionCombatView"
             x:DataType="vm:SessionDetailViewModel"
             x:Name="Root">

    <Grid ColumnDefinitions="6*, 4*" Margin="0,10,0,0">

        <!-- ========================================== -->
        <!-- LEWA STRONA: MASYWNY PANEL KONTROLNY       -->
        <!-- ========================================== -->
        <ScrollViewer Grid.Column="0" Margin="0,0,30,0" HorizontalScrollBarVisibility="Disabled">
            <StackPanel Spacing="20">

                <!-- ===== SEKCJA 1: SZYBKIE DODAWANIE DRUŻYNY ===== -->
                <Border IsVisible="{Binding IsEditable}" Background="{DynamicResource CardBackground}" CornerRadius="{StaticResource CardCornerRadius}" Padding="{StaticResource CardPadding}" BorderThickness="0">
                    <StackPanel Spacing="20">
                        <!-- Nagłówek sekcji drużyny -->
                        <Grid ColumnDefinitions="*, Auto">
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="DRUŻYNA KAMPANII" FontSize="14" FontWeight="Bold" Foreground="{DynamicResource TextMuted}" LetterSpacing="1"/>
                                <TextBlock Text="Kliknij na postać, aby dodać ją do walki" FontSize="15" Foreground="{DynamicResource TextMuted}" Margin="0,2,0,0"/>
                            </StackPanel>
                            <Button Grid.Column="1" Classes="ghost" Command="{Binding AddAllPartyToCombatCommand}" 
                                    BorderThickness="0"  Padding="15,8">
                                <TextBlock Text="Dodaj wszystkich" FontSize="15" Foreground="{DynamicResource TextSecondary}"/>
                            </Button>
                        </Grid>

                        <!-- Lista postaci z drużyny -->
                        <ItemsControl ItemsSource="{Binding PartyCharacters}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <WrapPanel Orientation="Horizontal"/>
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Button Classes="card" Command="{Binding ((vm:SessionDetailViewModel)DataContext).AddPartyMemberToCombatCommand, ElementName=Root}"
                                            CommandParameter="{Binding}"
                                            Padding="15,12" Margin="0,0,12,12">
                                        <StackPanel Orientation="Horizontal" Spacing="12">
                                            <Border Width="40" Height="40" CornerRadius="20" Background="{DynamicResource InputBackground}">
                                                <PathIcon Data="{StaticResource IconShield}" Width="20" Height="20" Foreground="{DynamicResource TextMuted}"/>
                                            </Border>
                                            <StackPanel VerticalAlignment="Center">
                                                <TextBlock Text="{Binding CharacterName}" FontSize="16" FontWeight="Bold" Foreground="{DynamicResource TextSecondary}"/>
                                                <TextBlock Text="{Binding ClassAndLevel}" FontSize="14" Foreground="{DynamicResource TextMuted}"/>
                                            </StackPanel>
                                        </StackPanel>
                                    </Button>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <!-- Separator -->
                        <Border Height="1" Background="{DynamicResource BorderSecondary}"/>

                        <!-- Formularz ręcznego dodawania -->
                        <StackPanel Spacing="10">
                            <TextBlock Text="DODAJ RĘCZNIE (POTWORY / NPC)" FontSize="14" FontWeight="Bold" Foreground="{DynamicResource TextMuted}" LetterSpacing="1"/>
                            <Grid ColumnDefinitions="*, 90, 90, Auto, Auto" RowDefinitions="Auto, Auto">
                                <TextBlock Grid.Row="0" Grid.Column="0" Text="NAZWA POTWORA" FontSize="12" FontWeight="Bold" Foreground="{DynamicResource TextMuted}" Margin="0,0,10,5"/>
                                <TextBlock Grid.Row="0" Grid.Column="1" Text="INICJATYWA" FontSize="12" FontWeight="Bold" Foreground="{DynamicResource TextMuted}" Margin="0,0,10,5" HorizontalAlignment="Center"/>
                                <TextBlock Grid.Row="0" Grid.Column="2" Text="MAX HP" FontSize="12" FontWeight="Bold" Foreground="{DynamicResource TextMuted}" Margin="0,0,10,5" HorizontalAlignment="Center"/>

                                <TextBox Grid.Row="1" Grid.Column="0" Text="{Binding NewCombatantName}" 
                                         PlaceholderText="Nazwa potwora/NPC..." 
                                         Margin="0,0,10,0"
                                         Background="{DynamicResource AppBackground}"  CornerRadius="8" Padding="12,10"/>
                                <TextBox Grid.Row="1" Grid.Column="1" Text="{Binding NewCombatantInitiative}" 
                                         PlaceholderText="0" 
                                         Margin="0,0,10,0"
                                         Background="{DynamicResource AppBackground}"  CornerRadius="8" Padding="12,10" TextAlignment="Center"/>
                                <TextBox Grid.Row="1" Grid.Column="2" Text="{Binding NewCombatantHp}" 
                                         PlaceholderText="10" 
                                         Margin="0,0,10,0"
                                         Background="{DynamicResource AppBackground}"  CornerRadius="8" Padding="12,10" TextAlignment="Center"/>
                                
                                <CheckBox Grid.Row="1" Grid.Column="3" IsChecked="{Binding NewCombatantIsEnemy}" 
                                          Content="Wróg" Foreground="{DynamicResource TextSecondary}" Margin="0,0,15,0" VerticalAlignment="Center"/>
                                
                                <Button Grid.Row="1" Grid.Column="4" Classes="ghost" BorderThickness="0"  Command="{Binding AddCombatantCommand}" Padding="22,12">
                                    <StackPanel Orientation="Horizontal" Spacing="8">
                                        <PathIcon Data="{StaticResource IconAdd}" Width="15" Height="15" Foreground="{DynamicResource TextMuted}"/>
                                        <TextBlock Text="Dodaj" Foreground="{DynamicResource TextSecondary}"/>
                                    </StackPanel>
                                </Button>
                            </Grid>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- ===== SEKCJA 2: PASEK KONTROLNY WALKI ===== -->
                <Border Background="{DynamicResource CardHoverBackground}" CornerRadius="10" Padding="20,15">
                    <Grid ColumnDefinitions="Auto, 160, *, Auto, Auto, Auto" RowDefinitions="Auto">
                        
                        <!-- Runda i Status (Zgrupowane by zachować stabilność) -->
                        <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="20">
                            <Border Background="{DynamicResource BorderSecondary}" CornerRadius="8" Padding="18,10">
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <TextBlock Text="RUNDA" FontSize="14" FontWeight="Bold" Foreground="{DynamicResource TextMuted}" VerticalAlignment="Center"/>
                                    <TextBlock Text="{Binding CurrentRound}" FontSize="22" FontWeight="Bold" Foreground="{DynamicResource AccentGold}" VerticalAlignment="Center" MinWidth="31" TextAlignment="Center"/>
                                </StackPanel>
                            </Border>

                            <!-- Zastosowano staly wymiar kontenera dla uniknięcia skakania elementow -->
                            <Border Width="200">
                                <Panel VerticalAlignment="Center">
                                    <StackPanel Orientation="Horizontal" Spacing="10" IsVisible="{Binding !IsCombatActive}">
                                        <PathIcon Data="{StaticResource IconPause}" Width="18" Height="18" Foreground="{DynamicResource TextMuted}"/>
                                        <TextBlock Text="WALKA NIEAKTYWNA" Foreground="{DynamicResource TextMuted}" FontSize="15" FontWeight="SemiBold"/>
                                    </StackPanel>
                                    <StackPanel Orientation="Horizontal" Spacing="10" IsVisible="{Binding IsCombatActive}">
                                        <PathIcon Data="{StaticResource IconSwords}" Width="18" Height="18" Foreground="{DynamicResource TextSecondary}"/>
                                        <TextBlock Text="WALKA TRWA" Foreground="{DynamicResource TextSecondary}" FontSize="15" FontWeight="Bold"/>
                                    </StackPanel>
                                </Panel>
                            </Border>
                        </StackPanel>

                        <!-- Przyciski akcji (Do prawej) -->
                        <StackPanel Grid.Column="3" Orientation="Horizontal" Spacing="10">
                            <Button Classes="ghost" BorderThickness="0"  Command="{Binding StartCombatCommand}" 
                                    IsVisible="{Binding !IsCombatActive}">
                                <StackPanel Orientation="Horizontal" Spacing="10">
                                    <PathIcon Data="{StaticResource IconPlay}" Width="18" Height="18" Foreground="{DynamicResource TextSecondary}" />
                                    <TextBlock Text="Rozpocznij" Foreground="{DynamicResource TextSecondary}" />
                                </StackPanel>
                            </Button>

                            <Button Classes="danger" Command="{Binding StopCombatCommand}" 
                                    IsVisible="{Binding IsCombatActive}">
                                <StackPanel Orientation="Horizontal" Spacing="10">
                                    <PathIcon Data="{StaticResource IconStop}" Width="18" Height="18" />
                                    <TextBlock Text="Zakończ"/>
                                </StackPanel>
                            </Button>
                        </StackPanel>

                        <Button Grid.Column="4" Classes="ghost" Command="{Binding SortInitiativeCommand}" 
                                BorderThickness="0"  Margin="10,0,0,0" Padding="20,12">
                            <StackPanel Orientation="Horizontal" Spacing="8" HorizontalAlignment="Center">
                                <PathIcon Data="{StaticResource IconSort}" Width="18" Height="18" Foreground="{DynamicResource TextMuted}"/>
                                <TextBlock Text="Sortuj" Foreground="{DynamicResource TextMuted}" FontSize="15"/>
                            </StackPanel>
                        </Button>

                        <StackPanel Grid.Column="5" Orientation="Horizontal" Spacing="10" Margin="10,0,0,0">
                            <Button Classes="primary" Command="{Binding NextTurnCommand}" Padding="25,10">
                                <StackPanel Orientation="Horizontal" Spacing="10" HorizontalAlignment="Center">
                                    <TextBlock Text="Następna Tura" FontWeight="Bold"/>
                                    <PathIcon Data="{StaticResource IconNext}" Width="20" Height="20" />
                                </StackPanel>
                            </Button>
                            <Button Classes="dangerGhost" Command="{Binding ClearAllCombatantsCommand}" BorderThickness="0" Padding="15,12" ToolTip.Tip="Wyczyść listę">
                                <PathIcon Data="{StaticResource IconTrash}" Width="18" Height="18" />
                            </Button>
                        </StackPanel>

                    </Grid>
                </Border>

            </StackPanel>
        </ScrollViewer>


        <!-- ========================================== -->
        <!-- PRAWA STRONA: KOLEJKA WALKI (QUEUE)        -->
        <!-- ========================================== -->
        <ScrollViewer Grid.Column="1" HorizontalScrollBarVisibility="Disabled">
            <StackPanel>
                
                <!-- Nagłówek kolejki -->
                <TextBlock Text="KOLEJKA TUR" FontSize="14" FontWeight="Bold" Foreground="{DynamicResource TextMuted}" LetterSpacing="1" Margin="0,0,0,15"/>

                <!-- Pusty stan -->
                <Border IsVisible="{Binding !CombatantsList.Count}" 
                        Background="{DynamicResource CardBackground}" CornerRadius="15" Padding="38" 
                        HorizontalAlignment="Stretch">
                    <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="15">
                        <PathIcon Data="{StaticResource IconSwords}" Width="40" Height="40" HorizontalAlignment="Center" Foreground="{DynamicResource BorderInput}"/>
                        <TextBlock Text="Kolejka jest pusta" FontSize="18" Foreground="{DynamicResource TextMuted}" HorizontalAlignment="Center"/>
                    </StackPanel>
                </Border>

                <!-- Lista walczących -->
                <ItemsControl ItemsSource="{Binding CombatantsList}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <!-- Kompaktowa karta -->
                            <Border CornerRadius="10" Padding="15,10" Margin="0,0,0,8" 
                                    Background="{DynamicResource CardBackground}" 
                                    BorderThickness="0" 
                                    Classes.isDead="{Binding IsDead}"
                                    Classes.isActiveTurn="{Binding IsActiveTurn}">
                                <Border.Styles>
                                    <Style Selector="Border.isDead">
                                        <Setter Property="Opacity" Value="0.4"/>
                                        <Setter Property="BorderBrush" Value="{DynamicResource AccentDanger}"/>
                                    </Style>
                                    <Style Selector="Border.isActiveTurn">
                                        <Setter Property="BorderBrush" Value="{DynamicResource AccentGold}"/>
                                        <Setter Property="BorderThickness" Value="4,0,0,0"/>
                                        <Setter Property="Background" Value="{DynamicResource HoverGrip}"/>
                                    </Style>
                                </Border.Styles>
                                
                                <Grid ColumnDefinitions="Auto, *, Auto, Auto">
                                    
                                    <!-- Ikona / Numer tury -->
                                    <Border Grid.Column="0" Width="45" Height="45" CornerRadius="22" 
                                            Background="{DynamicResource InputBackground}"
                                            VerticalAlignment="Center" Margin="0,0,15,0">
                                        <Panel>
                                            <PathIcon Data="{StaticResource IconChevronRight}" Width="20" Height="20" Foreground="{DynamicResource AccentGold}"
                                                      HorizontalAlignment="Center" VerticalAlignment="Center"
                                                      IsVisible="{Binding IsActiveTurn}"/>
                                            <Panel IsVisible="{Binding !IsActiveTurn}">
                                                <PathIcon Data="{StaticResource IconShield}" Width="20" Height="20" Foreground="{DynamicResource AccentPrimary}"
                                                          HorizontalAlignment="Center" VerticalAlignment="Center"
                                                          IsVisible="{Binding !IsEnemy}"/>
                                                <PathIcon Data="{StaticResource IconSkull}" Width="20" Height="20" Foreground="{DynamicResource AccentDanger}"
                                                          HorizontalAlignment="Center" VerticalAlignment="Center"
                                                          IsVisible="{Binding IsEnemy}"/>
                                            </Panel>
                                        </Panel>
                                    </Border>
                                    
                                    <!-- Nazwa i typ (Rozciąga się) -->
                                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                        <TextBlock Text="{Binding Name}" FontSize="19" FontWeight="Bold" Foreground="{DynamicResource TextSecondary}" TextTrimming="CharacterEllipsis"/>
                                    </StackPanel>
                                    
                                    <!-- HP i Inicjatywa w kompaktowym bloku -->
                                    <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center" Margin="15,0,0,0" Spacing="10">
                                        
                                        <!-- Inicjatywa (Mała) -->
                                        <StackPanel VerticalAlignment="Center" Width="56">
                                            <TextBlock Text="INICJ." FontSize="10" Foreground="{DynamicResource TextMuted}" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,0,0,2"/>
                                            <Border Background="{DynamicResource InputBackground}" CornerRadius="5" Padding="2">
                                                <TextBox Text="{Binding Initiative}" 
                                                         FontSize="16" FontWeight="Bold" Foreground="{DynamicResource TextPrimary}" 
                                                         TextAlignment="Center" Background="Transparent" BorderThickness="0" 
                                                         Padding="0" MinHeight="0" VerticalAlignment="Center" VerticalContentAlignment="Center"/>
                                            </Border>
                                        </StackPanel>
                                        
                                        <!-- HP (Kompaktowe) -->
                                        <StackPanel VerticalAlignment="Center" Width="112">
                                            <TextBlock Text="HP" FontSize="10" Foreground="{DynamicResource TextMuted}" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,0,0,2"/>
                                            <Border Background="{DynamicResource InputBackground}" CornerRadius="5" Padding="5,2">
                                                <Grid ColumnDefinitions="*, Auto, *">
                                                    <TextBox Grid.Column="0" Text="{Binding CurrentHp}" 
                                                             HorizontalAlignment="Center" TextAlignment="Center" 
                                                             FontSize="18" FontWeight="Bold" Foreground="{DynamicResource AccentDanger}" 
                                                             Background="Transparent" BorderThickness="0" Padding="0" MinHeight="0"
                                                             VerticalAlignment="Center" VerticalContentAlignment="Center"/>
                                                    <TextBlock Grid.Column="1" Text="/" Foreground="{DynamicResource BorderSecondary}" VerticalAlignment="Center" FontSize="18" Margin="2,0,2,1"/>
                                                    <TextBlock Grid.Column="2" Text="{Binding MaxHp}" HorizontalAlignment="Center" TextAlignment="Center" FontSize="15" FontWeight="SemiBold" Foreground="{DynamicResource TextMuted}" VerticalAlignment="Center"/>
                                                </Grid>
                                            </Border>
                                        </StackPanel>

                                    </StackPanel>
                                    
                                    <!-- Przyciski akcji (Małe ikonki) -->
                                    <StackPanel Grid.Column="3" Orientation="Horizontal" Spacing="5" VerticalAlignment="Center" Margin="15,0,0,0">
                                        <Button Classes="iconDanger"
                                                Command="{Binding ((vm:SessionDetailViewModel)DataContext).ToggleCombatantDeadCommand, ElementName=Root}" 
                                                CommandParameter="{Binding}" 
                                                Padding="8"
                                                ToolTip.Tip="Oznacz jako martwego / żywego">
                                            <PathIcon Data="{StaticResource IconSkull}" Width="18" Height="18" />
                                        </Button>
                                        <Button Classes="iconDanger"
                                                Command="{Binding ((vm:SessionDetailViewModel)DataContext).RemoveCombatantCommand, ElementName=Root}" 
                                                CommandParameter="{Binding}" 
                                                Padding="8"
                                                ToolTip.Tip="Usuń z walki">
                                            <PathIcon Data="{StaticResource IconTrash}" Width="18" Height="18" />
                                        </Button>
                                    </StackPanel>
                                    
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </StackPanel>
        </ScrollViewer>

    </Grid>
</UserControl>

