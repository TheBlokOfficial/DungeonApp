<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:DungeonApp.ViewModels"
             x:Class="DungeonApp.Views.SessionDetailView"
             x:DataType="vm:SessionDetailViewModel"
             x:Name="Root"
             Background="#171717">

    <Grid RowDefinitions="Auto, *" Margin="30">

        <!-- Górny pasek -->
        <Grid Grid.Row="0" ColumnDefinitions="Auto,*,Auto" Margin="0,0,0,24">
            <Button Grid.Column="0" Command="{Binding BackCommand}" Background="Transparent" BorderThickness="0" CornerRadius="6" Padding="10,8">
                <TextBlock Text="← Wróć do kampanii" FontSize="14" Foreground="#A3A3A3"/>
            </Button>

            <StackPanel Grid.Column="1" HorizontalAlignment="Center" VerticalAlignment="Center">
                <TextBox Text="{Binding Session.Title}" FontSize="24" FontWeight="Bold" Background="Transparent" BorderThickness="0" TextAlignment="Center" IsVisible="{Binding IsEditable}" PlaceholderText="Wpisz tytuł sesji..."/>
                <TextBlock Text="{Binding Session.Title}" FontSize="24" FontWeight="Bold" Foreground="#FFFFFF" TextAlignment="Center" IsVisible="{Binding IsReadOnly}"/>
            </StackPanel>
        </Grid>

        <!-- Obszar Zakładek -->
        <TabControl Grid.Row="1" Background="Transparent" Padding="0,20,0,0">
            
            <TabItem Header="NOTATKI">
                <Grid RowDefinitions="Auto, Auto, *">
                    <TextBox Grid.Row="0" Text="{Binding SearchQuery}" PlaceholderText="Wyszukaj..." 
                             Background="#1E1E1E" BorderThickness="1" Margin="0,0,0,16" Padding="12"/>

                    <Border Grid.Row="1" IsVisible="{Binding IsEditable}" Background="#1A1A1A" CornerRadius="8" Padding="16" Margin="0,0,0,24" BorderBrush="#292929" BorderThickness="1">
                        <Grid ColumnDefinitions="*, Auto">
                            <TextBox Grid.Column="0" Text="{Binding NewNoteText}" PlaceholderText="Nowa notatka..." 
                                     AcceptsReturn="True" MaxHeight="120" MinHeight="60" TextWrapping="Wrap" 
                                     Background="#171717" BorderBrush="#292929" BorderThickness="1" Margin="0,0,16,0"/>
                            <Button Grid.Column="1" Command="{Binding AddNoteCommand}" VerticalAlignment="Bottom"
                                    Background="#D4A017" Foreground="#171717" FontWeight="Bold" CornerRadius="6" Padding="20,12">
                                <TextBlock Text="Dodaj" />
                            </Button>
                        </Grid>
                    </Border>

                    <ScrollViewer Grid.Row="2">
                        <ItemsControl ItemsSource="{Binding FilteredNotes}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Background="#1A1A1A" CornerRadius="8" Padding="20" Margin="0,0,0,12" BorderBrush="#292929" BorderThickness="1">
                                        <Grid ColumnDefinitions="*, Auto">
                                            <StackPanel Grid.Column="0" Margin="0,0,16,0" IsVisible="{Binding !IsEditing}">
                                                <TextBlock Text="{Binding CreatedAt, StringFormat='{}{0:HH:mm}'}" FontSize="12" Foreground="#888888"/>
                                                <SelectableTextBlock Text="{Binding Text}" FontSize="15" Foreground="#E5E5E5" TextWrapping="Wrap"/>
                                            </StackPanel>
                                            
                                            <!-- Tryb Edycji -->
                                            <StackPanel Grid.Column="0" IsVisible="{Binding IsEditing}">
                                                <TextBox Text="{Binding DraftText}" AcceptsReturn="True" TextWrapping="Wrap" Background="#171717"/>
                                                <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                                                    <Button Command="{Binding ((vm:SessionDetailViewModel)DataContext).EditNoteCancelCommand, ElementName=Root, FallbackValue=null}" CommandParameter="{Binding}" Content="Anuluj" Margin="0,0,8,0"/>
                                                    <Button Command="{Binding ((vm:SessionDetailViewModel)DataContext).EditNoteSaveCommand, ElementName=Root, FallbackValue=null}" CommandParameter="{Binding}" Content="Zapisz" Background="#D4A017"/>
                                                </StackPanel>
                                            </StackPanel>

                                            <StackPanel Grid.Column="1" Orientation="Horizontal" IsVisible="{Binding !IsEditing}">
                                                <Button Command="{Binding ((vm:SessionDetailViewModel)DataContext).EditNoteStartCommand, ElementName=Root, FallbackValue=null}" CommandParameter="{Binding}" IsVisible="{Binding ((vm:SessionDetailViewModel)DataContext).IsEditable, ElementName=Root}" Background="Transparent">
                                                    <PathIcon Data="{StaticResource IconEdit}" Width="16" Foreground="#888888"/>
                                                </Button>
                                                <Button Command="{Binding ((vm:SessionDetailViewModel)DataContext).DeleteNoteCommand, ElementName=Root, FallbackValue=null}" CommandParameter="{Binding}" IsVisible="{Binding ((vm:SessionDetailViewModel)DataContext).IsEditable, ElementName=Root}" Background="Transparent">
                                                    <PathIcon Data="{StaticResource IconTrash}" Width="16" Foreground="#FF4D4D"/>
                                                </Button>
                                            </StackPanel>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </Grid>
            </TabItem>

            <TabItem Header="BOHATEROWIE"><Border Background="#1A1A1A" CornerRadius="8"/></TabItem>
            <TabItem Header="PRZECIWNICY"><Border Background="#1A1A1A" CornerRadius="8"/></TabItem>
        </TabControl>
    </Grid>
</UserControl>