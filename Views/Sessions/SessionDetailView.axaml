<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:DungeonApp.ViewModels"
             xmlns:sessions="clr-namespace:DungeonApp.Views.Sessions"
             x:Class="DungeonApp.Views.SessionDetailView"
             x:DataType="vm:SessionDetailViewModel"
             x:Name="Root">

    <Grid RowDefinitions="Auto, Auto, *" Margin="30">
        
        <!-- NAGŁÓWEK WIDOKU SESJI -->
        <Grid Grid.Row="0" ColumnDefinitions="Auto, *, Auto" Margin="0,0,0,24">
            <!-- Przycisk powrotu -->
            <Button Grid.Column="0" Command="{Binding BackCommand}" 
                    Background="Transparent" BorderThickness="0" Padding="8,4" Margin="0,0,20,0"
                    Foreground="#888888" VerticalAlignment="Center">
                <Button.Styles>
                    <Style Selector="Button:pointerover /template/ ContentPresenter">
                        <Setter Property="Background" Value="#292929"/>
                    </Style>
                </Button.Styles>
                <StackPanel Orientation="Horizontal" Spacing="8">
                    <TextBlock Text="←" FontSize="16" />
                    <TextBlock Text="Wróć do kampanii" VerticalAlignment="Center" />
                </StackPanel>
            </Button>

            <!-- Tytuł sesji -->
            <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Center">
                <TextBlock Text="{Binding Campaign.Name}" FontSize="26" FontWeight="Bold" Foreground="#888888" Margin="0,0,12,0"/>
                <TextBlock Text="/" FontSize="26" Foreground="#555555" Margin="0,0,12,0"/>
                <TextBlock Text="{Binding Session.Title}" FontSize="26" FontWeight="Bold" Foreground="#FFFFFF" />
            </StackPanel>
        </Grid>

        <!-- NAVBAR DLA PRZEŁĄCZANYCH ZAKŁADEK -->
        <StackPanel Grid.Row="1" Orientation="Horizontal" Spacing="12" Margin="0,0,0,24">
            <!-- Przełącznik do Notatek -->
            <ToggleButton x:Name="NavNotesToggle" Click="NavToggle_Click"
                          Background="#232323" BorderBrush="#333333" BorderThickness="1" CornerRadius="8" Padding="16,8">
                <ToggleButton.Styles>
                    <Style Selector="ToggleButton:pointerover /template/ ContentPresenter">
                        <Setter Property="Background" Value="#2A2A2A"/>
                    </Style>
                    <Style Selector="ToggleButton:checked /template/ ContentPresenter">
                        <Setter Property="Background" Value="#1A2A3A"/>
                        <Setter Property="BorderBrush" Value="#4DB8FF"/>
                    </Style>
                </ToggleButton.Styles>
                <StackPanel Orientation="Horizontal" Spacing="8">
                    <PathIcon Data="{StaticResource IconEdit}" Width="14" Height="14" Foreground="#4DB8FF"/>
                    <TextBlock Text="Notatki Sesji" FontSize="13" Foreground="#DDDDDD" FontWeight="SemiBold"/>
                </StackPanel>
            </ToggleButton>

            <!-- Przełącznik do Walki -->
            <ToggleButton x:Name="NavCombatToggle" Click="NavToggle_Click"
                          Background="#232323" BorderBrush="#333333" BorderThickness="1" CornerRadius="8" Padding="16,8">
                <ToggleButton.Styles>
                    <Style Selector="ToggleButton:pointerover /template/ ContentPresenter">
                        <Setter Property="Background" Value="#2A2A2A"/>
                    </Style>
                    <Style Selector="ToggleButton:checked /template/ ContentPresenter">
                        <Setter Property="Background" Value="#3A1A1A"/>
                        <Setter Property="BorderBrush" Value="#FF4D4D"/>
                    </Style>
                </ToggleButton.Styles>
                <StackPanel Orientation="Horizontal" Spacing="8">
                    <PathIcon Data="{StaticResource IconSwords}" Width="14" Height="14" Foreground="#FF4D4D"/>
                    <TextBlock Text="Tracker Walki" FontSize="13" Foreground="#DDDDDD" FontWeight="SemiBold"/>
                </StackPanel>
            </ToggleButton>
        </StackPanel>

        <!-- OBSZAR PANELI -->
        <Grid Grid.Row="2" x:Name="ContentGrid" ColumnDefinitions="*, 16, *">
            
            <!-- KOLUMNA NOTATEK -->
            <Border x:Name="NotesPanel" Grid.Column="0" HorizontalAlignment="Left" Background="#111111" CornerRadius="12" Padding="20" BorderBrush="#222222" BorderThickness="1" MinWidth="600" MaxWidth="1200">
                <Grid RowDefinitions="Auto, *">
                    <StackPanel Grid.Row="0" Orientation="Horizontal" Spacing="8" Margin="0,0,0,16">
                        <PathIcon Data="{StaticResource IconEdit}" Width="16" Height="16" Foreground="#4DB8FF"/>
                        <TextBlock Text="NOTATKI SESJI" FontSize="12" FontWeight="Bold" Foreground="#4DB8FF" LetterSpacing="1"/>
                    </StackPanel>
                    
                    <sessions:SessionNotesView Grid.Row="1" />
                </Grid>
            </Border>

            <!-- SPLITTER PIONOWY -->
            <GridSplitter x:Name="PanelSplitter" Grid.Column="1" Background="Transparent" ResizeDirection="Columns" HorizontalAlignment="Stretch">
                <GridSplitter.Template>
                    <ControlTemplate>
                        <Border Background="Transparent" Width="16">
                            <Border Background="#2A2A2A" Width="4" Height="40" CornerRadius="2" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </GridSplitter.Template>
            </GridSplitter>

            <!-- KOLUMNA WALKI -->
            <Border x:Name="CombatPanel" Grid.Column="2" HorizontalAlignment="Left" Background="#111111" CornerRadius="12" Padding="20" BorderBrush="#222222" BorderThickness="1" MinWidth="600" MaxWidth="1200">
                <Grid RowDefinitions="Auto, *">
                    <StackPanel Grid.Row="0" Orientation="Horizontal" Spacing="8" Margin="0,0,0,16">
                        <PathIcon Data="{StaticResource IconSwords}" Width="16" Height="16" Foreground="#FF4D4D"/>
                        <TextBlock Text="TRACKER WALKI" FontSize="12" FontWeight="Bold" Foreground="#FF4D4D" LetterSpacing="1"/>
                    </StackPanel>

                    <sessions:SessionCombatView Grid.Row="1" />
                </Grid>
            </Border>
            
        </Grid>

    </Grid>
</UserControl>