<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:DungeonApp.ViewModels"
             xmlns:sessions="clr-namespace:DungeonApp.Views.Sessions"
             x:Class="DungeonApp.Views.SessionDetailView"
             x:DataType="vm:SessionDetailViewModel"
             x:Name="Root">

    <Grid HorizontalAlignment="Stretch">
        <Grid RowDefinitions="Auto, Auto, *" Margin="38">
        
        <!-- NAGŁÓWEK WIDOKU SESJI -->
        <Grid Grid.Row="0" ColumnDefinitions="Auto, *, Auto" Margin="0,0,0,30">
            <!-- Przycisk powrotu -->
            <Button Grid.Column="0" Classes="ghost" Command="{Binding BackCommand}" Margin="0,0,25,0" VerticalAlignment="Center">
                <StackPanel Orientation="Horizontal" Spacing="10">
                    <TextBlock Text="←" FontSize="20" Foreground="{DynamicResource TextMuted}" />
                    <TextBlock Text="Wróć do kampanii" VerticalAlignment="Center" Foreground="{DynamicResource TextMuted}" />
                </StackPanel>
            </Button>

            <!-- Tytuł sesji -->
            <Grid Grid.Column="1" ColumnDefinitions="Auto, Auto, Auto" HorizontalAlignment="Center">
                <TextBlock Grid.Column="0" Text="{Binding Campaign.Name}" MaxWidth="312" TextTrimming="CharacterEllipsis" FontSize="32" FontWeight="Bold" Foreground="{DynamicResource TextMuted}" Margin="0,0,15,0"/>
                <TextBlock Grid.Column="1" Text="/" FontSize="32" Foreground="{DynamicResource BorderSecondary}" Margin="0,0,15,0"/>
                <TextBlock Grid.Column="2" Text="{Binding Session.Title}" MaxWidth="438" TextTrimming="CharacterEllipsis" FontSize="32" FontWeight="Bold" Foreground="{DynamicResource TextPrimary}" />
            </Grid>
        </Grid>

        <!-- NAVBAR DLA ZAKŁADEK -->
        <StackPanel Grid.Row="1" Orientation="Horizontal" Spacing="15" Margin="0,0,0,30">
            <!-- Zakładka Notatki -->
            <RadioButton Theme="{StaticResource {x:Type ToggleButton}}" GroupName="SessionTabs" Command="{Binding SwitchTabCommand}" CommandParameter="Notes" IsChecked="{Binding IsNotesTabActive, Mode=OneWay}"
                          Background="Transparent" BorderThickness="0" CornerRadius="10" Padding="20,10">
                <RadioButton.Styles>
                    <Style Selector="RadioButton:pointerover /template/ ContentPresenter">
                        <Setter Property="Background" Value="{DynamicResource HoverGrip}"/>
                    </Style>
                    <Style Selector="RadioButton:checked /template/ ContentPresenter">
                        <Setter Property="Background" Value="{DynamicResource CardHoverBackground}"/>
                    </Style>
                </RadioButton.Styles>
                <StackPanel Orientation="Horizontal" Spacing="10">
                    <PathIcon Data="{StaticResource IconEdit}" Width="18" Height="18" Foreground="{DynamicResource TextMuted}"/>
                    <TextBlock Text="Notatki Sesji" FontSize="16" Foreground="{DynamicResource TextSecondary}" FontWeight="SemiBold"/>
                </StackPanel>
            </RadioButton>

            <!-- Zakładka Walka -->
            <RadioButton Theme="{StaticResource {x:Type ToggleButton}}" GroupName="SessionTabs" Command="{Binding SwitchTabCommand}" CommandParameter="CombatTracker" IsChecked="{Binding IsCombatTabActive, Mode=OneWay}"
                          Background="Transparent" BorderThickness="0" CornerRadius="10" Padding="20,10">
                <RadioButton.Styles>
                    <Style Selector="RadioButton:pointerover /template/ ContentPresenter">
                        <Setter Property="Background" Value="{DynamicResource HoverGrip}"/>
                    </Style>
                    <Style Selector="RadioButton:checked /template/ ContentPresenter">
                        <Setter Property="Background" Value="{DynamicResource CardHoverBackground}"/>
                    </Style>
                </RadioButton.Styles>
                <StackPanel Orientation="Horizontal" Spacing="10">
                    <PathIcon Data="{StaticResource IconSwords}" Width="18" Height="18" Foreground="{DynamicResource TextMuted}"/>
                    <TextBlock Text="Tracker Walki" FontSize="16" Foreground="{DynamicResource TextSecondary}" FontWeight="SemiBold"/>
                </StackPanel>
            </RadioButton>
        </StackPanel>

        <!-- OBSZAR PANELI -->
        <ScrollViewer Grid.Row="2" HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Disabled">
            <!-- Bezpieczny, pojedynczy system wymieniania ekranów podrzędnych -->
            <TransitioningContentControl PageTransition="{x:Null}" Content="{Binding ActiveTabContent}" HorizontalAlignment="Stretch" />
        </ScrollViewer>

        </Grid>
    </Grid>
</UserControl>
