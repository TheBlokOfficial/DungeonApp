<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:DungeonApp.ViewModels"
             x:Class="DungeonApp.Views.CreateSessionView"
             x:DataType="vm:CreateSessionViewModel"
             Background="#171717">

    <UserControl.Styles>
        <Style Selector="TextBox">
            <Setter Property="Background" Value="#1E1E1E"/>
            <Setter Property="Foreground" Value="#E5E5E5"/>
            <Setter Property="BorderBrush" Value="#292929"/>
            <Setter Property="CornerRadius" Value="6"/>
            <Setter Property="Padding" Value="12,10"/>
        </Style>
        <!-- Delikatny styl dla CheckBox�w -->
        <Style Selector="CheckBox">
            <Setter Property="Foreground" Value="#EEEEEE"/>
        </Style>
    </UserControl.Styles>

    <Grid VerticalAlignment="Center" HorizontalAlignment="Center">
        <Border Classes="popModal" Background="#1A1A1A" 
                 
                BorderThickness="0" 
                CornerRadius="15" 
                Padding="50" 
                Width="625" 
                MaxHeight="812">
            
            <Grid RowDefinitions="Auto, *, Auto">
                <!-- NAGŁÓWEK -->
                <StackPanel Grid.Row="0" Orientation="Horizontal" Spacing="12" HorizontalAlignment="Center" Margin="0,0,0,30">
                    <PathIcon Data="{StaticResource IconAdd}" Width="30" Height="30" Foreground="#D4A017"/>
                    <TextBlock Text="Rozpocznij Nową Sesję" FontSize="30" FontWeight="Bold" Foreground="#FFFFFF" VerticalAlignment="Center"/>
                </StackPanel>

                <!-- FORMULARZ ZE SCROLLOWANIEM (przydatne przy dużej ilości postaci) -->
                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                    <StackPanel Spacing="30">
                        <StackPanel Spacing="10">
                            <TextBlock Text="Tytuł Sesji *" Foreground="#888888" FontSize="16" FontWeight="Medium"/>
                            <TextBox Text="{Binding Title}" PlaceholderText="np. Podróż do Neverwinter..."/>
                        </StackPanel>

                        <StackPanel Spacing="10">
                            <TextBlock Text="Obecni Bohaterowie" Foreground="#888888" FontSize="16" FontWeight="Medium"/>
                            <!-- Pojemnik na listę CheckBoxów -->
                            <Border Background="#171717"  BorderThickness="0" CornerRadius="8" Padding="20,15">
                                <Grid>
                                    <ItemsControl ItemsSource="{Binding AvailableCharacters}"
                                                  IsVisible="{Binding AvailableCharacters.Count}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <!-- CheckBox po��czony z klas� CharacterSelectionItem -->
                                                <CheckBox IsChecked="{Binding IsSelected}" Margin="0,8">
                                                    <TextBlock Text="{Binding Character.CharacterName}" FontSize="19" FontWeight="Medium" />
                                                </CheckBox>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>

                                    <!-- Stan pusty, gdy w kampanii nie ma jeszcze postaci -->
                                    <TextBlock Text="Brak przypisanych postaci do kampanii."
                                               IsVisible="{Binding !AvailableCharacters.Count}"
                                               Foreground="#666666"
                                               FontStyle="Italic"
                                               Margin="0,5"/>
                                </Grid>
                            </Border>
                        </StackPanel>
                    </StackPanel>
                </ScrollViewer>

                <!-- PRZYCISKI -->
                <Grid Grid.Row="2" ColumnDefinitions="*, *" Margin="0,30,0,0">
                    <Button Grid.Column="0" Content="Anuluj" Command="{Binding CancelCommand}"
                            Background="Transparent"  BorderThickness="0" 
                            Foreground="#A3A3A3" Padding="19,15" CornerRadius="8" 
                            HorizontalAlignment="Stretch" HorizontalContentAlignment="Center" Margin="0,0,8,0">
                        <Button.Styles><Style Selector="Button:pointerover /template/ ContentPresenter"><Setter Property="Background" Value="#292929"/><Setter Property="Foreground" Value="#FFFFFF"/></Style></Button.Styles>
                    </Button>
                    <Button Grid.Column="1" Content="Rozpocznij" Command="{Binding CreateCommand}"
                            Background="#D4A017" Foreground="#171717" FontWeight="Bold" 
                            Padding="19,15" CornerRadius="8" 
                            HorizontalAlignment="Stretch" HorizontalContentAlignment="Center" Margin="8,0,0,0">
                        <Button.Styles><Style Selector="Button:pointerover /template/ ContentPresenter"><Setter Property="Background" Value="#E5B027"/></Style></Button.Styles>
                    </Button>
                </Grid>
            </Grid>
        </Border>
    </Grid>
</UserControl>

