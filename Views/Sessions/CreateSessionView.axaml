<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:DungeonApp.ViewModels"
             x:Class="DungeonApp.Views.CreateSessionView"
             x:DataType="vm:CreateSessionViewModel"
             Background="#171717">

    <UserControl.Styles>
        <Style Selector="TextBox">
            <Setter Property="Background" Value="#1E1E1E"/>
            <Setter Property="Foreground" Value="#E5E5E5"/>
            <Setter Property="BorderBrush" Value="#292929"/>
            <Setter Property="CornerRadius" Value="6"/>
            <Setter Property="Padding" Value="12,10"/>
        </Style>
        <!-- Delikatny styl dla CheckBoxów -->
        <Style Selector="CheckBox">
            <Setter Property="Foreground" Value="#EEEEEE"/>
        </Style>
    </UserControl.Styles>

    <Grid VerticalAlignment="Center" HorizontalAlignment="Center">
        <Border Background="#1A1A1A" 
                BorderBrush="#292929" 
                BorderThickness="1" 
                CornerRadius="12" 
                Padding="40" 
                Width="500" 
                MaxHeight="650">
            
            <Grid RowDefinitions="Auto, *, Auto">
                <!-- NAGŁÓWEK -->
                <StackPanel Grid.Row="0" Orientation="Horizontal" Spacing="10" HorizontalAlignment="Center" Margin="0,0,0,24">
                    <PathIcon Data="{StaticResource IconAdd}" Width="24" Height="24" Foreground="#D4A017"/>
                    <TextBlock Text="Rozpocznij Nową Sesję" FontSize="24" FontWeight="Bold" Foreground="#FFFFFF" VerticalAlignment="Center"/>
                </StackPanel>

                <!-- FORMULARZ Z SCROLLOWANIEM (przydatne przy dużej ilości postaci) -->
                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                    <StackPanel Spacing="24">
                        <StackPanel Spacing="8">
                            <TextBlock Text="Tytuł Sesji *" Foreground="#888888" FontSize="13" FontWeight="Medium"/>
                            <TextBox Text="{Binding Title}" PlaceholderText="np. Podróż do Neverwinter..."/>
                        </StackPanel>

                        <StackPanel Spacing="8">
                            <TextBlock Text="Obecni Bohaterowie" Foreground="#888888" FontSize="13" FontWeight="Medium"/>
                            <!-- Pojemnik na listę CheckBoxów -->
                            <Border Background="#171717" BorderBrush="#292929" BorderThickness="1" CornerRadius="6" Padding="16,12">
                                <Grid>
                                    <ItemsControl ItemsSource="{Binding AvailableCharacters}"
                                                  IsVisible="{Binding AvailableCharacters.Count}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <!-- CheckBox połączony z klasą CharacterSelectionItem -->
                                                <CheckBox IsChecked="{Binding IsSelected}" Margin="0,6">
                                                    <TextBlock Text="{Binding Character.CharacterName}" FontSize="15" FontWeight="Medium" />
                                                </CheckBox>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>

                                    <!-- Stan pusty, gdy w kampanii nie ma jeszcze postaci -->
                                    <TextBlock Text="Brak przypisanych postaci do kampanii."
                                               IsVisible="{Binding !AvailableCharacters.Count}"
                                               Foreground="#666666"
                                               FontStyle="Italic"
                                               Margin="0,4"/>
                                </Grid>
                            </Border>
                        </StackPanel>
                    </StackPanel>
                </ScrollViewer>

                <!-- PRZYCISKI -->
                <Grid Grid.Row="2" ColumnDefinitions="*, *" Margin="0,24,0,0">
                    <Button Grid.Column="0" Content="Anuluj" Command="{Binding CancelCommand}"
                            Background="Transparent" BorderBrush="#333333" BorderThickness="1" 
                            Foreground="#A3A3A3" Padding="15,12" CornerRadius="6" 
                            HorizontalAlignment="Stretch" HorizontalContentAlignment="Center" Margin="0,0,6,0">
                        <Button.Styles><Style Selector="Button:pointerover /template/ ContentPresenter"><Setter Property="Background" Value="#292929"/><Setter Property="Foreground" Value="#FFFFFF"/></Style></Button.Styles>
                    </Button>
                    <Button Grid.Column="1" Content="Rozpocznij" Command="{Binding CreateCommand}"
                            Background="#D4A017" Foreground="#171717" FontWeight="Bold" 
                            Padding="15,12" CornerRadius="6" 
                            HorizontalAlignment="Stretch" HorizontalContentAlignment="Center" Margin="6,0,0,0">
                        <Button.Styles><Style Selector="Button:pointerover /template/ ContentPresenter"><Setter Property="Background" Value="#E5B027"/></Style></Button.Styles>
                    </Button>
                </Grid>
            </Grid>
        </Border>
    </Grid>
</UserControl>
