<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:converters="using:Avalonia.Data.Converters"
        xmlns:vm="using:DungeonApp.ViewModels"
        xmlns:views="using:DungeonApp.Views"
        xmlns:dashboard="clr-namespace:DungeonApp.Views.Dashboard"
        x:Class="DungeonApp.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Name="RootWindow"
        Title="Dungeon App"
        Width="1500" Height="1000" MinWidth="{Binding ScaledMinWidth}" MinHeight="{Binding ScaledMinHeight}"
        Background="{DynamicResource AppBackground}"
        Focusable="True"
        Icon="/Assets/avalonia-logo.ico">

    <LayoutTransformControl>
        <LayoutTransformControl.LayoutTransform>
            <ScaleTransform ScaleX="{Binding EffectiveUiScale}" ScaleY="{Binding EffectiveUiScale}" />
        </LayoutTransformControl.LayoutTransform>
        <Grid>
            <views:DashboardView />
        </Grid>
    </LayoutTransformControl>
</Window>