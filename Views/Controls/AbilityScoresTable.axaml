<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:i18n="using:DungeonApp.Markup"
             xmlns:controlsVM="using:DungeonApp.ViewModels.Controls"
             xmlns:converters="using:DungeonApp.Converters"
             mc:Ignorable="d" d:DesignWidth="400" d:DesignHeight="200"
             x:Class="DungeonApp.Views.Controls.AbilityScoresTable"
             x:DataType="controlsVM:AbilityScoresViewModel">

    <UserControl.Resources>
        <converters:ScoreToColorConverter x:Key="ScoreToColorConverter"/>
    </UserControl.Resources>

    <Grid ColumnDefinitions="Auto, 15, Auto" HorizontalAlignment="Left" Margin="0,10,0,10">
        <!-- Left Table -->
        <Grid Grid.Column="0" ColumnDefinitions="85, 40, 45, 45" RowDefinitions="Auto, Auto, Auto, Auto">
            <!-- Headers -->
            <TextBlock Grid.Row="0" Grid.Column="2" Text="MOD" Foreground="{DynamicResource TextMuted}" FontSize="11" HorizontalAlignment="Center" Margin="5,0,5,5"/>
            <TextBlock Grid.Row="0" Grid.Column="3" Text="SAVE" Foreground="{DynamicResource TextMuted}" FontSize="11" HorizontalAlignment="Center" Margin="5,0,5,5"/>

            <!-- Backgrounds & Outer Borders -->
            <Border Grid.Row="1" Grid.RowSpan="3" Grid.Column="0" Grid.ColumnSpan="2" Background="{DynamicResource InputBackground}" BorderBrush="{DynamicResource BorderSecondary}" BorderThickness="1,1,0,1" />
            <Border Grid.Row="1" Grid.RowSpan="3" Grid.Column="2" Grid.ColumnSpan="2" Background="{DynamicResource CardBackground}" BorderBrush="{DynamicResource BorderSecondary}" BorderThickness="1,1,1,1" />

            <!-- Horizontal Dividers -->
            <Border Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="4" BorderBrush="{DynamicResource BorderSecondary}" BorderThickness="0,0,0,1" />
            <Border Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="4" BorderBrush="{DynamicResource BorderSecondary}" BorderThickness="0,0,0,1" />

            <!-- Row 1: STR -->
            <TextBlock Grid.Row="1" Grid.Column="0" Text="{i18n:Translate ui_stat_str}" FontWeight="Bold" Foreground="{DynamicResource TextPrimary}" FontSize="13" Margin="10,8,6,8" VerticalAlignment="Center"/>
            <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding Abilities.Strength}" Foreground="{Binding Abilities.Strength, Converter={StaticResource ScoreToColorConverter}}" FontSize="16" Margin="0,8,6,8" VerticalAlignment="Center" HorizontalAlignment="Center"/>
            <TextBlock Grid.Row="1" Grid.Column="2" Text="{Binding StrMod}" Foreground="{DynamicResource TextPrimary}" FontSize="14" Margin="6,8" VerticalAlignment="Center" HorizontalAlignment="Center"/>
            <TextBlock Grid.Row="1" Grid.Column="3" Text="{Binding StrSave}" Foreground="{DynamicResource TextPrimary}" FontSize="14" Margin="6,8" VerticalAlignment="Center" HorizontalAlignment="Center"/>

            <!-- Row 2: DEX -->
            <TextBlock Grid.Row="2" Grid.Column="0" Text="{i18n:Translate ui_stat_dex}" FontWeight="Bold" Foreground="{DynamicResource TextPrimary}" FontSize="13" Margin="10,8,6,8" VerticalAlignment="Center"/>
            <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding Abilities.Dexterity}" Foreground="{Binding Abilities.Dexterity, Converter={StaticResource ScoreToColorConverter}}" FontSize="16" Margin="0,8,6,8" VerticalAlignment="Center" HorizontalAlignment="Center"/>
            <TextBlock Grid.Row="2" Grid.Column="2" Text="{Binding DexMod}" Foreground="{DynamicResource TextPrimary}" FontSize="14" Margin="6,8" VerticalAlignment="Center" HorizontalAlignment="Center"/>
            <TextBlock Grid.Row="2" Grid.Column="3" Text="{Binding DexSave}" Foreground="{DynamicResource TextPrimary}" FontSize="14" Margin="6,8" VerticalAlignment="Center" HorizontalAlignment="Center"/>

            <!-- Row 3: CON -->
            <TextBlock Grid.Row="3" Grid.Column="0" Text="{i18n:Translate ui_stat_con}" FontWeight="Bold" Foreground="{DynamicResource TextPrimary}" FontSize="13" Margin="10,8,6,8" VerticalAlignment="Center"/>
            <TextBlock Grid.Row="3" Grid.Column="1" Text="{Binding Abilities.Constitution}" Foreground="{Binding Abilities.Constitution, Converter={StaticResource ScoreToColorConverter}}" FontSize="16" Margin="0,8,6,8" VerticalAlignment="Center" HorizontalAlignment="Center"/>
            <TextBlock Grid.Row="3" Grid.Column="2" Text="{Binding ConMod}" Foreground="{DynamicResource TextPrimary}" FontSize="14" Margin="6,8" VerticalAlignment="Center" HorizontalAlignment="Center"/>
            <TextBlock Grid.Row="3" Grid.Column="3" Text="{Binding ConSave}" Foreground="{DynamicResource TextPrimary}" FontSize="14" Margin="6,8" VerticalAlignment="Center" HorizontalAlignment="Center"/>
        </Grid>

        <!-- Right Table -->
        <Grid Grid.Column="2" ColumnDefinitions="85, 40, 45, 45" RowDefinitions="Auto, Auto, Auto, Auto">
            <!-- Headers -->
            <TextBlock Grid.Row="0" Grid.Column="2" Text="MOD" Foreground="{DynamicResource TextMuted}" FontSize="11" HorizontalAlignment="Center" Margin="5,0,5,5"/>
            <TextBlock Grid.Row="0" Grid.Column="3" Text="SAVE" Foreground="{DynamicResource TextMuted}" FontSize="11" HorizontalAlignment="Center" Margin="5,0,5,5"/>

            <!-- Backgrounds & Outer Borders -->
            <Border Grid.Row="1" Grid.RowSpan="3" Grid.Column="0" Grid.ColumnSpan="2" Background="{DynamicResource InputBackground}" BorderBrush="{DynamicResource BorderSecondary}" BorderThickness="1,1,0,1" />
            <Border Grid.Row="1" Grid.RowSpan="3" Grid.Column="2" Grid.ColumnSpan="2" Background="{DynamicResource CardBackground}" BorderBrush="{DynamicResource BorderSecondary}" BorderThickness="1,1,1,1" />

            <!-- Horizontal Dividers -->
            <Border Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="4" BorderBrush="{DynamicResource BorderSecondary}" BorderThickness="0,0,0,1" />
            <Border Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="4" BorderBrush="{DynamicResource BorderSecondary}" BorderThickness="0,0,0,1" />

            <!-- Row 1: INT -->
            <TextBlock Grid.Row="1" Grid.Column="0" Text="{i18n:Translate ui_stat_int}" FontWeight="Bold" Foreground="{DynamicResource TextPrimary}" FontSize="13" Margin="10,8,6,8" VerticalAlignment="Center"/>
            <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding Abilities.Intelligence}" Foreground="{Binding Abilities.Intelligence, Converter={StaticResource ScoreToColorConverter}}" FontSize="16" Margin="0,8,6,8" VerticalAlignment="Center" HorizontalAlignment="Center"/>
            <TextBlock Grid.Row="1" Grid.Column="2" Text="{Binding IntMod}" Foreground="{DynamicResource TextPrimary}" FontSize="14" Margin="6,8" VerticalAlignment="Center" HorizontalAlignment="Center"/>
            <TextBlock Grid.Row="1" Grid.Column="3" Text="{Binding IntSave}" Foreground="{DynamicResource TextPrimary}" FontSize="14" Margin="6,8" VerticalAlignment="Center" HorizontalAlignment="Center"/>

            <!-- Row 2: WIS -->
            <TextBlock Grid.Row="2" Grid.Column="0" Text="{i18n:Translate ui_stat_wis}" FontWeight="Bold" Foreground="{DynamicResource TextPrimary}" FontSize="13" Margin="10,8,6,8" VerticalAlignment="Center"/>
            <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding Abilities.Wisdom}" Foreground="{Binding Abilities.Wisdom, Converter={StaticResource ScoreToColorConverter}}" FontSize="16" Margin="0,8,6,8" VerticalAlignment="Center" HorizontalAlignment="Center"/>
            <TextBlock Grid.Row="2" Grid.Column="2" Text="{Binding WisMod}" Foreground="{DynamicResource TextPrimary}" FontSize="14" Margin="6,8" VerticalAlignment="Center" HorizontalAlignment="Center"/>
            <TextBlock Grid.Row="2" Grid.Column="3" Text="{Binding WisSave}" Foreground="{DynamicResource TextPrimary}" FontSize="14" Margin="6,8" VerticalAlignment="Center" HorizontalAlignment="Center"/>

            <!-- Row 3: CHA -->
            <TextBlock Grid.Row="3" Grid.Column="0" Text="{i18n:Translate ui_stat_cha}" FontWeight="Bold" Foreground="{DynamicResource TextPrimary}" FontSize="13" Margin="10,8,6,8" VerticalAlignment="Center"/>
            <TextBlock Grid.Row="3" Grid.Column="1" Text="{Binding Abilities.Charisma}" Foreground="{Binding Abilities.Charisma, Converter={StaticResource ScoreToColorConverter}}" FontSize="16" Margin="0,8,6,8" VerticalAlignment="Center" HorizontalAlignment="Center"/>
            <TextBlock Grid.Row="3" Grid.Column="2" Text="{Binding ChaMod}" Foreground="{DynamicResource TextPrimary}" FontSize="14" Margin="6,8" VerticalAlignment="Center" HorizontalAlignment="Center"/>
            <TextBlock Grid.Row="3" Grid.Column="3" Text="{Binding ChaSave}" Foreground="{DynamicResource TextPrimary}" FontSize="14" Margin="6,8" VerticalAlignment="Center" HorizontalAlignment="Center"/>
        </Grid>
    </Grid>
</UserControl>
