<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:DungeonApp.ViewModels"
             x:Class="DungeonApp.Views.AddCharacterToCampaignView"
             x:DataType="vm:AddCharacterToCampaignViewModel"
             Background="#171717">

    <UserControl.Styles>
        <Style Selector="CheckBox">
            <Setter Property="Foreground" Value="#EEEEEE"/>
        </Style>
    </UserControl.Styles>

    <Grid VerticalAlignment="Center" HorizontalAlignment="Center">
        <Border Background="#1A1A1A" BorderBrush="#292929" BorderThickness="1" CornerRadius="12" Padding="40" Width="500" MaxHeight="600">
            <Grid RowDefinitions="Auto, *, Auto">
                
                <!-- NAGŁÓWEK -->
                <StackPanel Grid.Row="0" Orientation="Horizontal" Spacing="10" HorizontalAlignment="Center" Margin="0,0,0,24">
                    <PathIcon Data="{StaticResource IconSwords}" Width="24" Height="24" Foreground="#D4A017"/>
                    <TextBlock Text="Zrekrutuj do Kampanii" FontSize="24" FontWeight="Bold" Foreground="#FFFFFF" VerticalAlignment="Center"/>
                </StackPanel>

                <!-- LISTA POSTACI -->
                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                    <Border Background="#171717" BorderBrush="#292929" BorderThickness="1" CornerRadius="6" Padding="16,12" Margin="0,0,0,24">
                        <Grid>
                            <ItemsControl ItemsSource="{Binding AvailableCharacters}"
                                          IsVisible="{Binding AvailableCharacters.Count}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <CheckBox IsChecked="{Binding IsSelected}" Margin="0,6">
                                            <StackPanel Orientation="Horizontal" Spacing="8">
                                                <TextBlock Text="{Binding Character.CharacterName}" FontSize="16" FontWeight="Bold" />
                                                <TextBlock Text="{Binding Character.ClassAndLevel, StringFormat='({0})'}" FontSize="13" Foreground="#888888" VerticalAlignment="Center"/>
                                            </StackPanel>
                                        </CheckBox>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>

                            <TextBlock Text="Brak wolnych postaci. Stwórz nową w Rejestrze Postaci."
                                       IsVisible="{Binding !AvailableCharacters.Count}"
                                       Foreground="#666666"
                                       FontStyle="Italic"
                                       Margin="0,4"
                                       TextWrapping="Wrap"/>
                        </Grid>
                    </Border>
                </ScrollViewer>

                <!-- PRZYCISKI -->
                <Grid Grid.Row="2" ColumnDefinitions="*, *">
                    <Button Grid.Column="0" Content="Anuluj" Command="{Binding CancelCommand}"
                            Background="Transparent" BorderBrush="#333333" BorderThickness="1" Foreground="#A3A3A3" Padding="15,12" CornerRadius="6" HorizontalAlignment="Stretch" HorizontalContentAlignment="Center" Margin="0,0,6,0">
                        <Button.Styles><Style Selector="Button:pointerover /template/ ContentPresenter"><Setter Property="Background" Value="#292929"/><Setter Property="Foreground" Value="#FFFFFF"/></Style></Button.Styles>
                    </Button>
                    <Button Grid.Column="1" Content="Zapisz" Command="{Binding SaveCommand}"
                            Background="#D4A017" Foreground="#171717" FontWeight="Bold" Padding="15,12" CornerRadius="6" HorizontalAlignment="Stretch" HorizontalContentAlignment="Center" Margin="6,0,0,0">
                        <Button.Styles><Style Selector="Button:pointerover /template/ ContentPresenter"><Setter Property="Background" Value="#E5B027"/></Style></Button.Styles>
                    </Button>
                </Grid>
                
            </Grid>
        </Border>
    </Grid>
</UserControl>
