<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:DungeonApp.ViewModels"
             x:Class="DungeonApp.Views.AddCharacterToCampaignView"
             x:DataType="vm:AddCharacterToCampaignViewModel"
             Background="{DynamicResource AppBackground}">

    <UserControl.Styles>
        <Style Selector="CheckBox">
            <Setter Property="Foreground" Value="{DynamicResource TextPrimary}"/>
        </Style>
    </UserControl.Styles>

    <Grid VerticalAlignment="Center" HorizontalAlignment="Center">
        <Border Background="{DynamicResource CardBackground}"  BorderThickness="0" CornerRadius="{DynamicResource CardCornerRadius}" Padding="{DynamicResource CardPadding}" Width="625" MaxHeight="750">
            <Grid RowDefinitions="Auto, *, Auto">
                
                <!-- NAGŁÓWEK -->
                <StackPanel Grid.Row="0" Orientation="Horizontal" Spacing="12" HorizontalAlignment="Center" Margin="0,0,0,30">
                    <PathIcon Data="{StaticResource IconSwords}" Width="30" Height="30" Foreground="{DynamicResource AccentGold}"/>
                    <TextBlock Text="Zrekrutuj do Kampanii" FontSize="30" FontWeight="Bold" Foreground="{DynamicResource TextPrimary}" VerticalAlignment="Center"/>
                </StackPanel>

                <!-- LISTA POSTACI -->
                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                    <Border Background="{DynamicResource AppBackground}"  BorderThickness="0" CornerRadius="{DynamicResource InputBorderRadius}" Padding="20,15" Margin="0,0,0,30">
                        <Grid>
                            <ItemsControl ItemsSource="{Binding AvailableCharacters}"
                                          IsVisible="{Binding AvailableCharacters.Count}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <CheckBox IsChecked="{Binding IsSelected}" Margin="0,8">
                                            <StackPanel Orientation="Horizontal" Spacing="10">
                                                <TextBlock Text="{Binding Character.CharacterName}" FontSize="20" FontWeight="Bold" />
                                                <TextBlock Text="{Binding Character.ClassAndLevel, StringFormat='({0})'}" FontSize="16" Foreground="{DynamicResource TextMuted}" VerticalAlignment="Center"/>
                                            </StackPanel>
                                        </CheckBox>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>

                            <TextBlock Text="Brak wolnych postaci. Stwórz nową w Rejestrze Postaci."
                                       IsVisible="{Binding !AvailableCharacters.Count}"
                                       Foreground="{DynamicResource TextMuted}"
                                       FontStyle="Italic"
                                       Margin="0,5"
                                       TextWrapping="Wrap"/>
                        </Grid>
                    </Border>
                </ScrollViewer>

                <!-- PRZYCISKI -->
                <Grid Grid.Row="2" ColumnDefinitions="*, *">
                    <Button Grid.Column="0" Content="Anuluj" Command="{Binding CancelCommand}" Classes="ghost"
                             BorderThickness="0" HorizontalAlignment="Stretch" Margin="0,0,8,0" />
                    <Button Grid.Column="1" Content="Zapisz" Command="{Binding SaveCommand}" Classes="primary"
                            HorizontalAlignment="Stretch" Margin="8,0,0,0" />
                </Grid>
                
            </Grid>
        </Border>
    </Grid>
</UserControl>

