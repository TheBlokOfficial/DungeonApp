<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:DungeonApp.ViewModels.Campaigns.Tabs"
             xmlns:events="using:DungeonApp.Models.Campaigns.Engine.Events"
             xmlns:module="using:DungeonApp.Models.Campaigns.Engine.Modules.Timekeeper"
             xmlns:moduleCore="using:DungeonApp.Models.Campaigns.Engine.Modules.Core"
             xmlns:moduleViews="using:DungeonApp.Views.Campaigns.Modules"
             x:Class="DungeonApp.Views.Campaigns.Tabs.CampaignDashboardView"
             x:DataType="vm:CampaignDashboardViewModel">

    <!-- DataTemplate mapujący TimekeeperModule → TimekeeperView i ConsoleModule → ConsoleView -->
    <UserControl.DataTemplates>
        <DataTemplate DataType="module:TimekeeperModule">
            <moduleViews:TimekeeperView />
        </DataTemplate>
        <DataTemplate DataType="moduleCore:ConsoleModule">
            <moduleViews:ConsoleView />
        </DataTemplate>
    </UserControl.DataTemplates>

    <!-- BENTO BOX (Układ kafelkowy, styl surowy/zarządczy) -->
    <Grid ColumnDefinitions="1*, 1.6*, 1*" RowDefinitions="Auto, *">
        
        <!-- KOLUMNA 1 (Lewa) -->

        <!-- KAFEL 1: TimekeeperModule — wstrzyknięty przez DataTemplate -->
        <Border Grid.Column="0" Grid.Row="0"
                Background="{DynamicResource CardBackground}"
                CornerRadius="4" Padding="15" Margin="0,0,10,10"
                MinHeight="180" VerticalAlignment="Stretch">
            <!--
                ContentControl binduje się do TimekeeperModule. DataTemplate zdefiniowany wyżej
                automatycznie zamienia go na TimekeeperView — kafel nie wie nic o widoku modułu.
            -->
            <ContentControl Content="{Binding TimekeeperModule}" />
        </Border>

        <!-- KAFEL 2: KONSOLA DM-a (Lewy Dół) -->
        <Border Grid.Column="0" Grid.Row="1"
                Background="{DynamicResource CardBackground}"
                CornerRadius="4" Padding="15" Margin="0,0,10,0"
                VerticalAlignment="Stretch">
            <!-- 
                Hermetyczny widok konsoli, posiadający własny code-behind (scroll)
                oraz logikę w ConsoleModule.
            -->
            <ContentControl Content="{Binding ConsoleModule}" />
        </Border>

        <!-- KOLUMNA 2 (Środek) -->

        <!-- KAFEL 3: Combat Tracker (Wielki Panel na środku) -->
        <Border Grid.Column="1" Grid.Row="0" Grid.RowSpan="2"
                Background="{DynamicResource CardBackground}"
                CornerRadius="4" Padding="15" Margin="0,0,10,0"
                VerticalAlignment="Stretch">
            <Grid RowDefinitions="Auto, *">
                <TextBlock Grid.Row="0" Text="Combat Tracker" FontSize="18" FontWeight="SemiBold" Foreground="{DynamicResource TextMuted}" Margin="0,0,0,10"/>
                <StackPanel Grid.Row="1" VerticalAlignment="Center" HorizontalAlignment="Center" Spacing="15">
                    <PathIcon Data="{StaticResource IconSwords}" Width="64" Height="64" Foreground="{DynamicResource TextMuted}" Opacity="0.2"/>
                    <TextBlock Text="WKRÓTCE" FontSize="24" FontWeight="Bold" Foreground="{DynamicResource TextMuted}" HorizontalAlignment="Center"/>
                    <TextBlock Text="Szybki podgląd i odnośnik do modułu walki." FontSize="14" Foreground="{DynamicResource TextMuted}" HorizontalAlignment="Center" TextAlignment="Center"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- KOLUMNA 3 (Prawa) -->

        <!-- KAFEL 4: Brudnopis (Prawy Górny) -->
        <Border Grid.Column="2" Grid.Row="0"
                Background="{DynamicResource CardBackground}"
                CornerRadius="4" Padding="15" Margin="0,0,0,10"
                MinHeight="180" VerticalAlignment="Stretch">
            <Grid RowDefinitions="Auto, *">
                <TextBlock Grid.Row="0" Text="Notatnik" FontSize="18" FontWeight="SemiBold" Foreground="{DynamicResource TextMuted}" Margin="0,0,0,10"/>
                <StackPanel Grid.Row="1" VerticalAlignment="Center" HorizontalAlignment="Center" Spacing="10">
                    <PathIcon Data="{StaticResource IconEdit}" Width="36" Height="36" Foreground="{DynamicResource TextMuted}" Opacity="0.2"/>
                    <TextBlock Text="WKRÓTCE" FontSize="18" FontWeight="Bold" Foreground="{DynamicResource TextMuted}" HorizontalAlignment="Center"/>
                    <TextBlock Text="Szybkie pole na notatki." FontSize="14" Foreground="{DynamicResource TextMuted}" HorizontalAlignment="Center" TextWrapping="Wrap" TextAlignment="Center"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- KAFEL 5: Moduły / Świat (Prawy Dół) -->
        <Border Grid.Column="2" Grid.Row="1"
                Background="{DynamicResource CardBackground}"
                CornerRadius="4" Padding="15"
                VerticalAlignment="Stretch">
            <Grid RowDefinitions="Auto, *">
                <TextBlock Grid.Row="0" Text="Świat" FontSize="18" FontWeight="SemiBold" Foreground="{DynamicResource TextMuted}" Margin="0,0,0,10"/>
                <StackPanel Grid.Row="1" VerticalAlignment="Center" HorizontalAlignment="Center" Spacing="10">
                    <PathIcon Data="{StaticResource IconFolder}" Width="36" Height="36" Foreground="{DynamicResource TextMuted}" Opacity="0.2"/>
                    <TextBlock Text="WKRÓTCE" FontSize="18" FontWeight="Bold" Foreground="{DynamicResource TextMuted}" HorizontalAlignment="Center"/>
                    <TextBlock Text="Podgląd paczek DLC." FontSize="14" Foreground="{DynamicResource TextMuted}" HorizontalAlignment="Center" TextWrapping="Wrap" TextAlignment="Center"/>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</UserControl>
