<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:DungeonApp.ViewModels.Campaigns.Tabs"
             x:Class="DungeonApp.Views.Campaigns.Tabs.CampaignDashboardView"
             x:DataType="vm:CampaignDashboardViewModel">

    <!-- BENTO BOX (Układ kafelkowy, styl surowy/zarządczy) -->
    <Grid ColumnDefinitions="1*, 1.6*, 1*" RowDefinitions="Auto, *">
        
        <!-- KOLUMNA 1 (Lewa) -->
        
        <!-- KAFEL 1: Informacje o Kampanii (Lewy Górny) -->
        <Border Grid.Column="0" Grid.Row="0" Background="{DynamicResource CardBackground}" CornerRadius="4" Padding="15" Margin="0,0,10,10" MinHeight="180" VerticalAlignment="Stretch">
            <Grid RowDefinitions="Auto, *">
                <TextBlock Grid.Row="0" Text="Informacje" FontSize="18" FontWeight="SemiBold" Foreground="{DynamicResource TextMuted}" Margin="0,0,0,10"/>
                <StackPanel Grid.Row="1" VerticalAlignment="Center" HorizontalAlignment="Center" Spacing="10">
                    <PathIcon Data="{StaticResource IconShield}" Width="36" Height="36" Foreground="{DynamicResource TextMuted}" Opacity="0.2"/>
                    <TextBlock Text="WKRÓTCE" FontSize="18" FontWeight="Bold" Foreground="{DynamicResource TextMuted}" HorizontalAlignment="Center"/>
                    <TextBlock Text="Krótkie podsumowanie lub notatka systemowa." FontSize="14" Foreground="{DynamicResource TextMuted}" HorizontalAlignment="Center" TextWrapping="Wrap" TextAlignment="Center"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- KAFEL 2: Oś Czasu (Lewy Dół, pod Informacjami) -->
        <Border Grid.Column="0" Grid.Row="1" Background="{DynamicResource CardBackground}" CornerRadius="4" Padding="15" Margin="0,0,10,0" VerticalAlignment="Stretch">
            <Grid RowDefinitions="Auto, *">
                <TextBlock Grid.Row="0" Text="Oś Czasu" FontSize="18" FontWeight="SemiBold" Foreground="{DynamicResource TextMuted}" Margin="0,0,0,10"/>
                <StackPanel Grid.Row="1" VerticalAlignment="Center" HorizontalAlignment="Center" Spacing="15">
                    <PathIcon Data="{StaticResource IconList}" Width="48" Height="48" Foreground="{DynamicResource TextMuted}" Opacity="0.2"/>
                    <TextBlock Text="WKRÓTCE" FontSize="20" FontWeight="Bold" Foreground="{DynamicResource TextMuted}" HorizontalAlignment="Center"/>
                    <TextBlock Text="Wizualizacja zdarzeń z kampanii." FontSize="14" Foreground="{DynamicResource TextMuted}" HorizontalAlignment="Center" TextWrapping="Wrap" TextAlignment="Center"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- KOLUMNA 2 (Środek) -->

        <!-- KAFEL 3: Combat Tracker (Wielki Panel na środku) -->
        <Border Grid.Column="1" Grid.Row="0" Grid.RowSpan="2" Background="{DynamicResource CardBackground}" CornerRadius="4" Padding="15" Margin="0,0,10,0" VerticalAlignment="Stretch">
            <Grid RowDefinitions="Auto, *">
                <TextBlock Grid.Row="0" Text="Combat Tracker" FontSize="18" FontWeight="SemiBold" Foreground="{DynamicResource TextMuted}" Margin="0,0,0,10"/>
                <StackPanel Grid.Row="1" VerticalAlignment="Center" HorizontalAlignment="Center" Spacing="15">
                    <PathIcon Data="{StaticResource IconSword}" Width="64" Height="64" Foreground="{DynamicResource TextMuted}" Opacity="0.2"/>
                    <TextBlock Text="WKRÓTCE" FontSize="24" FontWeight="Bold" Foreground="{DynamicResource TextMuted}" HorizontalAlignment="Center"/>
                    <TextBlock Text="Szybki podgląd i odnośnik do modułu walki." FontSize="14" Foreground="{DynamicResource TextMuted}" HorizontalAlignment="Center" TextAlignment="Center"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- KOLUMNA 3 (Prawa) -->

        <!-- KAFEL 4: Brudnopis (Prawy Górny) -->
        <Border Grid.Column="2" Grid.Row="0" Background="{DynamicResource CardBackground}" CornerRadius="4" Padding="15" Margin="0,0,0,10" MinHeight="180" VerticalAlignment="Stretch">
            <Grid RowDefinitions="Auto, *">
                <TextBlock Grid.Row="0" Text="Notatnik" FontSize="18" FontWeight="SemiBold" Foreground="{DynamicResource TextMuted}" Margin="0,0,0,10"/>
                <StackPanel Grid.Row="1" VerticalAlignment="Center" HorizontalAlignment="Center" Spacing="10">
                    <PathIcon Data="{StaticResource IconEdit}" Width="36" Height="36" Foreground="{DynamicResource TextMuted}" Opacity="0.2"/>
                    <TextBlock Text="WKRÓTCE" FontSize="18" FontWeight="Bold" Foreground="{DynamicResource TextMuted}" HorizontalAlignment="Center"/>
                    <TextBlock Text="Szybkie pole na notatki." FontSize="14" Foreground="{DynamicResource TextMuted}" HorizontalAlignment="Center" TextWrapping="Wrap" TextAlignment="Center"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- KAFEL 5: Moduły / Świat (Prawy Dół) -->
        <Border Grid.Column="2" Grid.Row="1" Background="{DynamicResource CardBackground}" CornerRadius="4" Padding="15" VerticalAlignment="Stretch">
            <Grid RowDefinitions="Auto, *">
                <TextBlock Grid.Row="0" Text="Świat" FontSize="18" FontWeight="SemiBold" Foreground="{DynamicResource TextMuted}" Margin="0,0,0,10"/>
                <StackPanel Grid.Row="1" VerticalAlignment="Center" HorizontalAlignment="Center" Spacing="10">
                    <PathIcon Data="{StaticResource IconFolder}" Width="36" Height="36" Foreground="{DynamicResource TextMuted}" Opacity="0.2"/>
                    <TextBlock Text="WKRÓTCE" FontSize="18" FontWeight="Bold" Foreground="{DynamicResource TextMuted}" HorizontalAlignment="Center"/>
                    <TextBlock Text="Podgląd paczek DLC." FontSize="14" Foreground="{DynamicResource TextMuted}" HorizontalAlignment="Center" TextWrapping="Wrap" TextAlignment="Center"/>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</UserControl>
