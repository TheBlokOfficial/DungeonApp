<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:DungeonApp.ViewModels"
             x:Class="DungeonApp.Views.CreateCampaignView"
             x:DataType="vm:CreateCampaignViewModel"
             Background="{DynamicResource AppBackground}"> <!-- Dajemy ciemne tło na cały ekran -->
    
    <UserControl.Styles>
        <Style Selector="TextBox">
            <Setter Property="Background" Value="{DynamicResource InputBackground}"/>
            <Setter Property="Foreground" Value="{DynamicResource TextPrimary}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BorderSecondary}"/>
            <Setter Property="CornerRadius" Value="{DynamicResource InputBorderRadius}"/>
            <Setter Property="Padding" Value="12,10"/>
        </Style>
    </UserControl.Styles>

    <!-- Centrujemy zawartość na środku ekranu -->
    <Grid VerticalAlignment="Center" HorizontalAlignment="Center">
        <Border Classes="popModal" Background="{DynamicResource CardBackground}" 
                 
                BorderThickness="0" 
                CornerRadius="{DynamicResource CardCornerRadius}" 
                Padding="{DynamicResource CardPadding}" 
                Width="625">
            
            <StackPanel Spacing="30">
                <!-- Tytuł Widoku -->
                <StackPanel Orientation="Horizontal" Spacing="12" HorizontalAlignment="Center">
                    <PathIcon Data="{StaticResource IconSwords}" Width="30" Height="30" Foreground="{DynamicResource AccentGold}"/>
                    <TextBlock Text="Stwórz Nową Kampanię" FontSize="30" FontWeight="Bold" Foreground="{DynamicResource TextPrimary}" VerticalAlignment="Center"/>
                </StackPanel>

                <!-- Formularz -->
                <StackPanel Spacing="10">
                    <TextBlock Text="Nazwa Kampanii" Foreground="{DynamicResource TextMuted}" FontSize="16" FontWeight="Medium"/>
                    <TextBox Text="{Binding Name}" PlaceholderText="np. Klątwa Strahda..."/>
                </StackPanel>

                <StackPanel Spacing="10">
                    <TextBlock Text="System RPG" Foreground="{DynamicResource TextMuted}" FontSize="16" FontWeight="Medium"/>
                    <TextBox Text="{Binding System}" PlaceholderText="np. D&amp;D 5e..."/>
                </StackPanel>

                <!-- Przyciski Akcji -->
                <Grid ColumnDefinitions="*, *" Margin="0,12,0,0">
                    <Button Grid.Column="0" Content="Anuluj" Classes="ghost"
                            Command="{Binding CancelCommand}"
                            BorderThickness="0" 
                            HorizontalAlignment="Stretch" Margin="0,0,8,0" />

                    <Button Grid.Column="1" Content="Zapisz" Classes="primary"
                            Command="{Binding CreateCommand}"
                            HorizontalAlignment="Stretch" Margin="8,0,0,0" />
                </Grid>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
