<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:DungeonApp.ViewModels"
             x:Class="DungeonApp.Views.CampaignDetailView"
             x:DataType="vm:CampaignDetailViewModel"
             x:Name="Root">

    <UserControl.Styles>
        <Style Selector=":is(Control).toggleState">
            <Setter Property="Opacity" Value="0"/>
            <Setter Property="IsHitTestVisible" Value="False"/>
        </Style>
        <Style Selector=":is(Control).toggleState.active">
            <Setter Property="Opacity" Value="1"/>
            <Setter Property="IsHitTestVisible" Value="True"/>
        </Style>

        <Style Selector="TextBox.ghostInput">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Foreground" Value="{DynamicResource TextPrimary}"/>
            <Setter Property="Padding" Value="15,0"/>
            <Setter Property="MinHeight" Value="0"/>
            <Setter Property="MinWidth" Value="60"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="Cursor" Value="IBeam"/>
        </Style>
        <Style Selector="TextBox.ghostInput:pointerover /template/ Border#PART_BorderElement">
            <Setter Property="Background" Value="{DynamicResource InputBackground}"/>
            <Setter Property="CornerRadius" Value="{DynamicResource InputBorderRadius}"/>
        </Style>
        <Style Selector="TextBox.ghostInput:focus /template/ Border#PART_BorderElement">
            <Setter Property="Background" Value="{DynamicResource InputBackground}"/>
            <Setter Property="CornerRadius" Value="{DynamicResource InputBorderRadius}"/>
        </Style>
        <Style Selector="TextBox.ghostInput.editing /template/ Border#PART_BorderElement">
            <Setter Property="Background" Value="{DynamicResource SurfaceBackground}"/>
            <Setter Property="CornerRadius" Value="{DynamicResource InputBorderRadius}"/>
        </Style>
    </UserControl.Styles>

    <!-- Główny kontener bez twardych wierszy (Warstwy Z-Index) -->
    <Grid>

        <!-- WARSTWA 1: STREFA ROBOCZA (Rozciągnięta aż do dolnego marginesu, wchodzi w tło portretów) -->
        <!-- Dolny margines 110px sprawia, że zawartość kończy się w połowie wysokości portretów (220px / 2) -->
        <Grid HorizontalAlignment="Stretch" VerticalAlignment="Stretch" Margin="50,40,50,110" RowDefinitions="Auto, Auto, *">
            
            <!-- GÓRNY PASEK: Powrót + Tytuł -->
            <StackPanel Grid.Row="0" Orientation="Horizontal" Spacing="20" Margin="0,0,0,40">
                <Button Classes="ghost" Command="{Binding BackCommand}">
                    <TextBlock Text="← Wróć" FontSize="18" Foreground="{DynamicResource TextMuted}"/>
                </Button>

                <StackPanel VerticalAlignment="Center">
                    <Grid ColumnDefinitions="300, Auto">
                        <TextBox Grid.Column="0" Classes="ghostInput" Classes.editing="{Binding IsEditingName}" Margin="-15,0,0,0"
                                 Text="{Binding Campaign.Name}" FontSize="30" FontWeight="Bold" 
                                 VerticalAlignment="Center"
                                 IsHitTestVisible="{Binding IsEditingName}"
                                 Focusable="{Binding IsEditingName}">
                            <TextBox.KeyBindings>
                                <KeyBinding Gesture="Enter" Command="{Binding SaveCampaignNameCommand}"/>
                            </TextBox.KeyBindings>
                        </TextBox>
                        
                        <Grid Grid.Column="1" Margin="10,0,0,0">
                            <Button Classes="icon toggleState" Classes.active="{Binding !IsEditingName}"
                                    Command="{Binding StartEditingNameCommand}" ToolTip.Tip="Edytuj nazwę"
                                    VerticalAlignment="Center">
                                <PathIcon Data="{StaticResource IconEdit}" Width="18" Height="18"/>
                            </Button>
                            
                            <Button Classes="primary toggleState" Classes.active="{Binding IsEditingName}"
                                    Command="{Binding SaveCampaignNameCommand}" Padding="15,8"
                                    VerticalAlignment="Center">
                                <TextBlock Text="Zapisz" FontSize="15"/>
                            </Button>
                        </Grid>
                    </Grid>
                    <TextBlock Classes="dynamic" Text="{Binding Campaign.System}" FontSize="18" Foreground="{DynamicResource TextMuted}"/>
                </StackPanel>
            </StackPanel>

            <!-- ZAKŁADKI NAWIGACYJNE (Tab Strip) -->
            <StackPanel Grid.Row="1" Orientation="Horizontal" Spacing="20" Margin="0,0,0,20">
                <RadioButton Content="Panel Główny" Theme="{StaticResource {x:Type ToggleButton}}" 
                             Command="{Binding NavigateToDashboardCommand}" 
                             IsChecked="True" GroupName="CampaignTabs"
                             FontSize="16" FontWeight="SemiBold" Padding="15,8" CornerRadius="4" />
                
                <RadioButton Content="Combat Tracker" Theme="{StaticResource {x:Type ToggleButton}}" 
                             Command="{Binding NavigateToTrackerCommand}" 
                             GroupName="CampaignTabs"
                             FontSize="16" FontWeight="SemiBold" Padding="15,8" CornerRadius="4" />
                
                <RadioButton Content="Notatki" Theme="{StaticResource {x:Type ToggleButton}}" 
                             Command="{Binding NavigateToNotesCommand}" 
                             GroupName="CampaignTabs"
                             FontSize="16" FontWeight="SemiBold" Padding="15,8" CornerRadius="4" />
                
                <RadioButton Content="Fabuła" Theme="{StaticResource {x:Type ToggleButton}}" 
                             Command="{Binding NavigateToStoryCommand}" 
                             GroupName="CampaignTabs"
                             FontSize="16" FontWeight="SemiBold" Padding="15,8" CornerRadius="4" />
            </StackPanel>

            <!-- STREFA ROBOCZA (Zawartość Aktywnej Zakładki) -->
            <TransitioningContentControl Grid.Row="2" Content="{Binding ActiveTabContent}" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" />

        </Grid>

        <!-- WARSTWA 2: STREFA HUD (Pływający Pasek cRPG z przyciskiem oka) -->
        <!-- Pozycjonowanie absolutnie na dole, przysłania dolną krawędź strefy roboczej -->
        <Border HorizontalAlignment="Stretch" VerticalAlignment="Bottom" Margin="50,0,50,0">
            <StackPanel HorizontalAlignment="Center" Spacing="0">
                
                <!-- Nagłówek i przyciski sterujące HUD -->
                <Grid ColumnDefinitions="*,Auto,Auto" Margin="0,0,0,5">
                    <TextBlock Grid.Column="0" Text="DRUŻYNA" FontSize="14" FontWeight="Bold" Foreground="{DynamicResource TextMuted}" LetterSpacing="2" VerticalAlignment="Center"/>
                    
                    <Button Grid.Column="1" Classes="ghost" Command="{Binding AddCharacterToCampaignCommand}" Padding="5" Margin="0,0,10,0" ToolTip.Tip="Dodaj postać do drużyny">
                        <PathIcon Data="{StaticResource IconAdd}" Width="16" Height="16"/>
                    </Button>

                    <Button Grid.Column="2" Classes="ghost" Command="{Binding ToggleHudCommand}" Padding="5" ToolTip.Tip="Przełącz widoczność portretów">
                        <Grid>
                            <!-- XAML Anti-Jumping dla ikony -->
                            <PathIcon Data="{StaticResource IconEye}" Width="16" Height="16" IsVisible="{Binding !IsHudVisible}"/>
                            <PathIcon Data="{StaticResource IconEyeOff}" Width="16" Height="16" IsVisible="{Binding IsHudVisible}"/>
                        </Grid>
                    </Button>
                </Grid>

                <!-- Pojemnik na portrety chowany i pokazywany -->
                <ItemsControl ItemsSource="{Binding CampaignCharacters}" IsVisible="{Binding IsHudVisible}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <StackPanel Orientation="Horizontal" Spacing="0" />
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <!-- MASYWNA KARTA PORTRETOWA cRPG BEZ ZAOKRĄGLEŃ -->
                            <!-- Tło z pełnym kryciem, by zasłaniać to, co za nim -->
                            <Border Width="160" Height="220" Background="{DynamicResource SurfaceBackground}" CornerRadius="0" BorderThickness="1,1,1,0" BorderBrush="{DynamicResource BorderMuted}" ClipToBounds="True">
                                <Grid RowDefinitions="*, Auto">
                                    
                                    <!-- Miejsce na Awatar -->
                                    <Border Grid.Row="0" Background="{DynamicResource InputBackground}">
                                        <Grid>
                                            <PathIcon Data="{StaticResource IconUser}" Width="60" Height="60" Foreground="{DynamicResource TextMuted}" Opacity="0.1" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Grid>
                                    </Border>
                                    
                                    <!-- Panel z Imionami -->
                                    <Border Grid.Row="1" Background="{DynamicResource SurfaceBackground}" Padding="10" BorderThickness="0,1,0,0" BorderBrush="{DynamicResource BorderMuted}">
                                        <StackPanel>
                                            <TextBlock Classes="dynamic" Text="{Binding CharacterName}" FontSize="18" FontWeight="Bold" Foreground="{DynamicResource TextSecondary}" TextTrimming="CharacterEllipsis" TextAlignment="Center"/>
                                            <TextBlock Classes="dynamic" Text="{Binding PlayerName}" FontSize="14" Foreground="{DynamicResource TextMuted}" Margin="0,2,0,0" TextTrimming="CharacterEllipsis" TextAlignment="Center" FontStyle="Italic"/>
                                        </StackPanel>
                                    </Border>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </StackPanel>
        </Border>

    </Grid>
</UserControl>
