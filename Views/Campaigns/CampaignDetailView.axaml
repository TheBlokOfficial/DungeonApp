<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:DungeonApp.ViewModels"
             x:Class="DungeonApp.Views.CampaignDetailView"
             x:DataType="vm:CampaignDetailViewModel"
             x:Name="Root">

    <UserControl.Styles>
        <Style Selector=":is(Control).toggleState">
            <Setter Property="Opacity" Value="0"/>
            <Setter Property="IsHitTestVisible" Value="False"/>
            <Setter Property="Transitions">
                <Transitions>
                    <DoubleTransition Property="Opacity" Duration="0:0:0.15" />
                </Transitions>
            </Setter>
        </Style>
        <Style Selector=":is(Control).toggleState.active">
            <Setter Property="Opacity" Value="1"/>
            <Setter Property="IsHitTestVisible" Value="True"/>
        </Style>

        <!-- Ghost Input Style dla tytułu kampanii -->
        <Style Selector="TextBox.ghostInput">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Foreground" Value="{DynamicResource TextPrimary}"/>
            <Setter Property="Padding" Value="15,0"/>
            <Setter Property="MinHeight" Value="0"/>
            <Setter Property="MinWidth" Value="60"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="Cursor" Value="IBeam"/>
        </Style>
        <Style Selector="TextBox.ghostInput:pointerover /template/ Border#PART_BorderElement">
            <Setter Property="Background" Value="{DynamicResource InputBackground}"/>
            <Setter Property="CornerRadius" Value="{DynamicResource InputBorderRadius}"/>
        </Style>
        <Style Selector="TextBox.ghostInput:focus /template/ Border#PART_BorderElement">
            <Setter Property="Background" Value="{DynamicResource InputBackground}"/>
            <Setter Property="CornerRadius" Value="{DynamicResource InputBorderRadius}"/>
        </Style>
        <Style Selector="TextBox.ghostInput.editing /template/ Border#PART_BorderElement">
            <Setter Property="Background" Value="{DynamicResource SurfaceBackground}"/>
            <Setter Property="CornerRadius" Value="{DynamicResource InputBorderRadius}"/>
        </Style>
    </UserControl.Styles>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="2*" />
            <ColumnDefinition Width="6*" MinWidth="720" />
            <ColumnDefinition Width="2*" />
        </Grid.ColumnDefinitions>
        <Grid Grid.Column="1" RowDefinitions="Auto,*" Margin="0,38,0,0">

        <!-- Górny pasek: powrót + nazwa kampanii -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" Spacing="20" Margin="0,0,0,38">
            <Button Classes="ghost" Command="{Binding BackCommand}">
                <TextBlock Text="← Wróć" FontSize="18" Foreground="{DynamicResource TextMuted}"/>
            </Button>

            <StackPanel VerticalAlignment="Center">
                <!-- Tytuł kampanii (Anti-Jumping Ghost UI) -->
                <Grid ColumnDefinitions="300, Auto">
                    <TextBox Grid.Column="0" Classes="ghostInput" Classes.editing="{Binding IsEditingName}" Margin="-15,0,0,0"
                             Text="{Binding Campaign.Name}" FontSize="30" FontWeight="Bold" 
                             VerticalAlignment="Center"
                             IsHitTestVisible="{Binding IsEditingName}"
                             Focusable="{Binding IsEditingName}">
                        <TextBox.KeyBindings>
                            <KeyBinding Gesture="Enter" Command="{Binding SaveCampaignNameCommand}"/>
                        </TextBox.KeyBindings>
                    </TextBox>
                    
                    <Grid Grid.Column="1" Margin="10,0,0,0">
                        <Button Classes="icon toggleState" Classes.active="{Binding !IsEditingName}"
                                Command="{Binding StartEditingNameCommand}" ToolTip.Tip="Edytuj nazwę"
                                VerticalAlignment="Center">
                            <PathIcon Data="{StaticResource IconEdit}" Width="18" Height="18"/>
                        </Button>
                        
                        <Button Classes="primary toggleState" Classes.active="{Binding IsEditingName}"
                                Command="{Binding SaveCampaignNameCommand}" Padding="15,8"
                                VerticalAlignment="Center">
                            <TextBlock Text="Zapisz" FontSize="15"/>
                        </Button>
                    </Grid>
                </Grid>

                <TextBlock Text="{Binding Campaign.System}" FontSize="18" Foreground="{DynamicResource TextMuted}"/>
            </StackPanel>
        </StackPanel>

        <!-- Główna zawartość -->
        <ScrollViewer Grid.Row="1">
            <StackPanel Spacing="30">
                
                <!-- SEKCJA 1 i 2 (Nałożone na siebie w jednej siatce, by uniknąć skakania zawartości UI) -->
                <Grid>
                    <!-- SEKCJA 1: Przycisk dodawania nowej sesji (Widoczny gdy NIE MA aktywnej) -->
                    <Button Classes="primary toggleState" Classes.active="{Binding CanAddNewSession}" Command="{Binding AddSessionCommand}"
                            HorizontalAlignment="Left" VerticalAlignment="Center">
                        <StackPanel Orientation="Horizontal" Spacing="10">
                            <PathIcon Data="{StaticResource IconAdd}" Width="18" Height="18" />
                            <TextBlock Text="Rozpocznij Nową Sesję" FontSize="18"/>
                        </StackPanel>
                    </Button>

                    <!-- SEKCJA 2: Aktywna Sesja (Widoczna gdy JEST aktywna) -->
                    <Border Classes="toggleState" Classes.active="{Binding HasActiveSession}"
                            Background="{DynamicResource CardBackground}" CornerRadius="{StaticResource CardCornerRadius}" Padding="{StaticResource CardPadding}" 
                            BorderThickness="0">
                        <Grid ColumnDefinitions="*,Auto">
                            <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                <TextBlock Text="OBECNA SESJA" FontSize="15" FontWeight="Bold" Foreground="{DynamicResource AccentGold}" Margin="0,0,0,5"/>
                                <TextBlock Text="{Binding ActiveSession.Title}" FontSize="28" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimary}"/>
                                <TextBlock Text="{Binding ActiveSession.Date, StringFormat='{}Utworzono: {0:dd.MM.yyyy}'}" FontSize="16" Foreground="{DynamicResource TextMuted}" Margin="0,5,0,0"/>
                            </StackPanel>

                            <!-- Akcje Aktywnej Sesji -->
                            <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="15" VerticalAlignment="Center">
                                
                                <Button Classes="dangerGhost" Command="{Binding DeleteActiveSessionCommand}">
                                    <TextBlock Text="Usuń" FontSize="16" />
                                </Button>

                                <!-- Zmiana nazwy na Zakończ Sesję -->
                                <Button Classes="secondary" Command="{Binding ArchiveActiveSessionCommand}">
                                    <TextBlock Text="Zakończ Sesję" FontSize="16"/>
                                </Button>

                                <Button Classes="primary" Command="{Binding OpenActiveSessionCommand}">
                                    <TextBlock Text="Prowadź Sesję →" FontSize="18"/>
                                </Button>
                            </StackPanel>
                        </Grid>
                    </Border>
                </Grid>
                
                <!-- SEKCJA DRUŻYNY -->
<StackPanel>
    <Grid ColumnDefinitions="*,Auto" Margin="0,20,0,20">
        <TextBlock Grid.Column="0" Text="Drużyna" FontSize="20" FontWeight="SemiBold" Foreground="{DynamicResource TextMuted}" VerticalAlignment="Center"/>
        <Button Grid.Column="1" Classes="secondary" Command="{Binding AddCharacterToCampaignCommand}" Padding="15,10">
            <StackPanel Orientation="Horizontal" Spacing="8">
                <PathIcon Data="{StaticResource IconAdd}" Width="15" Height="15" />
                <TextBlock Text="Zrekrutuj" FontSize="15" FontWeight="Bold"/>
            </StackPanel>
        </Button>
    </Grid>

    <Grid>
        <ItemsControl ItemsSource="{Binding CampaignCharacters}"
                      IsVisible="{Binding CampaignCharacters.Count}">
            <ItemsControl.ItemsPanel>
                <ItemsPanelTemplate>
                    <UniformGrid Columns="4" />
                </ItemsPanelTemplate>
            </ItemsControl.ItemsPanel>
            <ItemsControl.ItemTemplate>
                <DataTemplate>
                    <Border Background="{DynamicResource CardBackground}" CornerRadius="{StaticResource CardCornerRadius}" Padding="20" Margin="10" BorderThickness="0">
                        <Grid ColumnDefinitions="*, Auto">
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="{Binding CharacterName}" FontSize="20" FontWeight="Bold" Foreground="{DynamicResource TextSecondary}"/>
                                <TextBlock Text="{Binding ClassAndLevel}" FontSize="15" Foreground="{DynamicResource TextMuted}" Margin="0,5,0,0"/>
                            </StackPanel>
                            <!-- Przycisk usuwania (wypisania z kampanii) -->
                            <Button Grid.Column="1" Classes="iconDanger" Command="{Binding ((vm:CampaignDetailViewModel)DataContext).RemoveCharacterFromCampaignCommand, ElementName=Root}" CommandParameter="{Binding}" VerticalAlignment="Top">
                                <PathIcon Data="{StaticResource IconTrash}" Width="15" Height="15" />
                            </Button>
                        </Grid>
                    </Border>
                </DataTemplate>
            </ItemsControl.ItemTemplate>
        </ItemsControl>

        <TextBlock Text="Brak postaci w drużynie."
                   IsVisible="{Binding !CampaignCharacters.Count}"
                   Foreground="{DynamicResource TextMuted}"
                   FontStyle="Italic"/>
    </Grid>
</StackPanel>

                <!-- SEKCJA 3: Archiwum Sesji -->
                <StackPanel IsVisible="{Binding ArchivedSessions.Count}">
                    <TextBlock Text="Zarchiwizowane Sesje" FontSize="20" FontWeight="SemiBold" Foreground="{DynamicResource TextMuted}" Margin="0,20,0,20"/>
                    
                    <ItemsControl ItemsSource="{Binding ArchivedSessions}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <UniformGrid Columns="4" />
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Button Classes="card" Command="{Binding ((vm:CampaignDetailViewModel)DataContext).ReadArchivedSessionCommand, ElementName=Root}"
                                        CommandParameter="{Binding}"
                                        Margin="10"
                                        HorizontalAlignment="Stretch" HorizontalContentAlignment="Left">
                                    <StackPanel>
                                        <TextBlock Text="{Binding Title}" FontSize="22" FontWeight="SemiBold" Foreground="{DynamicResource TextSecondary}"/>
                                        <TextBlock Text="{Binding Date, StringFormat='{}{0:dd.MM.yyyy}'}" FontSize="16" Foreground="{DynamicResource TextMuted}" Margin="0,8,0,0"/>
                                    </StackPanel>
                                </Button>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>

            </StackPanel>
        </ScrollViewer>
        </Grid>
    </Grid>
</UserControl>
