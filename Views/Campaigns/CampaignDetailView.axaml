<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:DungeonApp.ViewModels"
             x:Class="DungeonApp.Views.CampaignDetailView"
             x:DataType="vm:CampaignDetailViewModel"
             x:Name="Root"
             Background="#171717">

    <Grid RowDefinitions="Auto,*" Margin="30">

        <!-- Górny pasek: powrót + nazwa kampanii -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" Spacing="16" Margin="0,0,0,30">
            <Button Classes="ghost" Command="{Binding BackCommand}">
                <TextBlock Text="← Wróć" FontSize="14" Foreground="#A3A3A3"/>
            </Button>

            <StackPanel VerticalAlignment="Center">
                <StackPanel Orientation="Horizontal" Spacing="8" IsVisible="{Binding !IsEditingName}">
                    <TextBlock Text="{Binding Campaign.Name}" FontSize="24" FontWeight="Bold" Foreground="#FFFFFF" VerticalAlignment="Center"/>
                    <Button Classes="icon" Command="{Binding StartEditingNameCommand}" ToolTip.Tip="Edytuj nazwę">
                        <PathIcon Data="{StaticResource IconEdit}" Width="14" Height="14"/>
                    </Button>
                </StackPanel>
                
                <StackPanel Orientation="Horizontal" Spacing="8" IsVisible="{Binding IsEditingName}">
                    <TextBox Text="{Binding Campaign.Name}" FontSize="24" FontWeight="Bold" Background="#1A1A1A" Foreground="#FFFFFF" BorderBrush="#292929" Padding="4" VerticalAlignment="Center" MinWidth="200">
                        <TextBox.KeyBindings>
                            <KeyBinding Gesture="Enter" Command="{Binding SaveCampaignNameCommand}"/>
                        </TextBox.KeyBindings>
                    </TextBox>
                    <Button Classes="accent" Command="{Binding SaveCampaignNameCommand}" Padding="12,6" VerticalAlignment="Center">
                        <TextBlock Text="Zapisz" FontSize="12"/>
                    </Button>
                </StackPanel>

                <TextBlock Text="{Binding Campaign.System}" FontSize="14" Foreground="#888888"/>
            </StackPanel>
        </StackPanel>

        <!-- Główna zawartość -->
        <ScrollViewer Grid.Row="1">
            <StackPanel Spacing="24" MaxWidth="1200" HorizontalAlignment="Stretch">
                
                <!-- SEKCJA 1: Przycisk dodawania nowej sesji (Widoczny gdy NIE MA aktywnej) -->
                <Button Classes="accent" Command="{Binding AddSessionCommand}"
                        IsVisible="{Binding CanAddNewSession}" HorizontalAlignment="Left">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <PathIcon Data="{StaticResource IconAdd}" Width="14" Height="14" />
                        <TextBlock Text="Rozpocznij Nową Sesję" FontSize="14"/>
                    </StackPanel>
                </Button>

                <!-- SEKCJA 2: Aktywna Sesja (Widoczna gdy JEST aktywna) -->
                <Border IsVisible="{Binding HasActiveSession}" 
                        Background="#1A1A1A" CornerRadius="10" Padding="24" 
                        BorderBrush="#D4A017" BorderThickness="1.5">
                    <Grid ColumnDefinitions="*,Auto">
                        <StackPanel Grid.Column="0" VerticalAlignment="Center">
                            <TextBlock Text="OBECNA SESJA" FontSize="12" FontWeight="Bold" Foreground="#D4A017" Margin="0,0,0,4"/>
                            <TextBlock Text="{Binding ActiveSession.Title}" FontSize="22" FontWeight="SemiBold" Foreground="#FFFFFF"/>
                            <TextBlock Text="{Binding ActiveSession.Date, StringFormat='{}Utworzono: {0:dd.MM.yyyy}'}" FontSize="13" Foreground="#888888" Margin="0,4,0,0"/>
                        </StackPanel>

                        <!-- Akcje Aktywnej Sesji -->
                        <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="12" VerticalAlignment="Center">
                            
                            <Button Classes="dangerGhost" Command="{Binding DeleteActiveSessionCommand}">
                                <TextBlock Text="Usuń" FontSize="13" />
                            </Button>

                            <!-- Zmiana nazwy na Zakończ Sesję -->
                            <Button Classes="secondary" Command="{Binding ArchiveActiveSessionCommand}">
                                <TextBlock Text="Zakończ Sesję" FontSize="13"/>
                            </Button>

                            <Button Classes="accent" Command="{Binding OpenActiveSessionCommand}">
                                <TextBlock Text="Prowadź Sesję →" FontSize="14"/>
                            </Button>
                        </StackPanel>
                    </Grid>
                </Border>
                
                <!-- SEKCJA DRUŻYNY -->
<StackPanel>
    <Grid ColumnDefinitions="*,Auto" Margin="0,16,0,16">
        <TextBlock Grid.Column="0" Text="Drużyna" FontSize="16" FontWeight="SemiBold" Foreground="#888888" VerticalAlignment="Center"/>
        <Button Grid.Column="1" Classes="secondary" Command="{Binding AddCharacterToCampaignCommand}" Padding="12,8">
            <StackPanel Orientation="Horizontal" Spacing="6">
                <PathIcon Data="{StaticResource IconAdd}" Width="12" Height="12" />
                <TextBlock Text="Zrekrutuj" FontSize="12" FontWeight="Bold"/>
            </StackPanel>
        </Button>
    </Grid>

    <Grid>
        <ItemsControl ItemsSource="{Binding CampaignCharacters}"
                      IsVisible="{Binding CampaignCharacters.Count}">
            <ItemsControl.ItemsPanel>
                <ItemsPanelTemplate>
                    <WrapPanel Orientation="Horizontal" ItemWidth="250" />
                </ItemsPanelTemplate>
            </ItemsControl.ItemsPanel>
            <ItemsControl.ItemTemplate>
                <DataTemplate>
                    <Border Background="#1A1A1A" CornerRadius="8" Padding="16" Margin="0,0,12,12" BorderThickness="1" BorderBrush="#292929">
                        <Grid ColumnDefinitions="*, Auto">
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="{Binding CharacterName}" FontSize="16" FontWeight="Bold" Foreground="#EEEEEE"/>
                                <TextBlock Text="{Binding ClassAndLevel}" FontSize="12" Foreground="#888888" Margin="0,4,0,0"/>
                            </StackPanel>
                            <!-- Przycisk usuwania (wypisania z kampanii) -->
                            <Button Grid.Column="1" Classes="iconDanger" Command="{Binding ((vm:CampaignDetailViewModel)DataContext).RemoveCharacterFromCampaignCommand, ElementName=Root}" CommandParameter="{Binding}" VerticalAlignment="Top">
                                <PathIcon Data="{StaticResource IconTrash}" Width="12" Height="12" />
                            </Button>
                        </Grid>
                    </Border>
                </DataTemplate>
            </ItemsControl.ItemTemplate>
        </ItemsControl>

        <TextBlock Text="Brak postaci w drużynie."
                   IsVisible="{Binding !CampaignCharacters.Count}"
                   Foreground="#555555"
                   FontStyle="Italic"/>
    </Grid>
</StackPanel>

                <!-- SEKCJA 3: Archiwum Sesji -->
                <StackPanel IsVisible="{Binding ArchivedSessions.Count}">
                    <TextBlock Text="Zarchiwizowane Sesje" FontSize="16" FontWeight="SemiBold" Foreground="#888888" Margin="0,16,0,16"/>
                    
                    <ItemsControl ItemsSource="{Binding ArchivedSessions}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <WrapPanel Orientation="Horizontal" ItemWidth="280" />
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Button Classes="card" Command="{Binding ((vm:CampaignDetailViewModel)DataContext).ReadArchivedSessionCommand, ElementName=Root}"
                                        CommandParameter="{Binding}"
                                        Margin="0,0,16,16"
                                        HorizontalAlignment="Stretch" HorizontalContentAlignment="Left">
                                    <StackPanel>
                                        <TextBlock Text="{Binding Title}" FontSize="18" FontWeight="SemiBold" Foreground="#EEEEEE"/>
                                        <TextBlock Text="{Binding Date, StringFormat='{}{0:dd.MM.yyyy}'}" FontSize="13" Foreground="#555555" Margin="0,6,0,0"/>
                                    </StackPanel>
                                </Button>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>

            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>