<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:DungeonApp.ViewModels"
             x:Class="DungeonApp.Views.CampaignDetailView"
             x:DataType="vm:CampaignDetailViewModel"
             x:Name="Root">

    <Grid HorizontalAlignment="Stretch">
        <Grid RowDefinitions="Auto,*" Margin="38">

        <!-- Górny pasek: powrót + nazwa kampanii -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" Spacing="20" Margin="0,0,0,38">
            <Button Classes="ghost" Command="{Binding BackCommand}">
                <TextBlock Text="← Wróć" FontSize="18" Foreground="{DynamicResource TextMuted}"/>
            </Button>

            <StackPanel VerticalAlignment="Center">
                <Grid ColumnDefinitions="300, Auto" IsVisible="{Binding !IsEditingName}">
                    <TextBlock Grid.Column="0" Text="{Binding Campaign.Name}" FontSize="30" FontWeight="Bold" Foreground="{DynamicResource TextPrimary}" VerticalAlignment="Center" TextTrimming="CharacterEllipsis"/>
                    <Button Grid.Column="1" Classes="icon" Command="{Binding StartEditingNameCommand}" ToolTip.Tip="Edytuj nazwę" Margin="10,0,0,0">
                        <PathIcon Data="{StaticResource IconEdit}" Width="18" Height="18"/>
                    </Button>
                </Grid>
                
                <Grid ColumnDefinitions="300, Auto" IsVisible="{Binding IsEditingName}">
                    <TextBox Grid.Column="0" Text="{Binding Campaign.Name}" FontSize="30" FontWeight="Bold" Background="{DynamicResource SurfaceBackground}" Foreground="{DynamicResource TextPrimary}"  Padding="5" VerticalAlignment="Center">
                        <TextBox.KeyBindings>
                            <KeyBinding Gesture="Enter" Command="{Binding SaveCampaignNameCommand}"/>
                        </TextBox.KeyBindings>
                    </TextBox>
                    <Button Grid.Column="1" Classes="primary" Command="{Binding SaveCampaignNameCommand}" Padding="15,8" VerticalAlignment="Center" Margin="10,0,0,0">
                        <TextBlock Text="Zapisz" FontSize="15"/>
                    </Button>
                </Grid>

                <TextBlock Text="{Binding Campaign.System}" FontSize="18" Foreground="{DynamicResource TextMuted}"/>
            </StackPanel>
        </StackPanel>

        <!-- Główna zawartość -->
        <ScrollViewer Grid.Row="1">
            <StackPanel Classes="pageContainer" Spacing="30">
                
                <!-- SEKCJA 1: Przycisk dodawania nowej sesji (Widoczny gdy NIE MA aktywnej) -->
                <Button Classes="primary" Command="{Binding AddSessionCommand}"
                        IsVisible="{Binding CanAddNewSession}" HorizontalAlignment="Left">
                    <StackPanel Orientation="Horizontal" Spacing="10">
                        <PathIcon Data="{StaticResource IconAdd}" Width="18" Height="18" />
                        <TextBlock Text="Rozpocznij Nową Sesję" FontSize="18"/>
                    </StackPanel>
                </Button>

                <!-- SEKCJA 2: Aktywna Sesja (Widoczna gdy JEST aktywna) -->
                <Border IsVisible="{Binding HasActiveSession}" 
                        Background="{DynamicResource CardBackground}" CornerRadius="{StaticResource CardCornerRadius}" Padding="{StaticResource CardPadding}" 
                        BorderThickness="0">
                    <Grid ColumnDefinitions="*,Auto">
                        <StackPanel Grid.Column="0" VerticalAlignment="Center">
                            <TextBlock Text="OBECNA SESJA" FontSize="15" FontWeight="Bold" Foreground="{DynamicResource AccentGold}" Margin="0,0,0,5"/>
                            <TextBlock Text="{Binding ActiveSession.Title}" FontSize="28" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimary}"/>
                            <TextBlock Text="{Binding ActiveSession.Date, StringFormat='{}Utworzono: {0:dd.MM.yyyy}'}" FontSize="16" Foreground="{DynamicResource TextMuted}" Margin="0,5,0,0"/>
                        </StackPanel>

                        <!-- Akcje Aktywnej Sesji -->
                        <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="15" VerticalAlignment="Center">
                            
                            <Button Classes="dangerGhost" Command="{Binding DeleteActiveSessionCommand}">
                                <TextBlock Text="Usuń" FontSize="16" />
                            </Button>

                            <!-- Zmiana nazwy na Zakończ Sesję -->
                            <Button Classes="secondary" Command="{Binding ArchiveActiveSessionCommand}">
                                <TextBlock Text="Zakończ Sesję" FontSize="16"/>
                            </Button>

                            <Button Classes="primary" Command="{Binding OpenActiveSessionCommand}">
                                <TextBlock Text="Prowadź Sesję →" FontSize="18"/>
                            </Button>
                        </StackPanel>
                    </Grid>
                </Border>
                
                <!-- SEKCJA DRUŻYNY -->
<StackPanel>
    <Grid ColumnDefinitions="*,Auto" Margin="0,20,0,20">
        <TextBlock Grid.Column="0" Text="Drużyna" FontSize="20" FontWeight="SemiBold" Foreground="{DynamicResource TextMuted}" VerticalAlignment="Center"/>
        <Button Grid.Column="1" Classes="secondary" Command="{Binding AddCharacterToCampaignCommand}" Padding="15,10">
            <StackPanel Orientation="Horizontal" Spacing="8">
                <PathIcon Data="{StaticResource IconAdd}" Width="15" Height="15" />
                <TextBlock Text="Zrekrutuj" FontSize="15" FontWeight="Bold"/>
            </StackPanel>
        </Button>
    </Grid>

    <Grid>
        <ItemsControl ItemsSource="{Binding CampaignCharacters}"
                      IsVisible="{Binding CampaignCharacters.Count}">
            <ItemsControl.ItemsPanel>
                <ItemsPanelTemplate>
                    <WrapPanel Orientation="Horizontal" ItemWidth="250" />
                </ItemsPanelTemplate>
            </ItemsControl.ItemsPanel>
            <ItemsControl.ItemTemplate>
                <DataTemplate>
                    <Border Background="{DynamicResource CardBackground}" CornerRadius="{StaticResource CardCornerRadius}" Padding="20" Margin="0,0,15,15" BorderThickness="0">
                        <Grid ColumnDefinitions="*, Auto">
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="{Binding CharacterName}" FontSize="20" FontWeight="Bold" Foreground="{DynamicResource TextSecondary}"/>
                                <TextBlock Text="{Binding ClassAndLevel}" FontSize="15" Foreground="{DynamicResource TextMuted}" Margin="0,5,0,0"/>
                            </StackPanel>
                            <!-- Przycisk usuwania (wypisania z kampanii) -->
                            <Button Grid.Column="1" Classes="iconDanger" Command="{Binding ((vm:CampaignDetailViewModel)DataContext).RemoveCharacterFromCampaignCommand, ElementName=Root}" CommandParameter="{Binding}" VerticalAlignment="Top">
                                <PathIcon Data="{StaticResource IconTrash}" Width="15" Height="15" />
                            </Button>
                        </Grid>
                    </Border>
                </DataTemplate>
            </ItemsControl.ItemTemplate>
        </ItemsControl>

        <TextBlock Text="Brak postaci w drużynie."
                   IsVisible="{Binding !CampaignCharacters.Count}"
                   Foreground="{DynamicResource TextMuted}"
                   FontStyle="Italic"/>
    </Grid>
</StackPanel>

                <!-- SEKCJA 3: Archiwum Sesji -->
                <StackPanel IsVisible="{Binding ArchivedSessions.Count}">
                    <TextBlock Text="Zarchiwizowane Sesje" FontSize="20" FontWeight="SemiBold" Foreground="{DynamicResource TextMuted}" Margin="0,20,0,20"/>
                    
                    <ItemsControl ItemsSource="{Binding ArchivedSessions}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <WrapPanel Orientation="Horizontal" ItemWidth="380" />
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Button Classes="card" Command="{Binding ((vm:CampaignDetailViewModel)DataContext).ReadArchivedSessionCommand, ElementName=Root}"
                                        CommandParameter="{Binding}"
                                        Margin="0,0,20,20"
                                        HorizontalAlignment="Stretch" HorizontalContentAlignment="Left">
                                    <StackPanel>
                                        <TextBlock Text="{Binding Title}" FontSize="22" FontWeight="SemiBold" Foreground="{DynamicResource TextSecondary}"/>
                                        <TextBlock Text="{Binding Date, StringFormat='{}{0:dd.MM.yyyy}'}" FontSize="16" Foreground="{DynamicResource TextMuted}" Margin="0,8,0,0"/>
                                    </StackPanel>
                                </Button>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>

            </StackPanel>
        </ScrollViewer>
        </Grid>
    </Grid>
</UserControl>
