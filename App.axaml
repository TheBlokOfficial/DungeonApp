<Application xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="DungeonApp.App"
             xmlns:local="using:DungeonApp"
             xmlns:behaviors="using:DungeonApp.Behaviors"
             xmlns:converters="using:DungeonApp.Converters"
             RequestedThemeVariant="Default">
             <!-- "Default" ThemeVariant follows system theme variant. "Dark" or "Light" are other available options. -->

    <Application.DataTemplates>
        <local:ViewLocator/>
    </Application.DataTemplates>

    <Application.Resources>
        <converters:SmartIconConverter x:Key="SmartIconConverter"/>
        <converters:SmartBrushConverter x:Key="SmartBrushConverter"/>
    </Application.Resources>
  
    <Application.Styles>
        <FluentTheme />
        <StyleInclude Source="avares://DungeonApp/Styles/CommonStyles.axaml" />
        <Style Selector="TextBox:focus /template/ Border#PART_BorderElement">
            <Setter Property="Background" Value="{TemplateBinding Background}"/>
        </Style>
        <Style Selector="TextBox:pointerover /template/ Border#PART_BorderElement">
            <Setter Property="Background" Value="{TemplateBinding Background}"/>
        </Style>
        
        <!-- Globalna klasa dla tekstów ucinalnych z ToolTipem (Ellipsis standard) -->
        <Style Selector="TextBlock.dynamic">
            <Setter Property="TextTrimming" Value="CharacterEllipsis"/>
            <Setter Property="behaviors:AutoToolTipBehavior.ShowOnTrimmedOnly" Value="True"/>
        </Style>
    </Application.Styles>
             
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceInclude Source="avares://DungeonApp/Styles/Colors.axaml" />
                <ResourceInclude Source="avares://DungeonApp/Styles/Metrics.axaml" />
            </ResourceDictionary.MergedDictionaries>
            
