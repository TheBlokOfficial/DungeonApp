<ResourceDictionary xmlns="https://github.com/avaloniaui"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:system="clr-namespace:System;assembly=System.Runtime">

    <!-- GLOBALNE SZEROKOŚCI UKŁADU (Fixed Layout Tokens) -->
    <system:Double x:Key="AppLayoutMaxWidth">1500</system:Double>
    <system:Double x:Key="AppContentMaxWidth">1188</system:Double>
    
    <GridLength x:Key="ListPanelWidth">438</GridLength>
    <GridLength x:Key="DetailPanelWidth">812</GridLength>
    <GridLength x:Key="SidebarWidth">312</GridLength>

</ResourceDictionary>
