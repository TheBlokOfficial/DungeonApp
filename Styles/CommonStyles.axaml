<Styles xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Styles.Resources>
        <CornerRadius x:Key="CardCornerRadius">15</CornerRadius>
        <Thickness x:Key="CardPadding">25</Thickness>
        <CornerRadius x:Key="InputBorderRadius">8</CornerRadius>
    </Styles.Resources>

    <!-- 1. Page Container (Centered content, no rigid pixel limits) -->
    <Style Selector="Grid.pageContainer, StackPanel.pageContainer, Border.pageContainer">
        <Setter Property="HorizontalAlignment" Value="Center" />
    </Style>

    <!-- ==================== BUTTON STYLES ==================== -->
    
    <!-- 0. Global Button Transitions (Płynne przejścia dla WSZYSTKICH przycisków) -->
    <Style Selector="Button">
        <Setter Property="RenderTransform" Value="scale(1.0)" />
        <Setter Property="Transitions">
            <Transitions>
                <BrushTransition Property="Background" Duration="0:0:0.2" />
                <BrushTransition Property="BorderBrush" Duration="0:0:0.2" />
                <TransformOperationsTransition Property="RenderTransform" Duration="0:0:0.15" Easing="CubicEaseOut" />
            </Transitions>
        </Setter>
    </Style>
    <Style Selector="Button:pressed">
        <Setter Property="RenderTransform" Value="scale(0.96)" />
    </Style>

    <!-- 1. Accent Button (Złoty, Główna akcja) -->
    <Style Selector="Button.primary">
        <Setter Property="Background" Value="{DynamicResource AccentGold}" />
        <Setter Property="Foreground" Value="{DynamicResource AppBackground}" />
        <Setter Property="FontWeight" Value="Bold" />
        <Setter Property="CornerRadius" Value="{DynamicResource InputBorderRadius}" />
        <Setter Property="Padding" Value="18,10" />
        <Setter Property="HorizontalContentAlignment" Value="Center" />
    </Style>
    <!-- 
        UWAGA: Stan :pressed /template/ ContentPresenter jest wymagany. 
        Domyślny motyw Fluent w Avalonii wymusza szare tło po kliknięciu i wyjechaniu kursorem poza przycisk (utrata hovera).
        Nadpisując ContentPresenter dla :pressed i przypisując mu ten sam kolor co :pointerover, unikamy tego brzydkiego, szarego mignięcia.
    -->
    <Style Selector="Button.primary:pointerover /template/ ContentPresenter, Button.primary:pressed /template/ ContentPresenter">
        <Setter Property="Background" Value="{DynamicResource AccentGoldHover}" />
        <Setter Property="Foreground" Value="{DynamicResource TextPrimary}" />
    </Style>

    <!-- 2. Ghost Button (Poboczny, z subtelnym tłem na hover) -->
    <Style Selector="Button.ghost">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="Foreground" Value="{DynamicResource TextPrimary}" />
        <Setter Property="CornerRadius" Value="{DynamicResource InputBorderRadius}" />
        <Setter Property="Padding" Value="14,9" />
        <Setter Property="HorizontalContentAlignment" Value="Center" />
    </Style>
    <Style Selector="Button.ghost:pointerover /template/ ContentPresenter, Button.ghost:pressed /template/ ContentPresenter">
        <Setter Property="Background" Value="{DynamicResource BorderSecondary}" />
    </Style>

    <!-- 2.5 Secondary Button (Wypełniony szarym tłem) -->
    <Style Selector="Button.secondary">
        <Setter Property="Background" Value="{DynamicResource BorderSecondary}" />
        <Setter Property="Foreground" Value="{DynamicResource TextPrimary}" />
        <Setter Property="CornerRadius" Value="{DynamicResource InputBorderRadius}" />
        <Setter Property="Padding" Value="16,8" />
        <Setter Property="HorizontalContentAlignment" Value="Center" />
    </Style>
    <Style Selector="Button.secondary:pointerover /template/ ContentPresenter, Button.secondary:pressed /template/ ContentPresenter">
        <Setter Property="Background" Value="{DynamicResource HoverGrip}" />
    </Style>

    <!-- 3. Danger Ghost Button (Poboczny, niszczący) -->
    <Style Selector="Button.dangerGhost">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="Foreground" Value="{DynamicResource AccentDanger}" />
        <Setter Property="CornerRadius" Value="{DynamicResource InputBorderRadius}" />
        <Setter Property="Padding" Value="12,8" />
        <Setter Property="HorizontalContentAlignment" Value="Center" />
    </Style>
    <Style Selector="Button.dangerGhost:pointerover /template/ ContentPresenter, Button.dangerGhost:pressed /template/ ContentPresenter">
        <Setter Property="Background" Value="{DynamicResource AccentDanger}" />
        <Setter Property="Foreground" Value="{DynamicResource TextPrimary}" />
    </Style>
    
    <!-- Danger Solid Button -->
    <Style Selector="Button.danger">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="Foreground" Value="{DynamicResource AccentDanger}" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="FontWeight" Value="Bold" />
        <Setter Property="CornerRadius" Value="{DynamicResource InputBorderRadius}" />
        <Setter Property="Padding" Value="18,10" />
        <Setter Property="HorizontalContentAlignment" Value="Center" />
    </Style>
    <Style Selector="Button.danger:pointerover /template/ ContentPresenter, Button.danger:pressed /template/ ContentPresenter">
        <Setter Property="Background" Value="{DynamicResource AccentDanger}" />
        <Setter Property="Foreground" Value="{DynamicResource TextPrimary}" />
    </Style>

    <!-- 4. Success Button -->
    <Style Selector="Button.success">
        <Setter Property="Background" Value="{DynamicResource SuccessBackground}" />
        <Setter Property="Foreground" Value="{DynamicResource TextPrimary}" />
        <Setter Property="FontWeight" Value="Bold" />
        <Setter Property="CornerRadius" Value="{DynamicResource InputBorderRadius}" />
        <Setter Property="Padding" Value="18,10" />
        <Setter Property="HorizontalContentAlignment" Value="Center" />
    </Style>
    <Style Selector="Button.success:pointerover /template/ ContentPresenter, Button.success:pressed /template/ ContentPresenter">
        <Setter Property="Background" Value="{DynamicResource SuccessHoverBackground}" />
        <Setter Property="Foreground" Value="{DynamicResource TextPrimary}" />
    </Style>

    <!-- 5. Icon Button (Mały, przezroczysty, ikona w środku) -->
    <Style Selector="Button.icon">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="Padding" Value="10" />
        <Setter Property="CornerRadius" Value="{DynamicResource InputBorderRadius}" />
        <Setter Property="HorizontalContentAlignment" Value="Center" />
        <Setter Property="VerticalContentAlignment" Value="Center" />
    </Style>
    <Style Selector="Button.icon:pointerover /template/ ContentPresenter, Button.icon:pressed /template/ ContentPresenter, Button.icon.active /template/ ContentPresenter">
        <Setter Property="Background" Value="{DynamicResource HoverGrip}" />
    </Style>
    <Style Selector="Button.icon PathIcon">
        <Setter Property="Foreground" Value="{DynamicResource TextMuted}" />
    </Style>
    <Style Selector="Button.icon:pointerover PathIcon">
        <Setter Property="Foreground" Value="{DynamicResource TextPrimary}" />
    </Style>
    
    <!-- 5.5 Icon Danger Button -->
    <Style Selector="Button.iconDanger">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="Padding" Value="10" />
        <Setter Property="CornerRadius" Value="{DynamicResource InputBorderRadius}" />
        <Setter Property="HorizontalContentAlignment" Value="Center" />
        <Setter Property="VerticalContentAlignment" Value="Center" />
    </Style>
    <Style Selector="Button.iconDanger:pointerover /template/ ContentPresenter, Button.iconDanger:pressed /template/ ContentPresenter">
        <Setter Property="Background" Value="{DynamicResource AccentDanger}" />
    </Style>
    <Style Selector="Button.iconDanger PathIcon">
        <Setter Property="Foreground" Value="{DynamicResource AccentDanger}" />
    </Style>
    <Style Selector="Button.iconDanger:pointerover PathIcon">
        <Setter Property="Foreground" Value="{DynamicResource TextPrimary}" />
    </Style>

    <!-- 6. Card Button (Klikalna karta) -->
    <Style Selector="Button.card">
        <Setter Property="RenderTransform" Value="translateY(0px)" />
        <Setter Property="Background" Value="{DynamicResource CardBackground}" />
        <Setter Property="CornerRadius" Value="{DynamicResource CardCornerRadius}" />
        <Setter Property="Padding" Value="{DynamicResource CardPadding}" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="HorizontalAlignment" Value="Stretch" />
        <Setter Property="HorizontalContentAlignment" Value="Stretch" />
        <Style.Animations>
            <Animation Duration="0:0:0.25" Easing="CubicEaseOut">
                <KeyFrame Cue="0%">
                    <Setter Property="Opacity" Value="0" />
                    <Setter Property="Margin" Value="0,15,0,-15" />
                </KeyFrame>
                <KeyFrame Cue="100%">
                    <Setter Property="Opacity" Value="1" />
                    <Setter Property="Margin" Value="0,0,0,0" />
                </KeyFrame>
            </Animation>
        </Style.Animations>
    </Style>
    <Style Selector="Button.card:pointerover /template/ ContentPresenter, Button.card:pressed /template/ ContentPresenter">
        <Setter Property="Background" Value="{DynamicResource CardHoverBackground}" />
    </Style>
    <Style Selector="Button.card:pointerover">
        <Setter Property="RenderTransform" Value="translateY(-2px)" />
    </Style>
    <Style Selector="Button.card:pressed">
        <Setter Property="RenderTransform" Value="translateY(-2px) scale(0.96)" />
    </Style>

    <!-- ==================== GLOBAL ANIMATIONS ==================== -->
    
    <!-- Płynne przenikanie zakładek bez usuwania z drzewa -->
    <Style Selector=":is(UserControl).fadeTab, :is(Border).fadeTab">
        <Setter Property="Opacity" Value="0" />
        <Setter Property="IsHitTestVisible" Value="False" />
        <Setter Property="Transitions">
            <Transitions>
                <DoubleTransition Property="Opacity" Duration="0:0:0.25" />
            </Transitions>
        </Setter>
    </Style>
    <Style Selector=":is(UserControl).fadeTab.active, :is(Border).fadeTab.active">
        <Setter Property="Opacity" Value="1" />
        <Setter Property="IsHitTestVisible" Value="True" />
    </Style>

    <!-- Wyskakiwanie (Pop-up) -->
    <Style Selector=":is(Control).popModal">
        <Setter Property="RenderTransform">
            <ScaleTransform ScaleX="1" ScaleY="1" />
        </Setter>
        <Style.Animations>
            <Animation Duration="0:0:0.25" Easing="CubicEaseOut">
                <KeyFrame Cue="0%">
                    <Setter Property="Opacity" Value="0" />
                    <Setter Property="ScaleTransform.ScaleX" Value="0.95" />
                    <Setter Property="ScaleTransform.ScaleY" Value="0.95" />
                </KeyFrame>
                <KeyFrame Cue="100%">
                    <Setter Property="Opacity" Value="1" />
                    <Setter Property="ScaleTransform.ScaleX" Value="1.0" />
                    <Setter Property="ScaleTransform.ScaleY" Value="1.0" />
                </KeyFrame>
            </Animation>
        </Style.Animations>
    </Style>

    <!-- Wjazd z krawędzi (Slide-in) -->
    <Style Selector=":is(Control).slideInPanel">
        <Setter Property="RenderTransform">
            <TranslateTransform X="0" Y="0" />
        </Setter>
        <Style.Animations>
            <Animation Duration="0:0:0.3" Easing="CubicEaseOut">
                <KeyFrame Cue="0%">
                    <Setter Property="Opacity" Value="0" />
                    <Setter Property="TranslateTransform.X" Value="40" />
                </KeyFrame>
                <KeyFrame Cue="100%">
                    <Setter Property="Opacity" Value="1" />
                    <Setter Property="TranslateTransform.X" Value="0" />
                </KeyFrame>
            </Animation>
        </Style.Animations>
    </Style>

    <!-- Płynne wsuwanie list (Slide-up) -->
    <Style Selector=":is(Control).slideUpItem">
        <Setter Property="RenderTransform">
            <TranslateTransform X="0" Y="0" />
        </Setter>
        <Style.Animations>
            <Animation Duration="0:0:0.25" Easing="CubicEaseOut">
                <KeyFrame Cue="0%">
                    <Setter Property="Opacity" Value="0" />
                    <Setter Property="TranslateTransform.Y" Value="20" />
                </KeyFrame>
                <KeyFrame Cue="100%">
                    <Setter Property="Opacity" Value="1" />
                    <Setter Property="TranslateTransform.Y" Value="0" />
                </KeyFrame>
            </Animation>
        </Style.Animations>
    </Style>
</Styles>
